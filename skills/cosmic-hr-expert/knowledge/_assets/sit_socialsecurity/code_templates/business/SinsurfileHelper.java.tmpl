    // 根据带角度，调用接口更新社保基数设置
    public void alterSocialFileBase(DynamicObject bill, HashMap<String, Long> insuranceProp) {
        long sinsurfileid = bill.getLong("${ISV_FLAG}_person.id");           //社保档案
        DynamicObject payCompany = bill.getDynamicObject("${ISV_FLAG}_paying_company");
        // 根据代缴公司获取参保标准的参保标准生效日期
        Date effectDate = bill.getDate("${ISV_FLAG}_effective_date");

        // 根据代缴公司获取参保标准的参保标准
        Long sinSurstdandarId = getSinSurstdandarId(bill);
        if (effectDate == null || sinSurstdandarId.equals(0L))
            throw new KDBizException("公司【" + payCompany.getString("name") + "】没有设置参保标准");

        DynamicObjectCollection entryentity = bill.getDynamicObjectCollection("${ISV_FLAG}_base_entryentity");
        //如果参保标准没有对应险种，则不进行处理
        ArrayList<String> insurTypeList = this.getSinsurstd(sinSurstdandarId);
        //查找险种
        HashMap<String, Long> welfareTypes = getWelfaretypeMap();

        QFilter sinsurBase = new QFilter("sinsurfile", QCP.equals, sinsurfileid);
        sinsurBase.and(new QFilter("insured", QCP.equals, "1"));
        DynamicObject[] hcSiSinSurBases = BusinessDataServiceHelper.load("hcsi_sibase", "id,insured,welfaretype.name,welfaretype.number,startdate,paybaseofemployee,paybaseofcompany,enddate,sinsurfile,${ISV_FLAG}_radix_table,description", sinsurBase.toArray());
        HashMap<Long, DynamicObject> sinSurFileMap = new HashMap<>();
        for (DynamicObject hcSiSinSurBase : hcSiSinSurBases) {
            sinSurFileMap.put(hcSiSinSurBase.getLong("welfaretype.id"), hcSiSinSurBase);
        }

        for (DynamicObject entry : entryentity) {
            // 业务类型：A-社保，B-公积金
            String insuranceType = entry.getString("${ISV_FLAG}_base_insurance_e");
            HashMap<String, Object[]> insuranceConfig = getInsuranceConfigs().get(insuranceType);
            if (insuranceConfig == null)
                continue;
            // 遍历 社保或公积金 的险种配置，构建变更所需的数据包
            for (String insurancekey : insuranceConfig.keySet()) {
                //如果参保标准没有对应险种，则不进行处理
                if (!insurTypeList.contains(insurancekey)) {
                    continue;
                }
                // 根据配置，获取变更单据的基数字段名，并获取变更的基数字段数据
                Object[] insuranceData = insuranceConfig.get(insurancekey);
                if (insuranceData == null)
                    continue;
                Object value = entry.get((String) insuranceData[1]);
                long welfaretypeid = welfareTypes.get(insurancekey);
                BigDecimal amount = TypeConvertUtil.objToBigDecimal(value);
                if (!sinSurFileMap.isEmpty() && sinSurFileMap.containsKey(welfaretypeid)) {
                    DynamicObject sinSurFileBase = sinSurFileMap.get(welfaretypeid);
                    sinSurFileBase.set("paybaseofemployee", amount);
                    sinSurFileBase.set("paybaseofcompany", amount);
//                    sinSurFileBase.set("${ISV_FLAG}_radix_table",bill.getLong("${ISV_FLAG}_radix_table.id"));
                    sinSurFileBase.set("startdate", effectDate);
                    sinSurFileBase.set("insured", "1");
                }
            }
        }
        SaveServiceHelper.save(hcSiSinSurBases);
    }


    /**
     * 新增人员社保档案
     *
     * @param bill 代缴申请单
     */
    private DynamicObject[] addNewFile(DynamicObject bill) {
        long sinsurfileid = bill.getLong("${ISV_FLAG}_person.id");                         //社保档案id
        DynamicObject sinsurfile = BusinessDataServiceHelper.loadSingle(sinsurfileid, "hcsi_sinsurfile");
        Date effectiveDate = bill.getDate("${ISV_FLAG}_effective_date");                   //生效日期
        DynamicObject payCompany = bill.getDynamicObject("${ISV_FLAG}_paying_company");    //实际参保单位，代缴单内“代缴公司”
        //1.人员社保档案基本信息
        HRBaseServiceHelper serviceHelper = new HRBaseServiceHelper(SITEntityConstants.HCSI_SINSURFILE);
        DynamicObject newFile = serviceHelper.generateEmptyDynamicObject();
        newFile.set("id", ID.genLongId());
        newFile.set("isescrowstaff", Boolean.TRUE);                  //设置是否代管员工
        newFile.set("welfarepayertheory", bill.getDynamicObject("${ISV_FLAG}_insured_company"));   //理论参保单位,取代缴单上的理论参保单位
        newFile.set("sinsurstatus", "normal");                      //设置参保状态 normal-正常缴纳  seal-停止缴纳
        newFile.set("bsed", effectiveDate);                          //设置生效日期
        newFile.set("comment", bill.get("${ISV_FLAG}_description"));        //备注代缴单内“描述”
        newFile.set("employee", sinsurfile.get("employee"));          //设置企业人
        newFile.set("empposorgrel", sinsurfile.getDynamicObject("empposorgrel"));                //设置自然人
        newFile.set("sinsurstd", sinsurfile.getDynamicObject("sinsurstd"));
        newFile.set("assignment", sinsurfile.getDynamicObject("assignment"));
        newFile.set("creator", RequestContext.get().getCurrUserId());       //创建人
        //调用编码规则生成档案编码
        String number = CodeRuleServiceHelper.getNumber(SITEntityConstants.HCSI_SINSURFILE, newFile, null);
        newFile.set("number", number);                               //设置编码
        //设置社保公积金管理组织，代缴单内“代缴公司”所属的社保公积金管理组织
        newFile.set("org", payCompany.get("org"));
        newFile.set("manageregion", payCompany.get("country"));     //社保管理属地，默认中国
        newFile.set("empgroup", sinsurfile.get("empgroup"));        //设置社保人员组,默认“默认社保人员组”
        newFile.set("welfarepayer", payCompany);                    //设置实际参保单位，代缴单内“代缴公司”
        //3.调用接口，保存社保人员档案
        OperationServiceImpl operationService = new OperationServiceImpl();
        OperateOption operateOption = OperateOption.create();
        operateOption.setVariableValue("ishasright", "true");
        operateOption.setVariableValue("skipCheckDataPermission", "true");
        operateOption.setVariableValue("skipCheckSpecialDataPermission", "true");
        OperationResult saveResult = operationService.localInvokeOperation("save", new DynamicObject[]{newFile}, operateOption);
        OperateResultCheck.check(saveResult, "保存人员社保档案");
        return new DynamicObject[]{newFile};
    }


    /**
     * 调用微服务接口，新增社保基数设置
     *
     * @param bill       代缴单
     * @param newFile    新增的社保档案
     * @param uniqueCode 唯一识别码
     */
    protected void addNewFileBase(DynamicObject bill, DynamicObject newFile, String uniqueCode, HashMap<String, Long> insuranceProp) {
        Long sinSurFileId = bill.getLong("${ISV_FLAG}_person.id");
        DynamicObject payCompany = bill.getDynamicObject("${ISV_FLAG}_paying_company");
        // 根据代缴公司获取参保标准的参保标准
        Long sinSurstdandarId = getSinSurstdandarId(bill);
        Date effectDate = bill.getDate("${ISV_FLAG}_effective_date");
        if (effectDate == null || sinSurstdandarId.equals(0L))
            throw new KDBizException("公司【" + payCompany.getString("name") + "】没有设置参保标准");

        //如果参保标准没有对应险种，则不进行处理
        ArrayList<String> insurTypeList = this.getSinsurstd(sinSurstdandarId);
        //查找险种
        HashMap<String, Long> welfareTypes = getWelfaretypeMap();

        DynamicObjectCollection entryentity = bill.getDynamicObjectCollection("entryentity");
        List<DynamicObject> insertSiBase = new ArrayList<>();
        for (DynamicObject entry : entryentity) {
            // 业务类型：A-社保，B-公积金
            String insuranceType = entry.getString("${ISV_FLAG}_payment_insurance_e");
            HashMap<String, Object[]> insuranceConfig = getInsuranceConfigs().get(insuranceType);
            if (insuranceConfig == null)
                continue;
            // 遍历 社保或公积金 的险种配置，构建变更所需的数据包
            for (String insurancekey : insuranceConfig.keySet()) {
                //如果参保标准没有对应险种，则不进行处理
                if (!insurTypeList.contains(insurancekey)) {
                    continue;
                }
                // 根据配置，获取变更单据的基数字段名，并获取变更的基数字段数据
                Object[] insuranceData = insuranceConfig.get(insurancekey);
                if (insuranceData == null)
                    continue;
                Object value = entry.get((String) insuranceData[0]);
                long welfareTypeId = welfareTypes.get(insurancekey);
                BigDecimal amount = TypeConvertUtil.objToBigDecimal(value);
                DynamicObject siBase = BusinessDataServiceHelper.newDynamicObject("hcsi_sibase");
                siBase.set("sinsurfile", newFile.getLong("id"));
                siBase.set("welfaretype", welfareTypeId);
                siBase.set("paybaseofemployee", amount);
                siBase.set("iscurrentdata", true);
                siBase.set("paybaseofcompany", amount);
                siBase.set("startdate", effectDate);
                siBase.set("insured", "1");
                siBase.set("${ISV_FLAG}_radix_table", bill.getLong("${ISV_FLAG}_radix_table.id"));
                try {
                    siBase.set("enddate", new SimpleDateFormat("yyyy-MM-dd").parse("2999-12-31"));
                } catch (ParseException e) {
//                    e.printStackTrace();
                }
                insertSiBase.add(siBase);
            }
        }
        SaveServiceHelper.save(insertSiBase.toArray(new DynamicObject[0]));
    }

    /**
     * 在参保单位中获取参保标准
     *
     * @param bill
     * @return
     */
    private Long getSinSurstdandarId(DynamicObject bill) {
        Long sinSurstdandarId = 0L;
        DynamicObject payCompany = bill.getDynamicObject("${ISV_FLAG}_paying_company");
        if (Objects.nonNull(payCompany)) {
            DynamicObjectCollection mulSinSurStd = payCompany.getDynamicObjectCollection("mulsinsurstd");
            if (kd.bos.util.CollectionUtils.isNotEmpty(mulSinSurStd)) {
                sinSurstdandarId = mulSinSurStd.get(0).getLong("fbasedataid.id");
            }
        }
        return sinSurstdandarId;
    }


    /**
     * 构建员工社保的单个险种的【变更、停缴】数据包：生效日期、是否参保
     * sinsurfileid：社保档案id
     * welfareTypeId：险种id
     * effectDate：生效日期
     * amounts：缴费基数，如果是停缴可为空
     * isInsured：是否参保
     * uniqueCode：唯一标识
     */
    private HashMap<String, Object> createAlterDataMap(long sinsurfileid, long welfareTypeId,
                                                       Date effectDate, BigDecimal amount, Boolean isInsured, String description, String uniqueCode, HashMap<String, Long> insuranceProp) {
        HashMap<String, Object> dataMap = new HashMap<>();
        dataMap.put("uniqueCode", uniqueCode);                //唯一标识
        // 构建险种的变更数据包
        HashMap<String, Object> baseData = createBaseDataMap(welfareTypeId, effectDate, amount, isInsured, description, insuranceProp);
        baseData.put("sinSurFileId", sinsurfileid);       //社保档案id
        dataMap.put("sinSurFileBase", baseData);
        return dataMap;
    }


    /**
     * 构建员工社保的单个险种的接口数据包：生效日期、是否参保
     * welfareTypeId：险种id
     * effectDate：生效日期
     * amounts：缴费基数，如果是停缴可为空
     * isInsured：是否参保
     */
    public HashMap<String, Object> createBaseDataMap(long welfareTypeId,
                                                     Date effectDate, BigDecimal amount, Boolean isInsured, String description, HashMap<String, Long> insuranceProp) {
        // 构建险种的变更数据
        HashMap<String, Object> baseData = new HashMap<>();
        baseData.put("welfareTypeId", welfareTypeId);     //险种ID
        baseData.put("bsed", effectDate);                 //生效日期
        baseData.put("insured", isInsured);               //是否参保
        baseData.put("description", description);          //备注说明
        // 构建险种属性的变更数据
        ArrayList<Map> insuranceItemList = new ArrayList<>(); //险种项目信息
        baseData.put("insuranceItem", insuranceItemList); //险种项目信息
        //6.1设置个人缴费基数
        HashMap<String, Object> itemData = new HashMap<>();
        itemData.put("insurancePropId", insuranceProp.get("1001_S"));       //险种属性ID
        itemData.put("insurancePropValue", amount == null ? BigDecimal.ZERO : amount);
        insuranceItemList.add(itemData);
        //6.2设置单位缴费基数
        itemData = new HashMap<>();
        itemData.put("insurancePropId", insuranceProp.get("1002_S"));       //险种属性ID
        itemData.put("insurancePropValue", amount == null ? BigDecimal.ZERO : amount);
        insuranceItemList.add(itemData);
        return baseData;
    }


    // 获取所有险种的【编码-ID】映射表
    protected HashMap<String, Long> getWelfaretypeMap() {
        if (welfaretypeHashMap == null) {
            welfaretypeHashMap = new HashMap<>();
            QFilter insurancePropFilter = new QFilter("status", QCP.equals, "C");
            insurancePropFilter.and("enable", QCP.equals, "1");
            DynamicObjectCollection insuranceProp = QueryServiceHelper.query("sitbs_welfaretype",
                    "id,number,name", insurancePropFilter.toArray());
            for (DynamicObject item : insuranceProp) {
                welfaretypeHashMap.put(item.getString("number"), item.getLong("id"));
            }
        }
        return welfaretypeHashMap;
    }


    // 获取所有险种属性的【编码-ID】映射表
    public static HashMap<String, Long> getInsuranceProp() {
        HashMap<String, Long> insurancePropHashMap = new HashMap<>();
        QFilter insurancePropFilter = new QFilter("status", QCP.equals, "C");
        insurancePropFilter.and("enable", QCP.equals, "1");
        DynamicObjectCollection insuranceProp = QueryServiceHelper.query("sitbs_insuranceprop",
                "id,number", insurancePropFilter.toArray());
        for (DynamicObject item : insuranceProp) {
            insurancePropHashMap.put(item.getString("number"), item.getLong("id"));
        }
        return insurancePropHashMap;
    }


    // 检查社保接口返回结果，如果有异常则抛出
    protected void checkServiceResult(Map<String, Object> serviceResult) {
        JSONArray resultData = (JSONArray) serviceResult.get("data");
        if (resultData.size() > 0) {
            JSONObject oneResultData = resultData.getJSONObject(0);
            throw new KDBizException("设置社保基数出现异常（" + oneResultData.getString("errorCode") + oneResultData.getString("message") + "），请前往人员社保档案手动修改");
        }
    }

    //新增代缴时，发现在其代缴公司已有档案，则根据档案id进行更新代缴档案，而不是新增代缴档案
    //社保代缴调整-若遇到实际代缴单位已存在档案：
    // 1、首先禁用理论参保单位档案或者对应代缴险种，然后更新代缴单位档案；
    // 2、更新代缴单位档案时，同时打开按钮“代管员工”，赋值“理论参保单位”为代缴单的“理论参保单位”
    public void addSocialFileBase(Long sinsurfileid, DynamicObject bill, HashMap<String, Long> insuranceProp) {
        //原档案处理
        DynamicObjectCollection entryentity = bill.getDynamicObjectCollection("entryentity");
        HashMap<String, BigDecimal> socialBaseValueMap = getsocialBaseValueMap();
        for (DynamicObject entry : entryentity) {
            String insuranceTypeEntry = entry.getString("${ISV_FLAG}_payment_insurance_e");
            if ("A".equals(insuranceTypeEntry)) {
                //社保
                BigDecimal endowmentE = entry.getBigDecimal("${ISV_FLAG}_endowment_e");
                BigDecimal medicalE = entry.getBigDecimal("${ISV_FLAG}_medical_e");
                BigDecimal unemploymentE = entry.getBigDecimal("${ISV_FLAG}_unemployment_e");
                BigDecimal industrialInjuryE = entry.getBigDecimal("${ISV_FLAG}_industrial_injury_e");
                BigDecimal maternityE = entry.getBigDecimal("${ISV_FLAG}_maternity_e");
                BigDecimal supplyMedicaE = entry.getBigDecimal("${ISV_FLAG}_supply_medica_e");

                socialBaseValueMap.put("1010_S", endowmentE); //养老保险
                socialBaseValueMap.put("1020_S", medicalE); //医疗保险
                socialBaseValueMap.put("1030_S", unemploymentE); //失业保险
                socialBaseValueMap.put("1040_S", industrialInjuryE); //工伤保险
                socialBaseValueMap.put("1050_S", maternityE); //生育保险
                socialBaseValueMap.put("1070_S", supplyMedicaE); //补充医疗保险
            }

            if ("B".equals(insuranceTypeEntry)) {
                //公积金
                BigDecimal housingE = entry.getBigDecimal("${ISV_FLAG}_housing_e");
                socialBaseValueMap.put("1060_S", housingE); //住房公积金
            }
        }
        long oldSinsurFileId = bill.getLong("${ISV_FLAG}_person.id");                        //原社保档案id
        Date effectiveDate = bill.getDate("${ISV_FLAG}_effective_date");                  //生效日期
        String oldInsuranceType = bill.getString("${ISV_FLAG}_payment_insurance");           //业务类型：A-社保，B-公积金
        stopSocialFileByValue(oldSinsurFileId, effectiveDate, oldInsuranceType, bill, socialBaseValueMap);

        //将已有的档案处理为代缴档案
        DynamicObject payCompany = bill.getDynamicObject("${ISV_FLAG}_paying_company");
        // 根据代缴公司获取参保标准的参保标准
        Long sinSurstdandarId = getSinSurstdandarId(bill);
        Date effectDate = bill.getDate("${ISV_FLAG}_effective_date");
        if (effectDate == null || sinSurstdandarId.equals(0L))
            throw new KDBizException("公司【" + payCompany.getString("name") + "】没有设置参保标准");

        ArrayList<String> insurTypeList = this.getSinsurstd(sinSurstdandarId);
        //查找险种
        HashMap<String, Long> welfareTypes = getWelfaretypeMap();
        List<DynamicObject> insertSiBase = new ArrayList<>();
        for (DynamicObject entry : entryentity) {
            // 业务类型：A-社保，B-公积金
            String insuranceType = entry.getString("${ISV_FLAG}_payment_insurance_e");
            HashMap<String, Object[]> insuranceConfig = getInsuranceConfigs().get(insuranceType);
            if (insuranceConfig == null)
                continue;
            // 遍历 社保或公积金 的险种配置，构建变更所需的数据包
            for (String insurancekey : insuranceConfig.keySet()) {
                //如果参保标准没有对应险种，则不进行处理
                if (!insurTypeList.contains(insurancekey)) {
                    continue;
                }
                // 根据配置，获取变更单据的基数字段名，并获取变更的基数字段数据
                Object[] insuranceData = insuranceConfig.get(insurancekey);
                if (insuranceData == null)
                    continue;
                Object value = entry.get((String) insuranceData[0]);
                long welfaretypeid = welfareTypes.get(insurancekey);
                BigDecimal amount = TypeConvertUtil.objToBigDecimal(value);
                DynamicObject siBase = BusinessDataServiceHelper.newDynamicObject("hcsi_sibase");
                siBase.set("sinsurfile", sinsurfileid);
                siBase.set("welfaretype", welfaretypeid);
                siBase.set("paybaseofemployee", amount);
                siBase.set("iscurrentdata", true);
                siBase.set("paybaseofcompany", amount);
                siBase.set("startdate", effectDate);
                siBase.set("insured", "1");
                siBase.set("${ISV_FLAG}_radix_table", bill.getLong("${ISV_FLAG}_radix_table.id"));
                try {
                    siBase.set("enddate", new SimpleDateFormat("yyyy-MM-dd").parse("2999-12-31"));
                } catch (ParseException e) {
//                    e.printStackTrace();
                }
                insertSiBase.add(siBase);
            }
        }
        SaveServiceHelper.save(insertSiBase.toArray(new DynamicObject[0]));

        //根据档案id查询其代缴档案，如果为参保状态为正常缴纳，则不做处理，如果为停止缴纳，修改为正常缴纳
        DynamicObject sinsurfile = BusinessDataServiceHelper.loadSingle(sinsurfileid, "hcsi_sinsurfile");
        if (sinsurfile != null) {
            String sinsurstatus = sinsurfile.getString("sinsurstatus");
            if ("seal".equals(sinsurstatus)) {
                sinsurfile.set("sinsurstatus", "normal");
                sinsurfile.set("sinsurstatus", "normal");//正常缴纳
                sinsurfile.set("bsed", effectiveDate); //生效日期改为代缴单的生效日期
                sinsurfile.set("isescrowstaff", "1"); //代管员工
                sinsurfile.set("welfarepayertheory", bill.getDynamicObject("${ISV_FLAG}_insured_company"));//理论参保单位
                //更新人员社保档案
                OperationServiceImpl operationService = new OperationServiceImpl();
                OperateOption operateOption = OperateOption.create();
                operateOption.setVariableValue("ishasright", "true");
                operateOption.setVariableValue("skipCheckDataPermission", "true");
                operateOption.setVariableValue("skipCheckSpecialDataPermission", "true");
                OperationResult saveResult = operationService.localInvokeOperation("save", new DynamicObject[]{sinsurfile}, operateOption);
                OperateResultCheck.check(saveResult, "新增代缴时,更新人员社保档案");
            }
        }
    }

    /**
     * 根据参保标准id,查询险种编码
     */
    public ArrayList<String> getSinsurstd(Long sinSurstdandarId) {
        //根据参保标准查询险种
        ArrayList<String> insurTypeList = new ArrayList<>();
        DynamicObject sitbsSinsurstd = BusinessDataServiceHelper.loadSingle(sinSurstdandarId, "sitbs_sinsurstd");
        DynamicObjectCollection stdentryentity = sitbsSinsurstd.getDynamicObjectCollection("stdentryentity");
        for (DynamicObject entry : stdentryentity) {
            String insurTypeNumber = entry.getString("insurtype.number");
            insurTypeList.add(insurTypeNumber);
        }
        return insurTypeList;
    }
