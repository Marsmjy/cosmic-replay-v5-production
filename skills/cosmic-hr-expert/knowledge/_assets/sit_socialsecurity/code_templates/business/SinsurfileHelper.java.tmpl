    private static HashMap<String, BigDecimal> getsocialBaseValueMap() {
        HashMap<String, BigDecimal> socialBaseValueMap = new HashMap<>();
        //初始化险种目的值，用于判断是否将档案的险种停缴纳，值为0，不进行停缴
        socialBaseValueMap.put("1010_S", BigDecimal.ZERO); //养老保险
        socialBaseValueMap.put("1020_S", BigDecimal.ZERO); //医疗保险
        socialBaseValueMap.put("1030_S", BigDecimal.ZERO); //失业保险
        socialBaseValueMap.put("1040_S", BigDecimal.ZERO); //工伤保险
        socialBaseValueMap.put("1050_S", BigDecimal.ZERO); //生育保险
        socialBaseValueMap.put("1070_S", BigDecimal.ZERO); //补充医疗保险
        socialBaseValueMap.put("1060_S", BigDecimal.ZERO); //住房公积金
        return socialBaseValueMap;
    }

    private static HashMap<String, HashMap<String, Object[]>> getInsuranceConfigs() {
        HashMap<String, HashMap<String, Object[]>> insuranceConfigs = new HashMap<>();
        // 社保、公积金的配置
        insuranceConfigs.put("A", getSocialConfigs());
        insuranceConfigs.put("B", getFundConfigs());
        return insuranceConfigs;
    }

    private static HashMap<String, Object[]> getFundConfigs() {
        HashMap<String, Object[]> fundConfigs = new HashMap<>();
        // 配置公积金【新增/修改/停用】的保险项目，以及该项目在【代缴申请单】上的新增时/变更时对应的基数字段名称
        fundConfigs.put("1060_S", new Object[]{"${ISV_FLAG}_housing_e", "${ISV_FLAG}_base_housing_e1"}); //住房公积金
        return fundConfigs;
    }


    private static HashMap<String, Object[]> getSocialConfigs() {
        // 配置社保【新增/修改/停用】的保险项目，以及该项目在【代缴申请单】上的新增时/变更时对应的基数字段名称
        HashMap<String, Object[]> socialConfigs = new HashMap<>();
        socialConfigs.put("1010_S", new Object[]{"${ISV_FLAG}_endowment_e", "${ISV_FLAG}_base_endowment_e1"}); //养老保险
        socialConfigs.put("1020_S", new Object[]{"${ISV_FLAG}_medical_e", "${ISV_FLAG}_base_medical_e1"}); //医疗保险
        socialConfigs.put("1030_S", new Object[]{"${ISV_FLAG}_unemployment_e", "${ISV_FLAG}_unemployment_e1"}); //失业保险
        socialConfigs.put("1040_S", new Object[]{"${ISV_FLAG}_industrial_injury_e", "${ISV_FLAG}_base_injury_e1"}); //工伤保险
        socialConfigs.put("1050_S", new Object[]{"${ISV_FLAG}_maternity_e", "${ISV_FLAG}_base_maternity_e1"}); //生育保险
        socialConfigs.put("1070_S", new Object[]{"${ISV_FLAG}_supply_medica_e", "${ISV_FLAG}_base_medica_e1"}); //补充医疗保险
        return socialConfigs;
    }


    // 代缴申请单业务处理
    public Long doSinsurAgnetPay(DynamicObject bill, HashMap<String, Long> insuranceProp) {
        long sinsurfileid = bill.getLong("${ISV_FLAG}_person.id");                        //社保档案id
        Date effectiveDate = bill.getDate("${ISV_FLAG}_effective_date");                  //生效日期
        String insuranceType = bill.getString("${ISV_FLAG}_payment_insurance");           //业务类型：A-社保，B-公积金
        DynamicObject serviceType = (DynamicObject) bill.get("${ISV_FLAG}_payment_service_type");       //代缴业务类型
        String serviceTypeName = serviceType.getString("number");
        if ("001".equals(serviceTypeName)) {
            //新增代缴处理
            //原档案处理
            DynamicObjectCollection entryentity = bill.getDynamicObjectCollection("entryentity");
            HashMap<String, BigDecimal> socialBaseValueMap = getsocialBaseValueMap();
            for (DynamicObject entry : entryentity) {
                String insuranceTypeEntry = entry.getString("${ISV_FLAG}_payment_insurance_e");
                if ("A".equals(insuranceTypeEntry)) {
                    //社保
                    BigDecimal endowmentE = entry.getBigDecimal("${ISV_FLAG}_endowment_e");
                    BigDecimal medicalE = entry.getBigDecimal("${ISV_FLAG}_medical_e");
                    BigDecimal unemploymentE = entry.getBigDecimal("${ISV_FLAG}_unemployment_e");
                    BigDecimal industrialInjuryE = entry.getBigDecimal("${ISV_FLAG}_industrial_injury_e");
                    BigDecimal maternityE = entry.getBigDecimal("${ISV_FLAG}_maternity_e");
                    BigDecimal supplyMedicaE = entry.getBigDecimal("${ISV_FLAG}_supply_medica_e");

                    socialBaseValueMap.put("1010_S", endowmentE); //养老保险
                    socialBaseValueMap.put("1020_S", medicalE); //医疗保险
                    socialBaseValueMap.put("1030_S", unemploymentE); //失业保险
                    socialBaseValueMap.put("1040_S", industrialInjuryE); //工伤保险
                    socialBaseValueMap.put("1050_S", maternityE); //生育保险
                    socialBaseValueMap.put("1070_S", supplyMedicaE); //补充医疗保险
                }

                if ("B".equals(insuranceTypeEntry)) {
                    //公积金
                    BigDecimal housingE = entry.getBigDecimal("${ISV_FLAG}_housing_e");
                    socialBaseValueMap.put("1060_S", housingE); //住房公积金
                }
            }
            stopSocialFileByValue(sinsurfileid, effectiveDate, insuranceType, bill, socialBaseValueMap);
            //新增档案
            DynamicObject[] newAddResults = addNewFile(bill);
            DynamicObject newFile = newAddResults[0];
            //社保基数设置
            addNewFileBase(bill, newFile, UUID.randomUUID().toString(), insuranceProp);
            // 提交和审核社保档案
            OperationServiceImpl operationService = new OperationServiceImpl();
            OperateOption operateOption = OperateOption.create();
            operateOption.setVariableValue("ishasright", "true");
            operateOption.setVariableValue("skipCheckDataPermission", "true");
            operateOption.setVariableValue("skipCheckSpecialDataPermission", "true");
            OperationResult saveResult = operationService.localInvokeOperation("submit", "hcsi_sinsurfile", new Object[]{newFile.get("id")}, operateOption);
            OperateResultCheck.check(saveResult, "提交人员社保档案");
            operateOption = OperateOption.create();
            operateOption.setVariableValue("ishasright", "true");
            operateOption.setVariableValue("skipCheckDataPermission", "true");
            operateOption.setVariableValue("skipCheckSpecialDataPermission", "true");
            saveResult = operationService.localInvokeOperation("audit", "hcsi_sinsurfile", new Object[]{newFile.get("id")}, operateOption);
            OperateResultCheck.check(saveResult, "审核人员社保档案");
            return newFile.getLong("id");
        } else if ("002".equals(serviceTypeName)) {
            //停止代缴处理
            stopSocialFile(sinsurfileid, effectiveDate, insuranceType, insuranceProp);
        } else if ("003".equals(serviceTypeName)) {
            //基数调整处理
            alterSocialFileBase(bill, insuranceProp);
        }
        return sinsurfileid;
    }


    /**
     * 社保档案停缴_代缴使用，只停缴代缴单中险种有值的基数设置
     * sinsurfileid：社保档案id
     * effectiveDate：生效日期
     * insuranceType：业务类型：A-社保，B-公积金，A,B-社保＋公积金
     */
    public void stopSocialFileByValue(long sinsurfileid, Date effectiveDate, String insuranceType, DynamicObject bill, HashMap<String, BigDecimal> socialBaseValueMap) {
        DynamicObject sinsurfile = BusinessDataServiceHelper.loadSingle(sinsurfileid, "hcsi_sinsurfile");
        String status = sinsurfile.getString("status");                 //数据状态
        String sinsurStatus = sinsurfile.getString("sinsurstatus");     //参保状态
        // 如果社保档案是暂存状态，那么改为废弃状态
        if ("A".equals(status)) {
            sinsurfile.set("status", "E");
            OperationServiceImpl opImpl = new OperationServiceImpl();
            OperateOption operateOption = OperateOption.create();
            operateOption.setVariableValue("ishasright", "true");
            operateOption.setVariableValue("skipCheckDataPermission", "true");
            operateOption.setVariableValue("skipCheckSpecialDataPermission", "true");
            OperationResult operationResult = opImpl.localInvokeOperation("save", new DynamicObject[]{sinsurfile}, operateOption);
            OperateResultCheck.check(operationResult, "保存社保档案");
        }
        //  若“数据状态”为“已废弃”，那么档案不做处理
        else if ("E".equals(status)) {
        } else {
            // 获取社保人员的已参保的基数设置，然后进行停止代缴
            QFilter sinsurBase = new QFilter("sinsurfile", QCP.equals, sinsurfileid);
            sinsurBase.and(new QFilter("insured", QCP.equals, "1"));
            DynamicObject[] hcsiSinsurbases = BusinessDataServiceHelper.load("hcsi_sibase", "id,insured,welfaretype.name,welfaretype.number,startdate,paybaseofemployee,paybaseofcompany,enddate,sinsurfile,${ISV_FLAG}_radix_table,description", sinsurBase.toArray());
            for (DynamicObject item : hcsiSinsurbases) {
                String welfaretype_number = item.getString("welfaretype.number");
                if (insuranceType.contains("A") && getSocialConfigs().containsKey(welfaretype_number) // 公积金判断
                        || insuranceType.contains("B") && getFundConfigs().containsKey(welfaretype_number)) // 社保判断
                {
                    //只停缴值为不为0的险种
                    BigDecimal welfareValue = socialBaseValueMap.get(welfaretype_number);
                    if (welfareValue != null && welfareValue.compareTo(BigDecimal.ZERO) > 0) {
                        //场将原档案内社保险种的“是否参保”改成“否”，对应“生效日期”改为代缴单内【代缴信息】的“生效日期”
                        item.set("insured", "0");        //是否参保
                        item.set("startdate", effectiveDate);//生效日期改为代缴单的生效日期
                        item.set("paybaseofemployee", BigDecimal.ZERO);
                        item.set("paybaseofcompany", BigDecimal.ZERO);
                    }
                }
            }
            SaveServiceHelper.save(hcsiSinsurbases);
            // 若原档案内所有险种的“是否参保”均为否，那么将原档案“参保状态”改为“停止缴纳”, 停止缴纳日期为代缴单内【代缴信息】的“生效日期”。
            boolean isAllStoped = true;
            for (DynamicObject hcsiSinsurbase : hcsiSinsurbases) {
                isAllStoped = isAllStoped && !hcsiSinsurbase.getBoolean("insured");
            }
            // 如果全部险种停缴，并且社保状态不是停缴，那么停止社保档案
            if (isAllStoped && !"seal".equals(sinsurStatus)) {
                sinsurfile.set("sinsurstatus", "seal");
                sinsurfile.set("bsed", effectiveDate); //生效日期改为代缴单的生效日期
                //更新人员社保档案
                OperationServiceImpl opImpl = new OperationServiceImpl();
                OperateOption operateOption = OperateOption.create();
                operateOption.setVariableValue("ishasright", "true");
                operateOption.setVariableValue("skipCheckDataPermission", "true");
                operateOption.setVariableValue("skipCheckSpecialDataPermission", "true");
                OperationResult operationResult = opImpl.localInvokeOperation("save", new DynamicObject[]{sinsurfile}, operateOption);
                OperateResultCheck.check(operationResult, "更新人员社保档案");
            }
        }
    }


