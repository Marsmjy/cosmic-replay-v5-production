    public void hideFields(String insurTypeList, String paymentServiceTypeNumber) {
        if ("001".equals(paymentServiceTypeNumber)) {
            setEntryHide(insurTypeList, "0");
        }

        if ("002".equals(paymentServiceTypeNumber)) {
            setEntryHide(insurTypeList, "1");
        }

        if ("003".equals(paymentServiceTypeNumber)) {
            setEntryHide(insurTypeList, "2,3");
        }
    }

    public void setEntryHide(String insurTypeList, String index) {
        String[] split = index.split(",");
        //社保
        Set<String> socailSet = getSocialConfigs().keySet();
        for (String key : socailSet) {
            String[] formId = getSocialConfigs().get(key);
            //包含对应险种则显示，不包含则隐藏
            if (insurTypeList.contains(key)) {
                for (String i : split) {
                    this.getView().setVisible(true, formId[Integer.parseInt(i)]);
                }
            } else {
                for (String i : split) {
                    this.getView().setVisible(false, formId[Integer.parseInt(i)]);
                }
            }
        }
        //公积金
        Set<String> fundKeySet = getFundConfigs().keySet();
        for (String key : fundKeySet) {
            String[] formId = getFundConfigs().get(key);
            //包含对应险种则显示，不包含则隐藏
            if (insurTypeList.contains(key)) {
                for (String i : split) {
                    this.getView().setVisible(true, formId[Integer.parseInt(i)]);
                }
            } else {
                for (String i : split) {
                    this.getView().setVisible(false, formId[Integer.parseInt(i)]);
                }
            }
        }
    }

    /**
     * 设置分录的值
     */
    public void setEntryValue(String insurTypeList, String paymentInsurance, int rowIndex, Object newValue, String index, String name) {
        String[] split = index.split(",");
        //险种
        //社保
        HashMap<String, String[]> socialConfigs = getSocialConfigs();
        //公积金
        HashMap<String, String[]> fundConfigs = getFundConfigs();
        //配置
        HashMap<String, String[]> insuranceMap = getInsuranceConfigs(socialConfigs, fundConfigs).get(paymentInsurance);
        //设置险种值
        Set<String> insuranceSet = insuranceMap.keySet();
        for (String key : insuranceSet) {
            String[] formId = insuranceMap.get(key);
            if (insurTypeList.contains(key)) {
                for (String i : split) {
                    if ("${ISV_FLAG}_radix".equals(name)) {
                        this.getModel().setValue(formId[Integer.parseInt(i)], newValue, rowIndex);//新增代缴明细中养老保险基数
                    }

                    if ("${ISV_FLAG}_radix_base".equals(name)) {
                        BigDecimal value = (BigDecimal) this.getModel().getValue(formId[2], rowIndex);
                        if (value != null && value.compareTo(BigDecimal.ZERO) > 0) {
                            this.getModel().setValue(formId[Integer.parseInt(i)], newValue, rowIndex);//基数调整
                        }
                    }
                }
            }
        }
    }

    /**
     * 根据代缴公司设置险种缓存
     **/
    public void setPayingCompany(DynamicObject payingCompany) {
        if (payingCompany != null) {
            ArrayList<String> insurTypeList = new ArrayList<>();
            SinsurfileHelper sinsurfileHelper = new SinsurfileHelper();
            Long sinSurstdandarId = 0L;
            DynamicObjectCollection mulSinSurStd = payingCompany.getDynamicObjectCollection("mulsinsurstd");
            if (CollectionUtils.isNotEmpty(mulSinSurStd)) {
                sinSurstdandarId = mulSinSurStd.get(0).getLong("fbasedataid.id");
            }
            DynamicObject sitbsSinsurstd = BusinessDataServiceHelper.loadSingle(sinSurstdandarId, "sitbs_sinsurstd");
            if (Objects.nonNull(sitbsSinsurstd)) {
                DynamicObjectCollection entryentity = sitbsSinsurstd.getDynamicObjectCollection("stdentryentity");
                for (DynamicObject entry : entryentity) {
                    String insurTypeNumber = entry.getString("insurtype.number");
                    insurTypeList.add(insurTypeNumber);
                }
                this.getPageCache().put(String.valueOf(payingCompany.getLong("id")), StringUtils.join(insurTypeList, ","));
            }
        }
    }

