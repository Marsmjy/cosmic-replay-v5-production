    //如果paymentInsurance为A，即社保，那么将住房公积金设置为不可编辑
    //如果paymentInsurance为B，即住房公积金，那么将社保设置为不可编辑
    public void setEntryFiledEnable(IFormView view, String paymentInsurance, int rowIndex, String index) {
        String[] split = index.split(",");
        //社保
        HashMap<String, String[]> socialConfigs = getSocialConfigs();
        //公积金
        HashMap<String, String[]> fundConfigs = getFundConfigs();
        //配置
        HashMap<String, HashMap<String, String[]>> insuranceConfigs = getInsuranceConfigs(socialConfigs, fundConfigs);
        if ("A".equals(paymentInsurance)) {
            HashMap<String, String[]> map = insuranceConfigs.get("B");
            Set<String> keySet = map.keySet();
            for (String key : keySet) {
                String[] formId = map.get(key);
                for (String i : split) {
                    view.setEnable(false, rowIndex, formId[Integer.parseInt(i)]);
                }
            }
        }

        if ("B".equals(paymentInsurance)) {
            HashMap<String, String[]> map = insuranceConfigs.get("A");
            Set<String> keySet = map.keySet();
            for (String key : keySet) {
                String[] formId = map.get(key);
                for (String i : split) {
                    view.setEnable(false, rowIndex, formId[Integer.parseInt(i)]);
                }
            }
        }
    }
