    // 永祥需要显示的字段
    public static final String[] YONG_XIANG_FIELD = {"${ISV_FLAG}_pension_insurance","${ISV_FLAG}_medical_insurance","${ISV_FLAG}_unemployment_insuran","${ISV_FLAG}_commercial_insurance","${ISV_FLAG}_mul_insured_entity","${ISV_FLAG}_supply_medical"};
    // 永祥需要显示的按钮
    public static final String[] YONG_XIANG_BTN_KEY = {"${ISV_FLAG}_yx_insertdatabtn","${ISV_FLAG}_show_flow_chart"};
    // 股份需要显示的字段
