package ${ISV_FLAG}.swc.sit.form.social_security_fund;

import kd.bos.bill.AbstractBillPlugIn;
import kd.bos.dataentity.entity.DynamicObject;
import kd.bos.dataentity.entity.DynamicObjectCollection;
import kd.bos.dataentity.entity.MulBasedataDynamicObjectCollection;
import kd.bos.dataentity.utils.StringUtils;
import kd.bos.entity.datamodel.events.ChangeData;
import kd.bos.entity.datamodel.events.PropertyChangedArgs;
import kd.bos.form.FormShowParameter;
import kd.bos.form.control.Control;
import kd.bos.form.control.events.BeforeItemClickEvent;
import kd.bos.form.events.BeforeDoOperationEventArgs;
import kd.bos.form.field.BasedataEdit;
import kd.bos.form.field.DecimalEdit;
import kd.bos.form.field.MulBasedataEdit;
import kd.bos.form.field.events.BeforeF7SelectEvent;
import kd.bos.form.field.events.BeforeF7SelectListener;
import kd.bos.list.ListShowParameter;
import kd.bos.orm.query.QCP;
import kd.bos.orm.query.QFilter;
import kd.sdk.plugin.Plugin;

import java.util.EventObject;
import java.util.HashSet;
import java.util.Set;

/**
 * Author: wanghansheng
 * 修改职级编码时，自动带出职级名称
 */
public class SocialSecurityFundFormPlugin extends AbstractBillPlugIn implements Plugin, BeforeF7SelectListener {
    @Override
    public void registerListener(EventObject e) {
        BasedataEdit personController = this.getView().getControl("${ISV_FLAG}_multiple_ranks");
        personController.addBeforeF7SelectListener(this);

        BasedataEdit insuredEntity = this.getView().getControl("${ISV_FLAG}_insured_entity");
        insuredEntity.addBeforeF7SelectListener(this);

//        MulBasedataEdit mulInsuredEntity = this.getView().getControl("${ISV_FLAG}_mul_insured_entity");
//        mulInsuredEntity.addBeforeF7SelectListener(this);
    }

    @Override
    public void afterBindData(EventObject e) {
        hideAndMustInputFieldByCreatOrg();
        // 隐藏【变更原因】字段 --- 只有变更进入流程的时候才显示出来
        this.getView().setVisible(false,"${ISV_FLAG}_change_reason");
        showChangeReasonByChangeBtn();
    }

    @Override
    public void propertyChanged(PropertyChangedArgs e) {
        String name = e.getProperty().getName();
        ChangeData changeSet = e.getChangeSet()[0];
        if ("${ISV_FLAG}_multiple_ranks".equals(name)){
            MulBasedataDynamicObjectCollection newValue = (MulBasedataDynamicObjectCollection)e.getChangeSet()[0].getNewValue();
            if (newValue != null){
                this.getModel().setValue("${ISV_FLAG}_multiple_rank_name",newValue);
            }
        }else if("createorg".equals(name)){
            hideAndMustInputFieldByCreatOrg();
        }else if("${ISV_FLAG}_change_reason".equals(name)){
            this.getModel().setValue("changedescription",changeSet.getNewValue());
        }
    }

    @Override
    public void beforeF7Select(BeforeF7SelectEvent beforeF7SelectEvent) {
        String name = beforeF7SelectEvent.getProperty().getName();

        if ("${ISV_FLAG}_multiple_ranks".equals(name)) {
            DynamicObjectCollection entryEntity = this.getModel().getDataEntity(true).getDynamicObjectCollection("${ISV_FLAG}_entryentity");
            Set<Long> ids = new HashSet<>();
            for (DynamicObject item : entryEntity) {
                DynamicObjectCollection multipleRanks = item.getDynamicObjectCollection("${ISV_FLAG}_multiple_ranks");
                for (DynamicObject multipleRank : multipleRanks) {
                    ids.add(multipleRank.getLong("fbasedataid.id"));
                }
            }
            //进行过滤
            if (ids.size() > 0){
                QFilter qFilter = new QFilter("id", QFilter.not_in, ids);
                ListShowParameter showParameter = (ListShowParameter) beforeF7SelectEvent.getFormShowParameter();
                showParameter.getListFilterParameter().setFilter(qFilter);
            }
        }

        if ("${ISV_FLAG}_insured_entity".equals(name)) {
            //进行过滤
            DynamicObject createOrg = (DynamicObject) this.getModel().getValue("createorg");
            if (createOrg == null){
                this.getView().showTipNotification("请先选择社保公积金管理组织");
                beforeF7SelectEvent.setCancel(true);
            }else {
                QFilter qFilter = new QFilter("org", QFilter.equals, createOrg.getLong("id"))
                        .and(getUniqueVerificationOfInsuredUnit());
                ListShowParameter showParameter = (ListShowParameter) beforeF7SelectEvent.getFormShowParameter();
                showParameter.getListFilterParameter().setFilter(qFilter);
            }
        }
    }

    /**
     * 校验参保单位和基数表的唯一性
     * @return 返回过滤后的QFilter
     */
    private QFilter getUniqueVerificationOfInsuredUnit() {
        // 1.先查询BU
        String createOrgNumber = getCreateOrgNumber();
        Set<Long> singletonInsuredUnitIds = SocialSecurityFundCommon.getBUInsuredUnitIds(createOrgNumber);
        return new QFilter("id",QCP.not_in,singletonInsuredUnitIds);
    }

    @Override
    public void beforeItemClick(BeforeItemClickEvent evt) {
        String itemKey = evt.getItemKey();
        if("bar_audit".equals(itemKey)){
            String number = getCreateOrgNumber();
            if(SocialSecurityFundCommon.YONG_XIANG_NUMBER.equals(number)){
                // 判断当前的【社保公积金管理组织】是否为永祥
                evt.setCancel(true);
            }
        }
    }

    @Override
    public void beforeDoOperation(BeforeDoOperationEventArgs args) {

    }

    /**
     * 根据变更按钮点击进入流程来显示和隐藏【变更原因】字段
     */
    private void showChangeReasonByChangeBtn() {
        // 根据工作里标识判断，是否需要显示【变更原因】字段
        FormShowParameter formShowParameter = this.getView().getFormShowParameter();
        // 从工作流中获取业务标识的参数
        String bizIdentifyKey = formShowParameter.getCustomParam("bizIdentifyKey");
        // 参数匹配
        if("show_change_reason".equals(bizIdentifyKey)){
            String showChangeReason = formShowParameter.getCustomParam(bizIdentifyKey);
            // 显示【变更原因】字段
            this.getView().setVisible(!StringUtils.isEmpty(showChangeReason),"${ISV_FLAG}_change_reason");
        }
    }


    /**
     * 根据社保公积金管理组织进行相关字段的隐藏和必录
     */
    private void hideAndMustInputFieldByCreatOrg() {
        // 获取社保公积金管理组织的编码
        String orgNumber = getCreateOrgNumber();
        // 判断当前是否为永祥
        if(SocialSecurityFundCommon.YONG_XIANG_NUMBER.equals(orgNumber)){
            this.getView().setVisible(true,SocialSecurityFundCommon.YONG_XIANG_FIELD);
            this.getView().setVisible(true,SocialSecurityFundCommon.YONG_XIANG_BTN_KEY);
            this.getView().setVisible(false,SocialSecurityFundCommon.OTHER_FILED);
            this.getView().setVisible(false,SocialSecurityFundCommon.OTHER_BTN_KEY);
            setMustInput(SocialSecurityFundCommon.YONG_XIANG_FIELD);
            cancelMustInput(SocialSecurityFundCommon.OTHER_FILED);
        }
        // 但前是太阳能
        else if(SocialSecurityFundCommon.TAI_YANG_NENG_NUMBER.equals(orgNumber)){
            this.getView().setVisible(true,SocialSecurityFundCommon.TAI_YANG_NENG_FIELD);
            this.getView().setVisible(true,SocialSecurityFundCommon.OTHER_BTN_KEY);
            this.getView().setVisible(false,SocialSecurityFundCommon.OTHER_FILED);
            this.getView().setVisible(false,SocialSecurityFundCommon.YONG_XIANG_BTN_KEY);
            setMustInput(SocialSecurityFundCommon.TAI_YANG_NENG_FIELD);
            cancelMustInput(SocialSecurityFundCommon.OTHER_FILED);
        }
        // 其他（股份总部 + 组件）
        else{
            this.getView().setVisible(false,SocialSecurityFundCommon.YONG_XIANG_FIELD);
            this.getView().setVisible(false,SocialSecurityFundCommon.YONG_XIANG_BTN_KEY);
            this.getView().setVisible(true,SocialSecurityFundCommon.OTHER_FILED);
            this.getView().setVisible(true,SocialSecurityFundCommon.OTHER_BTN_KEY);
            setMustInput(SocialSecurityFundCommon.OTHER_FILED);
            cancelMustInput(SocialSecurityFundCommon.YONG_XIANG_FIELD);
        }
    }

    /**
     * 设置必录
     * @param fields 要设置必录的字段
     */
    private void setMustInput(String[] fields){
        for (String field : fields) {
            Control control = this.getControl(field);
            if(control instanceof DecimalEdit){
                ((DecimalEdit)control).setMustInput(true);
            }else if(control instanceof MulBasedataEdit){
                ((MulBasedataEdit)control).setMustInput(true);
            }else if(control instanceof BasedataEdit){
                ((BasedataEdit)control).setMustInput(true);
            }
        }
    }

    /**
     * 取消必录
     * @param fields 要取消必录的字段
     */
    private void cancelMustInput(String[] fields){
        for (String field : fields) {
            Control control = this.getControl(field);
            if(control instanceof DecimalEdit){
                ((DecimalEdit)control).setMustInput(false);
            }else if(control instanceof MulBasedataEdit){
                ((MulBasedataEdit)control).setMustInput(false);
            }else if(control instanceof BasedataEdit){
                ((BasedataEdit)control).setMustInput(false);
            }
        }
    }

    /**
     * 获取社保公基金管理组织的编码
     * @return 编码
     */
    private String getCreateOrgNumber() {
        DynamicObject createOrg = this.getModel().getDataEntity(true).getDynamicObject("createorg");
        return createOrg == null ? "" : createOrg.getString("number");
    }
}