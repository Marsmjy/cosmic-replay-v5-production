/**
 * Author: wanghansheng
 * 社保公积金代缴申请单校验插件
 */
public class SocialSecurityPayOperationPlugin extends AbstractOperationServicePlugIn {
    @Override
    public void   onPreparePropertys(PreparePropertysEventArgs e) {
        e.getFieldKeys().add("entryentity.${ISV_FLAG}_payment_insurance_e");
        e.getFieldKeys().add("entryentity.${ISV_FLAG}_endowment_e");
        e.getFieldKeys().add("entryentity.${ISV_FLAG}_medical_e");
        e.getFieldKeys().add("entryentity.${ISV_FLAG}_unemployment_e");
        e.getFieldKeys().add("entryentity.${ISV_FLAG}_industrial_injury_e");
        e.getFieldKeys().add("entryentity.${ISV_FLAG}_supply_medica_e");
        e.getFieldKeys().add("entryentity.${ISV_FLAG}_maternity_e");
        e.getFieldKeys().add("entryentity.${ISV_FLAG}_housing_e");
        e.getFieldKeys().add("${ISV_FLAG}_payment_service_type");
        e.getFieldKeys().add("${ISV_FLAG}_person");
        e.getFieldKeys().add("${ISV_FLAG}_effective_date");
        e.getFieldKeys().add("${ISV_FLAG}_payment_insurance");
        e.getFieldKeys().add("welfarepayertheory");
        e.getFieldKeys().add("${ISV_FLAG}_description");
        e.getFieldKeys().add("${ISV_FLAG}_paying_company");
        e.getFieldKeys().add("${ISV_FLAG}_paying_company.placeofwelfare");
        e.getFieldKeys().add("${ISV_FLAG}_insured_company");
        e.getFieldKeys().add("${ISV_FLAG}_employee");
        e.getFieldKeys().add("${ISV_FLAG}_radix_table");
        e.getFieldKeys().add("${ISV_FLAG}_pay_file");

        //基数调整单据体
        e.getFieldKeys().add("${ISV_FLAG}_base_entryentity.${ISV_FLAG}_base_endowment_e1");
        e.getFieldKeys().add("${ISV_FLAG}_base_entryentity.${ISV_FLAG}_base_medical_e1");
        e.getFieldKeys().add("${ISV_FLAG}_base_entryentity.${ISV_FLAG}_unemployment_e1");
        e.getFieldKeys().add("${ISV_FLAG}_base_entryentity.${ISV_FLAG}_base_injury_e1");
        e.getFieldKeys().add("${ISV_FLAG}_base_entryentity.${ISV_FLAG}_base_medica_e1");
        e.getFieldKeys().add("${ISV_FLAG}_base_entryentity.${ISV_FLAG}_base_housing_e1");
        e.getFieldKeys().add("${ISV_FLAG}_base_entryentity.${ISV_FLAG}_base_maternity_e1");
        e.getFieldKeys().add("${ISV_FLAG}_base_entryentity.${ISV_FLAG}_base_insurance_e");
        e.getFieldKeys().add("${ISV_FLAG}_base_entryentity.${ISV_FLAG}_base_insurance_e");
        e.getFieldKeys().add("${ISV_FLAG}_base_entryentity.${ISV_FLAG}_base_effective_date");
        e.getFieldKeys().add("${ISV_FLAG}_base_entryentity.${ISV_FLAG}_base_maternity_e1");

        //停止代缴单据体
        e.getFieldKeys().add("${ISV_FLAG}_stop_entryentity");
        e.getFieldKeys().add("${ISV_FLAG}_stop_entryentity.${ISV_FLAG}_stop_effective_date");
        e.getFieldKeys().add("${ISV_FLAG}_stop_entryentity.${ISV_FLAG}_stop_insurance_e");
        e.getFieldKeys().add("${ISV_FLAG}_stop_entryentity.${ISV_FLAG}_stop_endowment_e");
        e.getFieldKeys().add("${ISV_FLAG}_stop_entryentity.${ISV_FLAG}_stop_medical_e");
        e.getFieldKeys().add("${ISV_FLAG}_stop_entryentity.${ISV_FLAG}_stop_unemployment_e");
        e.getFieldKeys().add("${ISV_FLAG}_stop_entryentity.${ISV_FLAG}_stop_injury_e");
        e.getFieldKeys().add("${ISV_FLAG}_stop_entryentity.${ISV_FLAG}_stop_medica_e");
        e.getFieldKeys().add("${ISV_FLAG}_stop_entryentity.${ISV_FLAG}_stop_maternity_e");
