    public static DynamicObject[] queryPosChangeMsg(Map<String, Object> taskDays, Set<String> changeSceneSet) {
        //当天生效的
        QFilter qFilterEffect = new QFilter("changedate", QCP.large_equals, taskDays.get("beforeDt"));
        qFilterEffect.and("changedate", QCP.less_than, taskDays.get("currDt"));

        //当天操作并且已经生效的数据
        QFilter qFilter = new QFilter("operatetime", QCP.large_equals, taskDays.get("beforeDt"));
        qFilter.and("operatetime", QCP.less_than, taskDays.get("currModifyDt"));
        qFilter.and("changedate", QCP.less_than, taskDays.get("currDt"));

        QFilter finalQFilter = qFilterEffect.or(qFilter);

        //限定变动场景条件
        QFilter changeSceneFilter = new QFilter("changescene.number", QCP.in, changeSceneSet);

        HRBaseServiceHelper helper = new HRBaseServiceHelper("hbpm_chgrecordevt");
        return helper.loadDynamicObjectArray(new QFilter[]{finalQFilter.and(changeSceneFilter)});
    }

