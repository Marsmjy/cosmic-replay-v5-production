    /**
     * @description: 过滤已经处理过的数据
     * @param: posChangeList
     * changeType
     * getCompareId
     * @return: java.util.List<kd.bos.dataentity.entity.DynamicObject>
     * @author ningjie
     * @date: 2025/7/30 16:15
     */
    public static List<DynamicObject> excludHisDataDyList(List<DynamicObject> posChangeList, String changeType, BiFunction<DynamicObject, Set<String>, Boolean> getCompareId) {
        // 消费明细id集合
        DynamicObjectCollection posTranMappingIdSet = OrgTransferHelper.queryOrgTranMappingIdSet(changeType);
        Set<String> dealKeySet = posTranMappingIdSet.stream().map(data -> data.getString("${ISV_FLAG}_mapping_id")).collect(Collectors.toSet());
        return posChangeList.stream().filter(data -> getCompareId.apply(data, dealKeySet)).collect(Collectors.toList());
    }


