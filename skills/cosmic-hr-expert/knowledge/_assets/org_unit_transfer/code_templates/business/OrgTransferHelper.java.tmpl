    /**
     * @description: 组织变动消费明细(获取数据范围 当天生效的 + （ 当天操作并且已经生效的数据 ）)
     * @param: taskDays
     * changeScenceSet 变动场景
     * @return: kd.bos.dataentity.entity.DynamicObject[]
     * @author ningjie
     * @date: 2025/7/31 10:17
     */
    public static DynamicObject[] queryHAOSChangeMsg(Map<String, Object> taskDays, Set<String> changeSceneSet) {

        //当天生效的
        QFilter qFilterEffect = new QFilter("orgchgentry.chgeffecttime", QCP.large_equals, taskDays.get("beforeDt"));
        qFilterEffect.and("orgchgentry.chgeffecttime", QCP.less_than, taskDays.get("currDt"));

        //当天操作并且已经生效的数据
        QFilter qFilter = new QFilter("orgchgentry.operationtime", QCP.large_equals, taskDays.get("beforeDt"));
        qFilter.and("orgchgentry.operationtime", QCP.less_than, taskDays.get("currModifyDt"));
        qFilter.and("orgchgentry.chgeffecttime", QCP.less_than, taskDays.get("currDt"));

        QFilter finalQFilter = qFilterEffect.or(qFilter);

        //限定变动场景条件
        QFilter changeSceneFilter = new QFilter("orgchgentry.changescene.number", QCP.in, changeSceneSet);

        HRBaseServiceHelper helper = new HRBaseServiceHelper("homs_orgchgrecord");
        return helper.query("adminorg,orgchgentry.chgeffecttime,orgchgentry.changescene,orgchgentry.operationtime", new QFilter[]{finalQFilter.and(changeSceneFilter)});
    }


    /**
