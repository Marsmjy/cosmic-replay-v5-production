    /**
     * @description: 获取组织变动信息
     * @param: changeMsgList
     * changeType
     * chgSceneNumberSet
     * @return: java.util.List<kd.bos.dataentity.entity.DynamicObject>
     * @author ningjie
     * @date: 2025/7/23 19:55
     */
    public static List<DynamicObject> getOrgTransferDyList(List<DynamicObject> changeMsgList, String changeType, Set<String> chgSceneNumberSet) {

        List<DynamicObject> transferDyList = new ArrayList<>();

        Date modifyTime = new Date();

        // 消费明细id集合
        DynamicObjectCollection posTranMappingIdSet = OrgTransferHelper.queryOrgTranMappingIdSet(changeType);
        Set<String> dealKeySet = posTranMappingIdSet.stream().map(data -> data.getString("${ISV_FLAG}_mapping_id")).collect(Collectors.toSet());


        changeMsgList.stream().forEach(changeMsg -> {
            DynamicObjectCollection orgChgEntry = changeMsg.getDynamicObjectCollection("orgchgentry");
            if (CollectionUtils.isEmpty(orgChgEntry)) return;

            Optional<DynamicObject> orgChgOp = orgChgEntry.stream().filter(orgChg -> {
                if (Objects.isNull(orgChg.getDynamicObject("changescene"))
                        || !chgSceneNumberSet.contains(orgChg.getString("changescene.number"))) return false;
                if(dealKeySet.contains(orgChg.getString("id"))) return false;
                return true;
            }).sorted((e1, e2) -> {
                int compareResult = e2.getDate("chgeffecttime").compareTo(e1.getDate("chgeffecttime"));
                if (compareResult == 0) {
                    return e2.getDate("operationtime").compareTo(e1.getDate("operationtime"));
                }
                return compareResult;
            }).findFirst();

            if (orgChgOp.isPresent()) {
                DynamicObject orgChg = orgChgOp.get();
                TransferEntity entity = new TransferEntity();
                entity.setChangeType(changeType);
                entity.setOrgId(changeMsg.getLong("adminorg.id"));
                entity.setOrgNumber(changeMsg.getString("adminorg.number"));
                entity.setOrgName(changeMsg.getString("adminorg.name"));
                entity.setEffectDate(orgChg.getDate("chgeffecttime"));
                entity.setExecuteStatus("01");
                entity.setModifyDate(modifyTime);
                entity.setMappingId(orgChg.getLong("id"));
                DynamicObject transferDy = convertOrgTransfer(entity);
                transferDyList.add(transferDy);
            }
        });

        return transferDyList;

    }

    /**
     * @description: 获取岗位变动信息
     * @param: changeMsgArr
     * changeType
     * chgSceneNumberSet
     * @return: java.util.List<kd.bos.dataentity.entity.DynamicObject>
     * @author ningjie
     * @date: 2025/7/23 19:55
     */
    public static List<DynamicObject> getPosTransferDyList(List<DynamicObject> posChangeList, String changeType) {

        List<DynamicObject> transferDyList = new ArrayList<>();

        Date modifyTime = new Date();

        posChangeList.stream().forEach(changeMsg -> {
            Long posId = changeMsg.getLong("targetposition.id");
            TransferEntity entity = new TransferEntity();
            entity.setChangeType(changeType);
            entity.setOrgId(posId);
            entity.setOrgNumber(changeMsg.getString("targetposition.number"));
            entity.setOrgName(changeMsg.getString("targetposition.name"));
            entity.setEffectDate(changeMsg.getDate("changedate"));
            entity.setExecuteStatus("01");
            entity.setModifyDate(modifyTime);
            entity.setMappingId(changeMsg.getLong("id"));
            DynamicObject transferDy = convertOrgTransfer(entity);
            transferDyList.add(transferDy);
        });

        return transferDyList;

    }


