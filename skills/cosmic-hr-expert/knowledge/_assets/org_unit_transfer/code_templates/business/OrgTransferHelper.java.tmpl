    /**
     * 封装成建制划转基础信息
     *
     * @param entity 转换实体
     * @return
     */
    public static DynamicObject convertOrgTransfer(TransferEntity entity) {

        MainEntityType orgUnTiTransfer = MetadataServiceHelper.getDataEntityType("${ISV_FLAG}_orguntitransfer");
        DynamicObject transferDy = new DynamicObject(orgUnTiTransfer);
        // 变动类型
        transferDy.set("${ISV_FLAG}_changetype", entity.getChangeType());

        transferDy.set("${ISV_FLAG}_orgid", entity.getOrgId());
        // 岗位编码
        transferDy.set("${ISV_FLAG}_orgnumber", entity.getOrgNumber());
        // 岗位名称
        transferDy.set("${ISV_FLAG}_orgname", entity.getOrgName());

        // 关联消费明细的id
        transferDy.set("${ISV_FLAG}_mapping_id", entity.getMappingId());
        // 更新日期
        transferDy.set("${ISV_FLAG}_modifydate", entity.getModifyDate());
        // 生效日期
        transferDy.set("${ISV_FLAG}_takeeffectdate", entity.getEffectDate());
        // 执行状态：待执行
        transferDy.set("${ISV_FLAG}_executestatus", entity.getExecuteStatus());

        return transferDy;
    }

    static class TransferEntity {

        /**
         * 变动类型
         */
        private String changeType;
        /**
         * 组织/岗位boid
         */
        private Long orgId;

        /**
         * 组织/岗位编码
         */
        private String orgNumber;

        /**
         * 组织/岗位名称
         */
        private String orgName;

        /**
         * 变动明细id
         */
        private Long mappingId;

        /**
         * 生效日期
         */
        private Date effectDate;

        /**
         * 执行状态：01：待执行
         */
        private String executeStatus;

        /**
         * 操作时间
         */
        private Date modifyDate;

        public String getChangeType() {
            return changeType;
        }

        public void setChangeType(String changeType) {
            this.changeType = changeType;
        }

        public Long getOrgId() {
            return orgId;
        }

        public void setOrgId(Long orgId) {
            this.orgId = orgId;
        }

        public String getOrgNumber() {
            return orgNumber;
        }

        public void setOrgNumber(String orgNumber) {
            this.orgNumber = orgNumber;
        }

        public String getOrgName() {
            return orgName;
        }

        public void setOrgName(String orgName) {
            this.orgName = orgName;
        }

        public Long getMappingId() {
            return mappingId;
        }

        public void setMappingId(Long mappingId) {
            this.mappingId = mappingId;
        }

        public String getExecuteStatus() {
            return executeStatus;
        }

        public void setExecuteStatus(String executeStatus) {
            this.executeStatus = executeStatus;
        }

        public Date getEffectDate() {
            return effectDate;
        }

        public void setEffectDate(Date effectDate) {
            this.effectDate = effectDate;
        }

        public Date getModifyDate() {
            return modifyDate;
        }

        public void setModifyDate(Date modifyDate) {
            this.modifyDate = modifyDate;
        }
    }


