    /**
     * @return void
     * @Author zb
     * @Description 值改变-数值型界面规则检查
     * @Date 9:22 2024/7/30
     * @Param [e, ruleDynamicObject]
     **/
    public void viewRuleCheckRuleDecimal(String fieldKey, DynamicObject ruleDynamicObject) {
        //改变的值
//        String fieldKey = e.getProperty().getName();
        //规则类型为数值型的情况下
        int minValue = ruleDynamicObject.getInt(CollectInfoRuleUtil.Field.MIN_VALUE);
        int maxValue = ruleDynamicObject.getInt(CollectInfoRuleUtil.Field.MAX_VALUE);
        String filedValueStr = this.getModel().getValue(fieldKey).toString();
        log.info("规则类型为数值型的情况下-filedValueStr:" + filedValueStr);
        if (CollectInfoRuleUtil.isNotEmptyNumeric(filedValueStr)) {
            BigDecimal filedValue = new BigDecimal(filedValueStr);
            log.info("规则类型为数值型的情况下-filedValueStr:" + filedValue);
//                    BigDecimal filedValue = (BigDecimal) this.getModel().getValue(fieldKey);
            if (filedValue.compareTo(new BigDecimal(minValue)) < 0 || filedValue.compareTo(new BigDecimal(maxValue)) > 0) {
                log.info("规则类型为数值型的情况下-filedValue不符合:" + filedValue);
                this.getView().showTipNotification("输入的值不符合最大最小值范围！");
                this.getModel().initValue(fieldKey, null);
                this.getView().updateView(fieldKey);
            }
        }
    }


    /**
     * @Author zb
     * @Description 值改变-检查文本界面规则
     * @Date 9:19 2024/7/30
     * @Param [e, ruleDynamicObject]
     **/
    public void viewRuleCheckRuleText(PropertyChangedArgs e, DynamicObject ruleDynamicObject) {

        //改变的值
        String fieldKey = e.getProperty().getName();

        //获取设置的字段最小长度
        Integer textMinLength = ruleDynamicObject.getInt(CollectInfoRuleUtil.Field.TEXT_MIN_LENGTH);

        //获取设置的字段最大长度
        Integer textMaxLength = ruleDynamicObject.getInt(CollectInfoRuleUtil.Field.TEXT_MAX_LENGTH);

        boolean noChinese = ruleDynamicObject.getBoolean(CollectInfoRuleUtil.Field.TXT_CHECK_NOT_CHINESE);
        boolean noDigit = ruleDynamicObject.getBoolean(CollectInfoRuleUtil.Field.TXT_CHECK_NO_DIGIT);
        boolean noEnglish = ruleDynamicObject.getBoolean(CollectInfoRuleUtil.Field.TXT_CHECK_NO_ENGLISH);
        boolean noSymbol = ruleDynamicObject.getBoolean(CollectInfoRuleUtil.Field.TXT_CHECK_NO_SYMBOL);

        String filedValueStr = this.getModel().getValue(fieldKey).toString();

        // 判断是否存在文本内容条件
        if (noChinese) {
            if (CollectInfoRuleUtil.containsChinese(filedValueStr)) {
                //如果包含中文，返回错误信息
                this.getView().showTipNotification(e.getProperty().getDisplayName() + "输入的值不可包含中文！");
                this.getModel().initValue(fieldKey, null);
            }
        }
        if (noDigit) {
            if (CollectInfoRuleUtil.containsDigit(filedValueStr)) {
                //如果包含中文，返回错误信息
                this.getView().showTipNotification(e.getProperty().getDisplayName() + "输入的值不可包含数字！");
                this.getModel().initValue(fieldKey, null);
            }
        }
        if (noEnglish) {
            if (CollectInfoRuleUtil.containsEnglish(filedValueStr)) {
                //如果包含中文，返回错误信息
                this.getView().showTipNotification(e.getProperty().getDisplayName() + "输入的值不可包含英文字母！");
                this.getModel().initValue(fieldKey, null);
            }
        }
        if (noSymbol) {
            if (CollectInfoRuleUtil.containsSymbol(filedValueStr)) {
                //如果包含中文，返回错误信息
                this.getView().showTipNotification(e.getProperty().getDisplayName() + "输入的值不可包含符号！");
                this.getModel().initValue(fieldKey, null);
            }
        }

        //长度判断
        if (filedValueStr.length() > textMaxLength || filedValueStr.length() < textMinLength) {
            log.info("CHECK_RULE_DECIMAL--params-textMinLength:" + textMinLength + ",textMaxLength:" + textMaxLength);
            this.getView().showTipNotification(e.getProperty().getDisplayName() + ":请输入" + textMinLength + "-" + textMaxLength + "位字符");
        }

        //刷新界面
        this.getView().updateView(fieldKey);
    }


