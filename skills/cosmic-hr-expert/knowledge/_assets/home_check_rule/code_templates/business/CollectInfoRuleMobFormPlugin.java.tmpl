    @Override
    public void afterBindData(EventObject e) {
        super.afterBindData(e);

        log.info("进入CollectInfoMobFormPlugin方法");
//        String entityName = this.getModel().getDataEntityType().getName();
        String entityName = this.getView().getFormShowParameter().getFormId();
        log.info("实体名称：" + entityName);

        //获取要设置界面规则的参数配置
        DynamicObject[] ruleDynamicObjectCollection = CollectInfoRuleUtil.getViewCheckedData(entityName, null);

        if (ObjectUtils.isEmpty(ruleDynamicObjectCollection)) return;

        log.info("afterBindData-ruleDynamicObjectCollection不为空");
        // 生成单次循环的uuid-唯一值，用于界面规则使用
        UUID cacheUniqueId = UUID.randomUUID();
        // 如果需要字符串形式的唯一标识符-用于多次循环使用
        String cacheUniqueIdStr = cacheUniqueId.toString();

        for (DynamicObject dynamicObject : ruleDynamicObjectCollection) {
            //获取标识
            String symbol = dynamicObject.getString(CollectInfoRuleUtil.Field.FILD_SYMBOL);
            log.info("symbol--" + symbol);
            //如果页面不存在该标识，停止执行插件
            boolean existSymbol = this.getModel().getDataEntityType().getProperties().containsKey(symbol);
            if (!existSymbol) {
                log.info("不存在该symbol--" + symbol);
                continue;
            }

            log.info("存在该symbol--" + symbol);

            //通用属性-字段锁定校验
            boolean fieldLock = dynamicObject.getBoolean(CollectInfoRuleUtil.Field.FIELD_LOCK);
            if (fieldLock) {
                this.getView().setEnable(false, symbol);
            }
            //通用属性-必填性
            boolean fieldMustInput = dynamicObject.getBoolean(CollectInfoRuleUtil.Field.FIELD_MUST_INPUT);
            if (fieldMustInput) {
                FieldEdit fieldEdit = this.getView().getControl(symbol);
                fieldEdit.setMustInput(true);
                //加入必填校验缓存
                addMustInputPageCache(symbol);
            }

            //默认值类型
            String defaultType = dynamicObject.getString(CollectInfoRuleUtil.Field.FIELD_DEFAULT_VAL_TYPE);
            if (defaultType != null) {
                switch (defaultType) {
                    //设置文本或下拉项默认值
                    case FIELD_DEFAULT_VAL_TYPE_TEXT:
                        this.getModel().setValue(symbol, dynamicObject.getString(CollectInfoRuleUtil.Field.FIELD_DEFAULT_VALUE));
                        break;
                    //设置基础资料默认值
                    case FIELD_DEFAULT_VAL_TYPE_BASEDATA:
                        this.getModel().setItemValueByNumber(symbol, dynamicObject.getString(CollectInfoRuleUtil.Field.FIELD_DEFAULT_VALUE));
                        break;
                }

            }

            //获取规则类型
            String ruleType = dynamicObject.getString(CollectInfoRuleUtil.Field.FILD_RULE_TYPE);
            //为小数类型时候-设置长度、小数位、最小值、最大值
            switch (ruleType) {
                case CHECK_RULE_DECIMAL:
                    //长度--从参数中获取--需判断是否为空
                    Integer decimalPrecision = dynamicObject.getInt(CollectInfoRuleUtil.Field.DECIMAL_PRECISION);
                    Integer decimalScale = dynamicObject.getInt(CollectInfoRuleUtil.Field.DECIMAL_SCALE);
                    Integer minValue = dynamicObject.getInt(CollectInfoRuleUtil.Field.MIN_VALUE);
                    Integer maxValue = dynamicObject.getInt(CollectInfoRuleUtil.Field.MAX_VALUE);
                    //设置一个缺省值
                    //                    this.getModel().setValue(symbol,minValue);
                    log.info("CHECK_RULE_DECIMAL--params-decimalScale:" + decimalPrecision + ",decimalScale:" + decimalScale + ",minValue:" + minValue + ",maxValue" + maxValue);
                    //更新界面规则
                    this.getView().updateControlMetadata(symbol, CollectInfoRuleUtil.getDecimalRuleItemMap(decimalPrecision, decimalScale, minValue, maxValue));
                    break;
                case CHECK_RULE_TEXT:

                    //获取设置的字段最小长度
                    Integer textMinLength = dynamicObject.getInt(CollectInfoRuleUtil.Field.TEXT_MIN_LENGTH);
                    //获取设置的字段最大长度
                    Integer textMaxLength = dynamicObject.getInt(CollectInfoRuleUtil.Field.TEXT_MAX_LENGTH);

                    log.info("CHECK_RULE_DECIMAL--params-textMinLength:" + textMinLength + ",textMaxLength:" + textMaxLength);

                    //更新界面规则
                    this.getView().updateControlMetadata(symbol, CollectInfoRuleUtil.getTextRuleItemMap(textMinLength, textMaxLength));

                    break;
                case CHECK_RULE_MATCH_VAL_EFFECT_FIELD:
                    //规则为：根据字段的值设置目标字段属性--z在在显示数据界面需要实现    当前字段和目标字段存在前提
                    if (null != this.getModel().getValue(symbol)) {
                        this.getView().updateControlMetadata(symbol, CollectInfoRuleUtil.getFireUpdEvtMap());
                        viewRuleCheckRuleMatchValEffectField(symbol, dynamicObject, cacheUniqueIdStr);
                    }
                    break;
                default:
                    //其他界面规则的情形，需要给相关设置规则的字段动态设置即时触发值更新
                    this.getView().updateControlMetadata(symbol, CollectInfoRuleUtil.getFireUpdEvtMap());
                    break;
            }
            this.updateShowView(symbol);
        }

    }

    private void updateShowView(String symbol){
        this.getView().updateView(symbol);
    }

    /**
     * @Author zb
     * @Description 属性变化事件
     * @Date 15:44 2024/7/21
     * @Param [e]
     **/
    @Override
    public void propertyChanged(PropertyChangedArgs e) {
        super.propertyChanged(e);

        log.info("进入propertyChanged");
        //改变的值
        String fieldKey = e.getProperty().getName();
        String entityName = this.getModel().getDataEntityType().getName();

        log.info("实体名称：" + entityName);
        log.info("改变的值：" + fieldKey);

        //获取所有业务规则配置集合
        DynamicObject[] buRuleDynamicObjectCollection = CollectInfoRuleUtil.getBusinessCheckedData(entityName, fieldKey);
        if (buRuleDynamicObjectCollection != null && buRuleDynamicObjectCollection.length > 0) {
            log.info("propertyChanged-buRuleDynamicObjectCollection不为空");
            for (DynamicObject dynamicObject : buRuleDynamicObjectCollection) {
                //获取标识
                String symbol = dynamicObject.getString(CollectInfoRuleUtil.Field.FILD_SYMBOL);
                String ruleType = dynamicObject.getString(CollectInfoRuleUtil.Field.FILD_RULE_TYPE);
                log.info("symbol=fieldKey--" + symbol);
                //对使用该规则的字段 设置及时触发值更新
                this.getView().updateControlMetadata(symbol, CollectInfoRuleUtil.getFireUpdEvtMap());
                switch (ruleType) {
                    case CHECK_RULE_CALCULATE:
                        //业务规则-根据字段进行计算设值
                        busRuleCalculate(fieldKey, dynamicObject);
                        break;
                    case CHECK_RULE_FIELD_EFFECT_SET_VAL:
                        //条件：根据字段设值另一字段值
                        busRuleFieldEffectSetVal(fieldKey, dynamicObject);
                        break;
                    case CHECK_RULE_COPY_TO_TARGET_FIELD:
                        //条件：复制当前字段值到目标字段
                        busRuleCopyToTargetField(fieldKey, dynamicObject);
                        break;
                }
            }
        }

        DynamicObject[] viewRuleDynamicObjectCollection = CollectInfoRuleUtil.getViewCheckedData(entityName, fieldKey);

        if (viewRuleDynamicObjectCollection != null && viewRuleDynamicObjectCollection.length > 0) {
            log.info("propertyChanged-viewRuleDynamicObjectCollection不为空");

            // 生成单次循环的uuid-唯一值，用于界面规则使用
            UUID cacheUniqueId = UUID.randomUUID();
            // 如果需要字符串形式的唯一标识符-用于多次循环使用
            String cacheUniqueIdStr = cacheUniqueId.toString();

            for (DynamicObject dynamicObject : viewRuleDynamicObjectCollection) {
                String ruleType = dynamicObject.getString(CollectInfoRuleUtil.Field.FILD_RULE_TYPE);
                //为小数类型时候-设置长度、小数位、最小值、最大值
                switch (ruleType) {
                    case CHECK_RULE_DECIMAL:
                        //规则为:数值型界面规则检查
                        viewRuleCheckRuleDecimal(fieldKey, dynamicObject);
                        break;
                    case CHECK_RULE_TEXT:
                        //规则为:文本界面规则检查
                        viewRuleCheckRuleText(e, dynamicObject);
                        break;
                    case CHECK_RULE_CHECKBOX:
                        //规则为:checkbox的情况下-checkbox选中影响的字段filedid
                        viewRuleCheckRuleCheckbox(fieldKey, dynamicObject);
                        break;
                    case CHECK_RULE_DATE_COMPARE:
                        //规则为：日期比较是否满足-界面提示
                        viewRuleCheckRuleDateCompare(fieldKey, dynamicObject);
                        break;
                    case CHECK_RULE_MATCH_VAL_EFFECT_FIELD:
                        //规则为：根据字段的值设置目标字段属性
                        viewRuleCheckRuleMatchValEffectField(fieldKey, dynamicObject, cacheUniqueIdStr);

                        break;
                }
            }
        }

    }


    /**
     * @Author zb
     * @Description 操作前校验
     * @Date 14:33 2024/8/22
     * @Param [args]
     **/
    public void beforeDoOperation(BeforeDoOperationEventArgs args) {

        super.beforeDoOperation(args);
        AbstractOperate operate = (AbstractOperate) args.getSource();
        String lblKey = operate.getOperateKey();
        if (!"save".equals(lblKey)) {  //只监听save事件
            return;
        }
        //校验必填
        IPageCache iPageCache = this.getPageCache();
        List<String> fieldList = new ArrayList<>();
        //获取已经存储在缓存中的必填数据--以JSON字符串存储
        if (null != iPageCache.get(PAGE_CACHE_MUST_INPUT)) {
            String fieldListJson = (iPageCache.get(PAGE_CACHE_MUST_INPUT));
            //Json转List
            JSONArray fieldJsonArray = new JSONArray(fieldListJson);
            for (int i = 0; i < fieldJsonArray.length(); i++) {
                fieldList.add(fieldJsonArray.getString(i));
                log.info("beforeDoOperation-field:" + fieldJsonArray.getString(i));
                //设置必填
                //前端加星号，前端不一定会校验
                FieldEdit fieldEdit = this.getControl(fieldJsonArray.getString(i));
                fieldEdit.setMustInput(true);

//                String classTypeName = this.getControl(fieldJsonArray.getString(i)).getClass().getName();


//                if("kd.bos.form.field.TextEdit".equals(classTypeName)){
//                    TextProp fieldProp = (TextProp) fieldEdit.getProperty();
//                    fieldProp.setMustInput(true);
//                }else if("kd.bos.form.field.BasedataEdit".equals(classTypeName)){
//                    //不执行操作
//                }


                //后端加校验-基础资料报错
//                FieldProp fieldProp = (FieldProp) fieldEdit.getProperty();
//                fieldProp.setMustInput(true);
                log.info("beforeDoOperation-field的值-" + fieldJsonArray.getString(i) + " : ---" + this.getModel().getValue(fieldJsonArray.getString(i)));

                //如果当前的值为空-则禁止提交
                if (null == this.getModel().getValue(fieldJsonArray.getString(i))
                        || ObjectUtils.isEmpty(this.getModel().getValue(fieldJsonArray.getString(i)))) {
                    this.getView().showTipNotification(this.getModel().getProperty(fieldJsonArray.getString(i)).getDisplayName() + " 字段未填写，无法提交！");
                    args.setCancel(true);
                } else {
                    //字段属性
                    String fieldTypeName = this.getModel().getValue(fieldJsonArray.getString(i)).getClass().getName();
                    //多语言文本单独判断
                    if (fieldTypeName.equals("kd.bos.dataentity.entity.OrmLocaleValue")) {
                        OrmLocaleValue ormLocaleValue = (OrmLocaleValue) this.getModel().getValue(fieldJsonArray.getString(i));
                        //如果当前的值为空-则禁止提交
                        if (ormLocaleValue.isEmpty()) {
                            this.getView().showTipNotification(this.getModel().getProperty(fieldJsonArray.getString(i)).getDisplayName() + " 字段未填写，无法提交！");
                            args.setCancel(true);
                        }
                    }
                }
            }
        }
    }

    /**
     * @Author zb
     * @Description 业务规则-根据字段进行计算设值
     * @Date 9:48 2024/7/30
     * @Param [e, ruleDynamicObject]
     **/
    public void busRuleCalculate(String fieldKey, DynamicObject ruleDynamicObject) {

        //改变的值
//        String fieldKey = e.getProperty().getName();
        //获取计算类型
        String calculateType = ruleDynamicObject.getString(CollectInfoRuleUtil.Field.CALCULATE_TYPE);
        log.info("calculateType--" + calculateType);


        //减数和被减数的标识
        String startValueSymbol = ruleDynamicObject.getString(CollectInfoRuleUtil.Field.CHECK_RULE_CALCULATE_START_VALUE_SYMBOL);
        String endValueSymbol = ruleDynamicObject.getString(CollectInfoRuleUtil.Field.CHECK_RULE_CALCULATE_END_VALUE_SYMBOL);
        String targetField = ruleDynamicObject.getString(CollectInfoRuleUtil.Field.CHECK_RULE_CALCULATE_TARGET_FIELD);

        //匹配值改变事件的字段
        if (StringUtils.equals(startValueSymbol, fieldKey) || StringUtils.equals(endValueSymbol, fieldKey)) {
            log.info("匹配到对应的值改变标识---startValueSymbol：" + startValueSymbol + ",endValueSymbol:" + endValueSymbol);
            //所需计算的数据都不为空情况下
            if ((null != this.getModel().getValue(startValueSymbol) && this.getModel().getDataEntity().containsProperty(endValueSymbol) && null != this.getModel().getValue(endValueSymbol))
                    || (null != this.getModel().getValue(startValueSymbol) && endValueSymbol.equals(NOW_DATE))) {


                //规则为根据两个字段计算日期差时-单位为年---带小数的
                if (calculateType.equals(CHECK_RULE_CALCULATE_DATE_YEAR)) {
                    //获取对应标识的数据-由于此处计算为日期类型，按日期获取值
                    //获取开始日期
                    Date startValue = (Date) this.getModel().getValue(startValueSymbol);

                    Date endValue;
                    if (endValueSymbol.equals(NOW_DATE)) {
                        //当前日期
                        endValue = new Date();
                    } else {
                        //获取结束日期  2024-06-12 00:00:00.0
                        endValue = (Date) this.getModel().getValue(endValueSymbol);
                    }

                    //计算相差的年
                    double yearsBetween = CollectInfoRuleUtil.calculateDateByYear(startValue, endValue);
                    log.info("计算结果---yearsBetween：" + yearsBetween);
                    //设置计算结果
                    this.getModel().setValue(targetField, yearsBetween);
                    this.getView().updateView(targetField);
                } else if (calculateType.equals(CHECK_RULE_CALCULATE_AGE)) {
                    //获取对应标识的数据-由于此处计算为日期类型，按日期获取值
                    //获取开始日期
                    Date startValue = (Date) this.getModel().getValue(startValueSymbol);
                    Date currentValue;
                    if (endValueSymbol.equals(NOW_DATE)) {
                        //当前日期
                        currentValue = new Date();
                    } else {
                        //获取日期  2024-06-12 00:00:00.0
                        currentValue = (Date) this.getModel().getValue(endValueSymbol);
                    }
                    //计算年龄
                    int age = CollectInfoRuleUtil.calculateAge(startValue, currentValue);
                    log.info("计算结果---年龄：" + age);
                    //设置计算结果
                    this.getModel().setValue(targetField, age);
                    this.getView().updateView(targetField);
                }
            }
        }

    }

    /**
     * @Author zb
     * @Description 值改变-业务规则-根据字段设值另一字段值
     * @Date 9:46 2024/7/30
     * @Param [e, ruleDynamicObject]
     **/
    public void busRuleFieldEffectSetVal(String fieldKey, DynamicObject ruleDynamicObject) {
        //改变的值
//        String fieldKey = e.getProperty().getName();
        //条件：根据字段设值另一字段值
        String effectField = ruleDynamicObject.getString(CollectInfoRuleUtil.Field.CHECK_RULE_FIELD_EFFECT_FIELD);
        String effectObject = ruleDynamicObject.getString(CollectInfoRuleUtil.Field.CHECK_RULE_FIELD_EFFECT_OBJECT);
        String eftObjectSymbol = ruleDynamicObject.getString(CollectInfoRuleUtil.Field.CHECK_RULE_FD_EFT_OBJECT_SYMBOL);
        String effectSetVal = ruleDynamicObject.getString(CollectInfoRuleUtil.Field.CHECK_RULE_FD_EFT_FD_SET_VAL);

        String effectFieldType = ruleDynamicObject.getString(CollectInfoRuleUtil.Field.CHECK_RULE_FD_EFT_FD_TYPE);


        //获取改变的字段的id值
        DynamicObject dynamicObjectFieldKey = (DynamicObject) this.getModel().getValue(fieldKey);
        long fieldKeyId = (long) dynamicObjectFieldKey.getPkValue();

        //改变的字段的id值作为查询条件
        QFilter qFieldKeyId = new QFilter(eftObjectSymbol, QCP.equals, fieldKeyId);
        //获取关联查询的数据
        DynamicObject eftObject = BusinessDataServiceHelper.loadSingleFromCache(effectObject, effectSetVal, new QFilter[]{qFieldKeyId});


        //需自动填入的字段为多选基础资料时
        if (effectFieldType.equals(CHECK_RULE_FD_EFT_FD_TYPE_MULBASEDATA)) {
            //获取需要设值的数据集合
            DynamicObjectCollection effectSetValObjectCollection = eftObject.getDynamicObjectCollection(effectSetVal);

//                        String[] effectSetValIds = new String[effectSetValObjectCollection.size()];
//                        for (int i = 0 ; i < effectSetValObjectCollection.size(); i++) {
//                            effectSetValIds[i] = ((DynamicObject)effectSetValObjectCollection.get(i)).getPkValue().toString();
//                        }
//                        this.getModel().setValue(effectField,effectSetValIds);
//                        this.getView().updateView(effectField);


            DynamicObjectCollection activityToolManDy = this.getModel().getDataEntity().getDynamicObjectCollection(effectField);
            DynamicObjectType type = activityToolManDy.getDynamicObjectType();
            DynamicObjectCollection newCu = new DynamicObjectCollection();
            for (DynamicObject effectSetValObject : effectSetValObjectCollection) {
                DynamicObject cu = effectSetValObject.getDynamicObject("fbasedataid");
                DynamicObject obj = new DynamicObject(type);
                obj.set("fbasedataid", cu);
                newCu.add(obj);
            }
            if (!newCu.isEmpty()) {
                this.getModel().setValue(effectField, newCu);
            } else {
                this.getModel().initValue(effectField, null);
            }
            this.getView().updateView(effectField);
        } else if (effectFieldType.equals(CHECK_RULE_FD_EFT_FD_TYPE_BASEDATA)) {
            DynamicObject effectSetValObject = eftObject.getDynamicObject(effectSetVal);
            //设置相关值到对象模型上
            this.getModel().setValue(effectField, effectSetValObject);
            this.getView().updateView(effectField);
        }
    }

    /**
