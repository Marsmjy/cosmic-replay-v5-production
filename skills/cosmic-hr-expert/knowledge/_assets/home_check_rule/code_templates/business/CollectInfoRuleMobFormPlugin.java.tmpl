    /**
     * @Author zb
     * @Description 值改变-日期比较是否满足-界面提示
     * @Date 9:01 2024/7/30
     * @Param [e, ruleDynamicObject]
     **/
    public void viewRuleCheckRuleDateCompare(String fieldKey, DynamicObject ruleDynamicObject) {

        String compareType = ruleDynamicObject.getString(CollectInfoRuleUtil.Field.CHECK_RULE_DATE_COMPARE_TYPE);
        String compareField = ruleDynamicObject.getString(CollectInfoRuleUtil.Field.CHECK_RULE_DATE_COMPARE_FIELD);
        String compareTips = ruleDynamicObject.getString(CollectInfoRuleUtil.Field.CHECK_RULE_DATE_COMPARE_TIPS);

        Date fieldKeyDate = (Date) this.getModel().getValue(fieldKey);

        Date compareDate;
        if (compareField.equals(NOW_DATE)) {
            compareDate = new Date();
        } else {
            compareDate = (Date) this.getModel().getValue(compareField);
        }
        //比较的目标字段compareDate不为空，进行比较
        if (null != compareDate) {
            //条件：当前值改变时间字段需大于比较字段
            if (compareType.equals(CHECK_RULE_DATE_COMPARE_TYPE_GREATER_THAN)) {
                if (fieldKeyDate.before(compareDate)) {
                    //如果值改变的字段在比较字段日期之前，则代表不满足大于条件，抛出提示
                    this.getView().showTipNotification(compareTips);
                    this.getModel().initValue(fieldKey, null);
                    this.getView().updateView(fieldKey);
                }
            } else if (compareType.equals(CHECK_RULE_DATE_COMPARE_TYPE_LESS_THAN)) {
                //条件：当前值改变时间字段需小于比较字段
                if (fieldKeyDate.after(compareDate)) {
                    //如果值改变的字段在比较字段日期之后，则代表不满足小于条件，抛出提示
                    this.getView().showTipNotification(compareTips);
                    this.getModel().initValue(fieldKey, null);
                    this.getView().updateView(fieldKey);
                }
            }
        }
    }


    /**
     * @Author zb
     * @Description 根据字段的值设置目标字段属性
     * @Date 18:40 2024/7/29
     * @Param [e, ruleDynamicObject,cacheUniqueIdStr]
     **/
    public void viewRuleCheckRuleMatchValEffectField(String fieldKey, DynamicObject ruleDynamicObject, String cacheUniqueIdStr) {

        String matchType = ruleDynamicObject.getString(CollectInfoRuleUtil.Field.CHECK_RULE_MATCH_VAL_TYPE);
        String matchCondition = ruleDynamicObject.getString(CollectInfoRuleUtil.Field.CHECK_RULE_MATCH_CONDITION);
        String matchConditionValue = ruleDynamicObject.getString(CollectInfoRuleUtil.Field.CHECK_RULE_MATCH_CONDI_VALUE);
        String matchTarField = ruleDynamicObject.getString(CollectInfoRuleUtil.Field.CHECK_RULE_MATCH_TARGET_FIELD);
        boolean matchTarHide = ruleDynamicObject.getBoolean(CollectInfoRuleUtil.Field.CHECK_RULE_MATCH_TAR_HIDE);
        boolean matchTarLock = ruleDynamicObject.getBoolean(CollectInfoRuleUtil.Field.CHECK_RULE_MATCH_TAR_LOCK);
        boolean matchTarMustInput = ruleDynamicObject.getBoolean(CollectInfoRuleUtil.Field.CHECK_RULE_MATCH_MUST_INPUT);

        // 如果当前界面不存在该字段和目标字段  不执行
        if (!this.getModel().getDataEntityType().getProperties().containsKey(fieldKey)
                || !this.getModel().getDataEntityType().getProperties().containsKey(ruleDynamicObject.getString(CollectInfoRuleUtil.Field.CHECK_RULE_MATCH_TARGET_FIELD))) {
            return;
        }


        //当前字段的值
        String fieldValue = "";

        //匹配文本
        if (matchType.equals(CHECK_RULE_MATCH_VAL_TYPE_TEXT)) {
            //获取当前字段的值-文本
            fieldValue = (String) this.getModel().getValue(fieldKey);
        }

        //匹配checkbox
        if (matchType.equals(CHECK_RULE_MATCH_VAL_TYPE_CHECKBOX)) {
            //获取当前字段的值-文本
            boolean checkboxValue = this.getModel().getDataEntity().getBoolean(fieldKey);
            if (checkboxValue) {
                fieldValue = "1";
            } else {
                fieldValue = "0";
            }
        }

        if (matchType.equals(CHECK_RULE_MATCH_VAL_TYPE_BASE_NAME)) {
            if (null != this.getModel().getDataEntity().getDynamicObject(fieldKey)) {
                //获取当前字段的值-基础资料-名称
                fieldValue = this.getModel().getDataEntity().getDynamicObject(fieldKey).getString("name");
            }
        }
        if (matchType.equals(CHECK_RULE_MATCH_VAL_TYPE_BASE_NUMBER)) {
            if (null != this.getModel().getDataEntity().getDynamicObject(fieldKey)) {
                //获取当前字段的值-基础资料-编码
                fieldValue = this.getModel().getDataEntity().getDynamicObject(fieldKey).getString("number");
            }
        }


        //以下操作页面的界面规则

        IPageCache iPageCache = this.getPageCache();
        iPageCache.put("", "");

        //条件为等于
        if (matchCondition.equals(CHECK_RULE_MATCH_CONDITION_EQUAL)) {
            //比较相关的值
            if (fieldValue.equals(matchConditionValue)) {
                //目标字段隐藏校验
                if (matchTarHide) {
                    iPageCache.put(cacheUniqueIdStr + matchTarField + "Visible", "false");
                    this.getModel().initValue(matchTarField, null);
                    this.getView().setVisible(false, matchTarField);
                } else {
                    this.getView().setVisible(true, matchTarField);
                }
                //目标字段锁定校验
                if (matchTarLock) {
                    iPageCache.put(cacheUniqueIdStr + matchTarField + "Enable", "false");
                    this.getView().setEnable(false, matchTarField);
                } else {
                    this.getView().setEnable(true, matchTarField);
                }
                //目标字段必填校验
                if (matchTarMustInput) {
                    iPageCache.put(cacheUniqueIdStr + matchTarField + "MustInput", "true");
                    FieldEdit fieldEdit = this.getView().getControl(matchTarField);
                    fieldEdit.setMustInput(true);
                    //加入必填校验缓存
                    addMustInputPageCache(matchTarField);
                } else {
                    this.getView().setEnable(true, matchTarField);
                    FieldEdit fieldEdit = this.getView().getControl(matchTarField);
                    fieldEdit.setMustInput(false);
                    //删除必填缓存数据
                    removeMustInputPageCache(matchTarField);
                }
            }
            else{
                // 不隐藏（显示），且不存在当前页面缓存为隐藏的设置，则修改为显示
                if(matchTarHide && null == iPageCache.get(cacheUniqueIdStr+matchTarField+"Visible")){
                    this.getView().setVisible(true, matchTarField);
                }
                //目标字段锁定校验 不锁定，且不存在当前页面缓存为锁定的设置，则修改为不锁定
                if(matchTarLock && null == iPageCache.get(cacheUniqueIdStr+matchTarField+"Enable")){
                    this.getView().setEnable(true, matchTarField);
                }
                //目标字段必填校验 不必填，且不存在当前页面缓存为锁定的设置，则修改为不锁定
                if(matchTarMustInput && null == iPageCache.get(cacheUniqueIdStr+matchTarField+"MustInput")){
                    FieldEdit fieldEdit = this.getView().getControl(matchTarField);
                    fieldEdit.setMustInput(false);
                    //删除必填缓存数据
                    removeMustInputPageCache(matchTarField);
                }else{
                    this.getView().setEnable(true, matchTarField);
                    FieldEdit fieldEdit = this.getView().getControl(matchTarField);
                    fieldEdit.setMustInput(false);
                    //删除必填缓存数据
                    removeMustInputPageCache(matchTarField);
                }
            }
        }
        //条件为包含
        if (matchCondition.equals(CHECK_RULE_MATCH_CONDITION_CONTAIN)) {
            //比较相关的值——满足条件
            if (fieldValue.contains(matchConditionValue)) {
                //目标字段隐藏校验
                if (matchTarHide) {
                    iPageCache.put(cacheUniqueIdStr + matchTarField + "Visible", "false");
                    this.getModel().initValue(matchTarField, null);
                    this.getView().setVisible(false, matchTarField);
                } else {
                    this.getView().setVisible(true, matchTarField);
                }
                //目标字段锁定校验
                if (matchTarLock) {
                    iPageCache.put(cacheUniqueIdStr + matchTarField + "Enable", "false");
                    this.getView().setEnable(false, matchTarField);
                } else {
                    this.getView().setEnable(true, matchTarField);
                }
                //目标字段必填校验
                if (matchTarMustInput) {
                    iPageCache.put(cacheUniqueIdStr + matchTarField + "MustInput", "true");
                    FieldEdit fieldEdit = this.getView().getControl(matchTarField);
                    fieldEdit.setMustInput(true);
                    //加入必填校验缓存
                    addMustInputPageCache(matchTarField);
                } else {
                    this.getView().setEnable(true, matchTarField);
                    FieldEdit fieldEdit = this.getView().getControl(matchTarField);
                    fieldEdit.setMustInput(false);
                    //删除必填缓存数据
                    removeMustInputPageCache(matchTarField);
                }
            }
            else{
                //判断本次值改变事件中设置不隐藏且没有对目标字段设置隐藏的数据，设置显示
                if(matchTarHide && null == iPageCache.get(cacheUniqueIdStr+matchTarField+"Visible")){
                    this.getView().setVisible(true, matchTarField);
                }
                //目标字段锁定校验-判断本次值改变事件中设置为不锁定且没有对目标字段设置锁定的数据，设置不锁定
                if(matchTarLock && null == iPageCache.get(cacheUniqueIdStr+matchTarField+"Enable")){
                    this.getView().setEnable(true, matchTarField);
                }
                //目标字段必填校验-判断本次值改变事件中设置为不锁定且没有对目标字段设置必填的数据，设置不不填
                if(matchTarMustInput && null == iPageCache.get(cacheUniqueIdStr+matchTarField+"MustInput")){
                    FieldEdit fieldEdit = this.getView().getControl(matchTarField);
                    fieldEdit.setMustInput(false);
                    //删除必填缓存数据
                    removeMustInputPageCache(matchTarField);
                }
            }
        }


        //条件为不等于
        if (matchCondition.equals(CHECK_RULE_MATCH_CONDITION_NOT_EQUAL)) {
            //比较相关的值——满足条件
            if (!fieldValue.equals(matchConditionValue)) {
                //目标字段隐藏校验
                if (matchTarHide) {
                    iPageCache.put(cacheUniqueIdStr + matchTarField + "Visible", "false");
                    this.getModel().initValue(matchTarField, null);
                    this.getView().setVisible(false, matchTarField);
                } else {
                    this.getView().setVisible(true, matchTarField);
                }
                //目标字段锁定校验
                if (matchTarLock) {
                    iPageCache.put(cacheUniqueIdStr + matchTarField + "Enable", "false");
                    this.getView().setEnable(false, matchTarField);
                } else {
                    this.getView().setEnable(true, matchTarField);
                }
                //目标字段必填校验
                if (matchTarMustInput) {
                    iPageCache.put(cacheUniqueIdStr + matchTarField + "MustInput", "true");
                    FieldEdit fieldEdit = this.getView().getControl(matchTarField);
                    fieldEdit.setMustInput(true);
                    //加入必填校验缓存
                    addMustInputPageCache(matchTarField);
                } else {
                    this.getView().setEnable(true, matchTarField);
                    FieldEdit fieldEdit = this.getView().getControl(matchTarField);
                    fieldEdit.setMustInput(false);
                    //删除必填缓存数据
                    removeMustInputPageCache(matchTarField);
                }
            }
            else{
                //判断本次值改变事件中设置不隐藏且没有对目标字段设置隐藏的数据，设置显示
                if(matchTarHide && null == iPageCache.get(cacheUniqueIdStr+matchTarField+"Visible")){
                    this.getView().setVisible(true, matchTarField);
                }
                //目标字段锁定校验-判断本次值改变事件中设置为不锁定且没有对目标字段设置锁定的数据，设置不锁定
                if(matchTarLock && null == iPageCache.get(cacheUniqueIdStr+matchTarField+"Enable")){
                    this.getView().setEnable(true, matchTarField);
                }
                //目标字段必填校验-判断本次值改变事件中设置为不锁定且没有对目标字段设置必填的数据，设置不不填
                if(matchTarMustInput && null == iPageCache.get(cacheUniqueIdStr+matchTarField+"MustInput")){
                    FieldEdit fieldEdit = this.getView().getControl(matchTarField);
                    fieldEdit.setMustInput(false);
                    //删除必填缓存数据
                    removeMustInputPageCache(matchTarField);
                }
            }
        }


        //刷新界面
        this.getView().updateView(matchTarField);

    }



    /**
     * @Author zb
     * @Description 添加必填字段缓存
     * @Date 14:25 2024/8/22
     * @Param [fieldStr]
     **/
    public void addMustInputPageCache(String fieldStr) {

        IPageCache iPageCache = this.getPageCache();

        List<String> fieldList = new ArrayList<>();

        //获取已经存储在缓存中的必填数据--以JSON字符串存储
        if (null != iPageCache.get(PAGE_CACHE_MUST_INPUT)) {
            String fieldListJson = (iPageCache.get(PAGE_CACHE_MUST_INPUT));

            //Json转List
            JSONArray fieldJsonArray = new JSONArray(fieldListJson);
            for (int i = 0; i < fieldJsonArray.length(); i++) {
                fieldList.add(fieldJsonArray.getString(i));
            }
        }
        //将要写入缓存的数据添加进去
        if (!fieldList.contains(fieldStr)) {  //cq add去重
            fieldList.add(fieldStr);
        }
        //将List转Json
        JSONArray jsonArray = new JSONArray(fieldList);

        // 更新到缓存中
        iPageCache.put(PAGE_CACHE_MUST_INPUT, jsonArray.toString());
    }


    /**
     * @Author zb
     * @Description 删除指定缓存数据
     * @Date 14:30 2024/8/22
     * @Param [fieldStr]
     **/
    public void removeMustInputPageCache(String fieldStr) {

        IPageCache iPageCache = this.getPageCache();

        List<String> fieldList = new ArrayList<>();

        //获取已经存储在缓存中的必填数据--以JSON字符串存储
        if (null != iPageCache.get(PAGE_CACHE_MUST_INPUT)) {
            String fieldListJson = (iPageCache.get(PAGE_CACHE_MUST_INPUT));
            //Json转List
            JSONArray fieldJsonArray = new JSONArray(fieldListJson);
            for (int i = 0; i < fieldJsonArray.length(); i++) {
                fieldList.add(fieldJsonArray.getString(i));
            }
            //将要删除缓存的数据删除 -此处jdk8方法
            fieldList.removeIf(element -> element.equals(fieldStr));
            //将List转Json
            JSONArray jsonArray = new JSONArray(fieldList);
            // 更新到缓存中
            iPageCache.put(PAGE_CACHE_MUST_INPUT, jsonArray.toString());
        }

    }


