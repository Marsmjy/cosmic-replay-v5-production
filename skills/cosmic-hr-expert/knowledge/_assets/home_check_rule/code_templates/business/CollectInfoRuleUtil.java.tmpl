    /**
     * @return double
     * @Author zb
     * @Description 计算两个日期相差的年数
     * @Date 17:10 2024/7/21
     * @Param [startDate, endDate]
     **/
    public static double calculateDateByYear(Date startDate, Date endDate) {

        double yearsBetween = 0;

        if (null != startDate && null != endDate) {

            // 转换为LocalDate（这里假设所有Date对象都是UTC时间）
            LocalDate localDateStrart = startDate.toInstant().atZone(ZoneId.systemDefault()).toLocalDate();
            LocalDate localDateEnd = endDate.toInstant().atZone(ZoneId.systemDefault()).toLocalDate();

            // 计算两个LocalDate之间的天数差
            long daysBetween = ChronoUnit.DAYS.between(localDateStrart, localDateEnd);

            // 假设一年有365.25天来计算近似的小数年份差
            double averageDaysPerYear = 365.25;
            yearsBetween = (double) daysBetween / averageDaysPerYear;

        }

        //保留两位小数
        BigDecimal bd = new BigDecimal(yearsBetween);
        bd = bd.setScale(2, RoundingMode.HALF_UP);

        return bd.doubleValue();
    }

    /**
     * @return int
     * @Author zb
     * @Description TODO 计算年龄
     * @Date 10:22 2024/11/22
     * @Param [birthDate]
     **/
    public static int calculateAge(Date birthDate, Date currentDate) {
        LocalDate birthLocalDate = convertToLocalDate(birthDate);
        LocalDate currentLocalDate = convertToLocalDate(currentDate);

        Period period = Period.between(birthLocalDate, currentLocalDate);
        return period.getYears();
    }

    /**
     * @Author zb
     * @Description TODO 将Date转换为LocalDate
     * @Date 15:03 2024/11/22
     * @Param
     **/
    public static LocalDate convertToLocalDate(Date date) {
        Instant instant = date.toInstant();
        return instant.atZone(ZoneId.systemDefault()).toLocalDate();
    }


    /**
     * @return boolean
     * @Author zb
     * @Description 字符串是否包含中文
     * @Date 10:34 2024/7/23
     * @Param [str]
     **/
    public static boolean containsChinese(String str) {
        Pattern pattern = Pattern.compile("[\u4e00-\u9fa5]");
        return pattern.matcher(str).find();
    }

    /**
     * @return boolean
     * @Author zb
     * @Description 字符串是否包含数字
     * @Date 10:34 2024/7/23
     * @Param [str]
     **/
    public static boolean containsDigit(String str) {
        Pattern pattern = Pattern.compile("[0-9]");
        return pattern.matcher(str).find();
    }

    /**
     * @return boolean
     * @Author zb
     * @Description 字符串是否包含英文字母
     * @Date 10:34 2024/7/23
     * @Param [str]
     **/
    public static boolean containsEnglish(String str) {
        Pattern pattern = Pattern.compile("[a-zA-Z]");
        return pattern.matcher(str).find();
    }

    /**
     * @return boolean
     * @Author zb
     * @Description 字符串是否包含符号
     * @Date 10:34 2024/7/23
     * @Param [str]
     **/
    public static boolean containsSymbol(String str) {
        Pattern pattern = Pattern.compile("[^a-zA-Z0-9\u4e00-\u9fa5]");
        return pattern.matcher(str).find();
    }


    /**
     * @Description 判断字符串不为空且为纯数字
     **/
    public static boolean isNotEmptyNumeric(String str) {
        return str != null && str.matches("\\d+");
    }

