        return ruleDynamicObjectCollection;
    }

    /**
     * 设置数值界面规则参数
     **/
    public static HashMap<String, Object> getDecimalRuleItemMap(Integer decimalPrecision, Integer decimalScale, Integer minValue, Integer maxValue) {

        //修改文本字段元数据
        HashMap<String, Object> param = new HashMap<>();

        if (decimalPrecision != null) {
            //数值总长度
            param.put(ClientProperties.Precision, decimalPrecision);
        }
        if (decimalScale != null) {
            //小数点位数
            param.put(ClientProperties.Scale, decimalScale);
        }
        if (minValue != null) {
            //最小值
            param.put(ClientProperties.MinValue, minValue);
        }
        if (maxValue != null) {
            //最大值
            param.put(ClientProperties.MaxValue, maxValue);
        }

        //设置即时触发值更新
        param.put(ClientProperties.FireUpdEvt, true);
        //设置控件的编辑类型
        HashMap<String, Object> itemMap = new HashMap<>();
        itemMap.put(ClientProperties.Item, param);

        return itemMap;

    }

