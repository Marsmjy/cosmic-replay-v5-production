    /**
     * @description:
     * @param: [entityName]  查询已审核的界面规则类配置数据
     * @return: kd.bos.dataentity.entity.DynamicObject[]
     * @author ningjie
     * @date: 2025/8/21 10:37
     */
    public static DynamicObject[] getViewCheckedData(String entityName, String fieldKey) {
        QFilter q1 = new QFilter(EVENT_TYPE, QCP.equals, EVENT_TYPE_VIEW_SET);
        q1.and(HRBaseConstants.ENABLE, QCP.equals, "1");
        QFilter qEntityName = new QFilter(Field.ENTITY_NAME, QCP.equals, entityName);
        QFilter qStatus = new QFilter(DATA_STATUS, QCP.equals, DATA_STATUS_CHECKED);

        if (!ObjectUtils.isEmpty(fieldKey)) {
            q1.and(Field.FILD_SYMBOL, QCP.equals, fieldKey);
        }

        //获取所有配置集合
        DynamicObject[] ruleDynamicObjectCollection = BusinessDataServiceHelper.load(COLLECT_INFO_CHECK_RULE_BASEDATA, SELECT_PROPERTIES, new QFilter[]{q1, qEntityName, qStatus});

        return ruleDynamicObjectCollection;

    }

