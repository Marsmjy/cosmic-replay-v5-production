    private Long queryPersonId() {
        Long personId = null;
        ArrayList<Long> userIds = new ArrayList<>();
        userIds.add(RequestContext.get().getCurrUserId());
        Map<String, Object> userInfo = HRPIEmployeeServiceHelper.queryEmployeeByUserIds(userIds, "", "1");

        LOGGER.info("getPersonModelId getUserId success:{} message:{}", userInfo.get("success"), userInfo.get("message"));
        if ((Boolean) userInfo.get("success") && userInfo.get("data") != null) {
            Map<String, Object> userData = (Map) userInfo.get("data");
            personId = (Long) userData.get("employee");
        }

        if (personId == null) {
            // 无四层人，当前账号为系统用户，未入职
            return 0L;
        }
        return personId;
    }

    private DynamicObject getRootNodeDynamic(Long personId) {
        DynamicObject[] hrpiPerson = getHrpiPerson(Arrays.asList(personId));
        if (hrpiPerson != null && hrpiPerson.length > 0) {
            // 取任意一条 设置父节点信息
            return hrpiPerson[0];
        }

        return null;
    }

    public EmpSuprelChartTreeNode buildRootTreeNode(DynamicObject rootDy, JSONObject paramsJsonObj) {
        String showDirection = paramsJsonObj.getString("showDirection");
        // 根节点的父节点Id
        String parentId = paramsJsonObj.getString("parentId");
        // 父对象
        EmpSuprelChartTreeNode treeNode = new EmpSuprelChartTreeNode(parentId, rootDy.getString("id"), rootDy.getString("name"), true);
        // 当前节点
        String nodeId = paramsJsonObj.getString("nodeId");
        if (HRStringUtils.isEmpty(nodeId)){
            nodeId = String.valueOf(ID.genLongId());
        }else {
            String currentLevel = paramsJsonObj.getString("currentLevel");
            if (HRStringUtils.isNotEmpty(currentLevel)){
                treeNode.setCurrentLevel(Integer.parseInt(currentLevel));
            }
        }
        // 查看方向
        treeNode.setShowDirection(showDirection);

        treeNode.setId(nodeId);
        // 当前人员id
        treeNode.setPersonId(rootDy.getString("id"));
        // 当前节点名称
        treeNode.setText(rootDy.getString("name"));
        // 过滤条件
        String reportReltypeNumber = paramsJsonObj.getString("reportReltypeNumber");
        QFilter searchQf = new QFilter("reporttype.number", QCP.in, reportReltypeNumber);
        String level = paramsJsonObj.getString("level");
        // 组装数结构
        List<EmpSuprelChartTreeNode> treeNodes;
        if ("up".equals(showDirection)) {
            // 向上展示
            treeNodes = getAllEmpSuprelTreeNodesToUp(treeNode, level, searchQf);
        }else {
            // 向下展示
            treeNodes = getAllEmpSuprelTreeNodesToDown(treeNode, level, searchQf);
        }
        // 增加父节点
        treeNodes.add(treeNode);
        Map<String, List<EmpSuprelChartTreeNode>> parentIdChildMap = (Map) treeNodes.stream().filter((node) -> {
            return HRStringUtils.isNotEmpty(node.getParentid());
        }).collect(Collectors.groupingBy(TreeNode::getParentid));
        // 增加子节点
        addChildNodes(treeNode, parentIdChildMap);
        // 设置展示字段信息
        setShowFieldInfos(treeNodes);

        return treeNode;

    }

    private void setShowFieldInfos(List<EmpSuprelChartTreeNode> treeNodes) {
        List<Long> personIds = treeNodes.stream().map((node) -> (Long.parseLong(node.getPersonId()))).collect(Collectors.toList());
        // 查人员任职经历
        DynamicObject[] hrpiEmpposorgrel = getHrpiEmpposorgrelByPerson(personIds);
        Map<String, DynamicObject> empposorgrelMap = new HashMap<>();
        if (hrpiEmpposorgrel != null && hrpiEmpposorgrel.length > 0) {
            for (DynamicObject empposorgrel : hrpiEmpposorgrel) {
                empposorgrelMap.put(empposorgrel.getString("employee.id"), empposorgrel);
            }
        }
        // 查询自然人信息
        DynamicObject[] hrpiPerson = getHrpiPerson(personIds);
        Map<String, DynamicObject> hrpiPersonMap = new HashMap<>();
        if (hrpiPerson != null && hrpiPerson.length > 0) {
            for (DynamicObject person : hrpiPerson) {
                hrpiPersonMap.put(person.getString("id"), person);
            }
        }
        DynamicObject[] hrpiPercontact = getHrpiPercontact(personIds);
        Map<String, DynamicObject> hrpiPercontactMap = new HashMap<>();
        if (hrpiPercontact != null && hrpiPercontact.length > 0) {
            for (DynamicObject percontact : hrpiPercontact) {
                hrpiPercontactMap.put(percontact.getString("employee.id"), percontact);
            }
        }

        // 设置每个树节点的数据
        for (EmpSuprelChartTreeNode node : treeNodes) {
            setShowFieldInfosDetail(node, empposorgrelMap, hrpiPersonMap,hrpiPercontactMap);
        }
    }

    private void setShowFieldInfosDetail(EmpSuprelChartTreeNode node, Map<String, DynamicObject> empposorgrelMap, Map<String, DynamicObject> hrpiPersonMap,Map<String, DynamicObject> hrpiPercontactMap) {

        String personId = node.getPersonId();
        DynamicObject empposorgrel = empposorgrelMap.get(personId);
        String adminorg = "";
        String position = "";
        String company = "";
        if (empposorgrel != null) {
            adminorg = ((OrmLocaleValue) empposorgrel.get("adminorg.name")).getLocaleValue();
            position = ((OrmLocaleValue) empposorgrel.get("position.name")).getLocaleValue();
            company = ((OrmLocaleValue) empposorgrel.get("company.name")).getLocaleValue();
        }

        DynamicObject person = hrpiPersonMap.get(personId);
        String empNumber = person.getString("number");
        String headsculpture = setUserPictureUrl(person.getString("headsculpture"));

        DynamicObject percontact = hrpiPercontactMap.get(personId);
        String phone = "";
        String peremail ="";
        if (percontact != null){
            phone = percontact.getString("phone");
            peremail = percontact.getString("peremail");
        }


        // 展示字段信息
        Map<String, Object> showFieldInfos = new HashMap<>();
        // 人员id
        showFieldInfos.put("personId",personId);
        // 公司
        showFieldInfos.put("company", company);
        // 部门
        showFieldInfos.put("adminorg", adminorg);
        // 岗位
        showFieldInfos.put("position", position);
        // 工号
        showFieldInfos.put("empnumber", empNumber);
        // 头像
        showFieldInfos.put("headsculpture", headsculpture);
        // 手机号
        showFieldInfos.put("phone", phone);
        // 邮箱
        showFieldInfos.put("peremail", peremail);

        node.setShowFields(showFieldInfos);

    }

    /**
     * 树对象增加子节点
     *
     * @param rootNode         rootNode
     * @param parentIdChildMap parentIdChildMap
     */
    private void addChildNodes(EmpSuprelChartTreeNode rootNode, Map<String, List<EmpSuprelChartTreeNode>> parentIdChildMap) {
        List<EmpSuprelChartTreeNode> childrenEmpSuprelTreeNodes = (List) parentIdChildMap.get(rootNode.getId());
        if (childrenEmpSuprelTreeNodes != null && !CollectionUtils.isEmpty(childrenEmpSuprelTreeNodes)) {
            parentIdChildMap.remove(rootNode.getId());
            List<TreeNode> childrenTreeNodes = new ArrayList(childrenEmpSuprelTreeNodes);
            rootNode.setChildren(childrenTreeNodes);
            childrenEmpSuprelTreeNodes.forEach((treeNode) -> {
                addChildNodes(treeNode, parentIdChildMap);
            });
            rootNode.setChildrenCount(childrenTreeNodes.size());
            rootNode.setLeaf(false);
        }

    }

    /**
     * 包装树节点对象
     *
     * @param dyn      dyn
     * @param currentLevel    level
     * @param parentId parentId
     * @return EmpSuprelChartTreeNode
     */
    private EmpSuprelChartTreeNode wrapTreeNodeToDown(DynamicObject dyn, int currentLevel, String parentId) {
        EmpSuprelChartTreeNode node = new EmpSuprelChartTreeNode();
        node.setId(String.valueOf(ID.genLongId()));
        node.setParentid(parentId);
        node.setText(dyn.getString("employee.name"));
        node.setPersonId(dyn.getString("employee"));
        // 当前所在层级
        node.setCurrentLevel(currentLevel + 1 );
        return node;

    }

    /**
     * 包装树节点对象
     *
     * @param dyn      dyn
     * @param currentLevel    level
     * @param parentId parentId
     * @return EmpSuprelChartTreeNode
     */
    private EmpSuprelChartTreeNode wrapTreeNodeToUp(DynamicObject dyn, int currentLevel, String parentId) {
        EmpSuprelChartTreeNode node = new EmpSuprelChartTreeNode();
        node.setId(String.valueOf(ID.genLongId()));
        node.setParentid(parentId);
        node.setText(dyn.getString("superiorempposorgrel.employee.name"));
        node.setPersonId(dyn.getString("superiorempposorgrel.employee.id"));
        // 当前所在层级
        node.setCurrentLevel(currentLevel + 1 );
        return node;

    }

    private List<EmpSuprelChartTreeNode> getAllEmpSuprelTreeNodesToDown(EmpSuprelChartTreeNode treeNode, String showlevel, QFilter searchQf) {
        // 总层级
        int level = Integer.parseInt(showlevel);
        String nodeId = treeNode.getId();
        String personId = treeNode.getPersonId();
        // 当前所在层级
        int currentLevel = treeNode.getCurrentLevel();
        Map<Integer, List<EmpSuprelChartTreeNode>> levelToTreeNodeListMap = new HashMap<>();
        List<EmpSuprelChartTreeNode> firstTreeNodeList = new ArrayList<>();
        // 查询第一层业务数据
        DynamicObjectCollection firstLevelCollection = queryBusinessDataToDown(personId, searchQf);
        for (DynamicObject dyn : firstLevelCollection) {
            EmpSuprelChartTreeNode node = wrapTreeNodeToDown(dyn, currentLevel, nodeId);
            firstTreeNodeList.add(node);
        }

        // 第二层映射对象
        levelToTreeNodeListMap.put(1, firstTreeNodeList);
        // 树对象结果集
        List<EmpSuprelChartTreeNode> allEmpSuprelChartTreeNodeList = new ArrayList<>(firstTreeNodeList);

        // 从第二层开始
        for (int index = 2; index <= level - 1; ++index) {
            List<EmpSuprelChartTreeNode> collectList = levelToTreeNodeListMap.get(index - 1);
            if (collectList != null) {
                for (EmpSuprelChartTreeNode empSuprelChartTreeNode : collectList) {
                    String parentId = empSuprelChartTreeNode.getId();
                    List<EmpSuprelChartTreeNode> tempTreeNodeList = new ArrayList<>();
                    DynamicObjectCollection curentLevelBusinessData = queryBusinessDataToDown(empSuprelChartTreeNode.getPersonId(), searchQf);
                    // 最后一层时，不设置节点
                    if (index == level -1 && curentLevelBusinessData.size() > 0){
                        empSuprelChartTreeNode.setChildrenCount(curentLevelBusinessData.size());
                        continue;
                    }

                    for (DynamicObject dyn : curentLevelBusinessData) {
                        // 包装树对象
                        EmpSuprelChartTreeNode node = wrapTreeNodeToDown(dyn, index, parentId);
                        tempTreeNodeList.add(node);
                    }

                    if (tempTreeNodeList.size() > 0) {
                        levelToTreeNodeListMap.put(index, tempTreeNodeList);
                        allEmpSuprelChartTreeNodeList.addAll(tempTreeNodeList);
                    }
                }

            }
        }
        return allEmpSuprelChartTreeNodeList;
    }

    private List<EmpSuprelChartTreeNode> getAllEmpSuprelTreeNodesToUp(EmpSuprelChartTreeNode treeNode, String showlevel, QFilter searchQf) {
        // 总层级
        int level = Integer.parseInt(showlevel);
        String nodeId = treeNode.getId();
        String personId = treeNode.getPersonId();
        // 当前所在层级
        int currentLevel = treeNode.getCurrentLevel();
        Map<Integer, List<EmpSuprelChartTreeNode>> levelToTreeNodeListMap = new HashMap<>();
        List<EmpSuprelChartTreeNode> firstTreeNodeList = new ArrayList<>();
        // 查询第一层业务数据
        DynamicObjectCollection firstLevelCollection = queryBusinessDataToUp(personId, searchQf);
        for (DynamicObject dyn : firstLevelCollection) {
            EmpSuprelChartTreeNode node = wrapTreeNodeToUp(dyn, currentLevel, nodeId);
            firstTreeNodeList.add(node);
        }

        // 第二层映射对象
        levelToTreeNodeListMap.put(1, firstTreeNodeList);
        // 树对象结果集
        List<EmpSuprelChartTreeNode> allEmpSuprelChartTreeNodeList = new ArrayList<>(firstTreeNodeList);

        // 从第二层开始
        for (int index = 2; index <= level - 1; ++index) {
            List<EmpSuprelChartTreeNode> collectList = levelToTreeNodeListMap.get(index - 1);
            if (collectList != null) {
                for (EmpSuprelChartTreeNode empSuprelChartTreeNode : collectList) {
                    String parentId = empSuprelChartTreeNode.getId();
                    List<EmpSuprelChartTreeNode> tempTreeNodeList = new ArrayList<>();
                    DynamicObjectCollection curentLevelBusinessData = queryBusinessDataToUp(empSuprelChartTreeNode.getPersonId(), searchQf);
                    // 最后一层时，不设置节点
                    if (index == level -1 && curentLevelBusinessData.size() > 0){
                        empSuprelChartTreeNode.setChildrenCount(curentLevelBusinessData.size());
                        continue;
                    }

                    for (DynamicObject dyn : curentLevelBusinessData) {
                        // 包装树对象
                        EmpSuprelChartTreeNode node = wrapTreeNodeToUp(dyn, index, parentId);
                        tempTreeNodeList.add(node);
                    }

                    if (tempTreeNodeList.size() > 0) {
                        levelToTreeNodeListMap.put(index, tempTreeNodeList);
                        allEmpSuprelChartTreeNodeList.addAll(tempTreeNodeList);
                    }
                }

            }
        }
        return allEmpSuprelChartTreeNodeList;
    }

    private DynamicObjectCollection queryBusinessDataToDown(String personId, QFilter searchQf) {
        HRBaseServiceHelper helper = new HRBaseServiceHelper("hrpi_empsuprel");
        // 生效中
        QFilter businessstatusQf = new QFilter("businessstatus", QCP.equals, "1");
        // 当前版本
//        QFilter currentQf = new QFilter("iscurrentversion", QCP.equals, true);
        // 汇报上级
        QFilter superiorQf = new QFilter("superiorempposorgrel.employee.id", QCP.equals, Long.valueOf(personId));
        return helper.queryOriginalCollection("id,employee,employee.name,superiorempposorgrel.employee.id,superiorempposorgrel.employee.name", new QFilter[]{businessstatusQf, superiorQf, searchQf});
    }

