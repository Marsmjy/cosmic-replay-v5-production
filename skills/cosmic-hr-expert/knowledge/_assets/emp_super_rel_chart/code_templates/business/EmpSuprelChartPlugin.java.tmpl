    private EmpSuprelChartTreeNode getEmpSuprelChartTreeNode(Long personId, JSONObject paramsJsonObj, EmpSuprelChartTreeNode rootTreeNode) {
        DynamicObject rootDyn = getRootNodeDynamic(personId);
        if (rootDyn != null) {
            // 构造根树对象
            rootTreeNode = buildRootTreeNode(rootDyn, paramsJsonObj);

        }
        return rootTreeNode;
    }


    @Override
    public void customEvent(CustomEventArgs args) {
        String eventName = args.getEventName();
        JSONObject paramsJsonObj = JSONObject.parseObject(args.getEventArgs());
        LOGGER.info("[EmpSuprelChartPlugin.customEvent] paramsJsonObj:{}", paramsJsonObj);
        switch (eventName) {
            case "queryEmpSuprelChartTreeNode":
                queryEmpSuprelChartTreeNode(paramsJsonObj, eventName, "update");
                break;
            case "jumpToErmanFileInfo":
                // 点击头像跳转到人员档案
                jumpToErmanFileInfo(paramsJsonObj);
                break;
            default:
                break;
        }

    }

    @Override
    public void propertyChanged(PropertyChangedArgs e) {
        super.propertyChanged(e);
        String name = e.getProperty().getName();
        JSONObject paramsJsonObj = new JSONObject();
        // 默认向下查
        paramsJsonObj.put("showDirection","down");
        // 层级--默认三层,展示两层
        paramsJsonObj.put("level", "3");
        paramsJsonObj.put("currentLevel", "1");
        // 根节点父Id
        paramsJsonObj.put("parentId", "");
        // 当前节点Id
        paramsJsonObj.put("nodeId", "");
        DynamicObject dataEntity = getModel().getDataEntity();
        String personId = dataEntity.getString("${ISV_FLAG}_hrperson.id");
        String reportReltypeNumber = dataEntity.getString("${ISV_FLAG}_reportreltype.number");
        if (HRStringUtils.isEmpty(personId)){
            this.getView().showErrorNotification("查询人员不能为空");
            return;
        }
        if (HRStringUtils.isEmpty(reportReltypeNumber)){
            this.getView().showErrorNotification("汇报关系类型不能为空");
            return;
        }
        switch (name){
            case "${ISV_FLAG}_reportreltype":
                // 查询汇报关系类型
                paramsJsonObj.put("personId", personId);
                paramsJsonObj.put("reportReltypeNumber", reportReltypeNumber);
                queryEmpSuprelChartTreeNode(paramsJsonObj, "openReportReltypeF7", "update");
                break;
            case "${ISV_FLAG}_hrperson":
                // 查询人员
                paramsJsonObj.put("reportReltypeNumber", reportReltypeNumber);
                paramsJsonObj.put("personId", personId);
                queryEmpSuprelChartTreeNode(paramsJsonObj, "openHrPersonF7", "update");
                break;
            case "${ISV_FLAG}_adminorg":
                // 查询部门
                long orgBoId = dataEntity.getLong("${ISV_FLAG}_adminorg.id");
                Long chargePersonId = getChargePersonByOrgId(orgBoId);
                // 部门负责人 赋值给查询人员
                if (chargePersonId != null && chargePersonId != 0L){
                    getModel().setValue("${ISV_FLAG}_hrperson",chargePersonId);
                }else {
                    paramsJsonObj.put("personId", personId);
                    paramsJsonObj.put("reportReltypeNumber", reportReltypeNumber);
                    queryEmpSuprelChartTreeNode(paramsJsonObj, "openHrPersonF7", "update");
                }

                break;
            default:
                break;
        }
    }

    /**
     * 根据部门boid 查询部门负责人
     *
     * @param orgBoId orgBoId
     * @return Long
     */
    private Long getChargePersonByOrgId(long orgBoId) {
        List<Long> orgList = new ArrayList<Long>();
        orgList.add(orgBoId);
        Map<Long, List<Map<String, Object>>> getPersonMap = HAOSServiceHelper.queryChargePersonByOrgId(orgList,new Date());
        if(getPersonMap.size() > 0) {
            List<Map<String, Object>> list = getPersonMap.get(orgBoId);
            if(list.size() > 0 ){
                // 部门负责人 财信这只有一个，标品多个
                long personId = Long.parseLong(String.valueOf(list.get(0).get("employee.id")));
                LOGGER.info("部门:{},部门负责人personId:{}",orgBoId,personId);
                return personId;
            }
        }
        return null;
    }


    @Override
    public void closedCallBack(ClosedCallBackEvent closedCallBackEvent) {
        super.closedCallBack(closedCallBackEvent);
        String actionId = closedCallBackEvent.getActionId();
        if ("openHrPersonF7".equals(actionId)) {
            this.afterHrPersonF7Select(closedCallBackEvent);
        } else if ("openReportReltypeF7".equals(actionId)) {
            this.afterReportReltypeF7Select(closedCallBackEvent);
        }

    }

    private void queryEmpSuprelChartTreeNode(JSONObject paramsJsonObj, String eventName, String status) {
        Long personId = Long.parseLong(paramsJsonObj.getString("personId"));
        Map<String, Object> result = new HashMap<>();
        EmpSuprelChartTreeNode rootTreeNode = null;
        rootTreeNode = getEmpSuprelChartTreeNode(personId, paramsJsonObj, rootTreeNode);
        // 设置返回树对象数据
        result.put("treeNodeData", rootTreeNode);
        // 层级
        result.put("level", paramsJsonObj.getString("level"));
        // 汇报关系类型
        result.put("reportReltypeInfo", getReportReltypeInfo(paramsJsonObj.getString("reportReltypeNumber")));
        // 查询人员
        result.put("personInfo", getPersonInfo(paramsJsonObj.getString("personId")));
        // 更新数据
        setDataToCustomControl(eventName, result, "200", status);
    }

    public JSONObject getPersonInfo(String personId) {
        if (HRStringUtils.isNotEmpty(personId)) {
            HRBaseServiceHelper helper = new HRBaseServiceHelper("hrpi_employeenewf7query");
            QFilter dataStatusQf = new QFilter("datastatus", QCP.equals, "1");
            QFilter currentVersionQf = new QFilter("iscurrentversion", QCP.equals, true);
            QFilter idQf = new QFilter("id", QCP.equals, Long.valueOf(personId));
            DynamicObject dy = helper.queryOne("id,name,number", new QFilter[]{dataStatusQf, currentVersionQf, idQf});
            if (dy != null) {
                JSONObject info = new JSONObject();
                info.put("id", dy.getString("id"));
                info.put("name", dy.getString("name"));
                info.put("number", dy.getString("number"));
                return info;
            }
        }

        return new JSONObject();
    }

    public JSONObject getReportReltypeInfo(String number) {
        if (HRStringUtils.isNotEmpty(number)) {
            HRBaseServiceHelper helper = new HRBaseServiceHelper("hbpm_reportcoreltype");
            QFilter statusQf = new QFilter("status", QCP.equals, "C");
            QFilter enableQf = new QFilter("enable", QCP.equals, "1");
            QFilter numberQf = new QFilter("number", QCP.equals, number);

            DynamicObject dy = helper.queryOne("id,number,name", new QFilter[]{statusQf, enableQf, numberQf});
            if (dy != null) {
                JSONObject info = new JSONObject();
                info.put("id", dy.getString("id"));
                info.put("name", dy.getString("name"));
                info.put("number", dy.getString("number"));
                return info;
            }
        }

        return new JSONObject();
    }


    private void afterReportReltypeF7Select(ClosedCallBackEvent closedCallBackEvent) {
        ListSelectedRowCollection selectedRows = (ListSelectedRowCollection) closedCallBackEvent.getReturnData();
        Map<String, Object> result = new HashMap();
        if (!CollectionUtils.isEmpty(selectedRows) && selectedRows.size() > 0) {
            JSONObject info = new JSONObject();
            HRBaseServiceHelper helper = new HRBaseServiceHelper("hbpm_reportreltype");
            DynamicObject dyn = helper.queryOne("id,name,number", selectedRows.get(0).getPrimaryKeyValue());
            info.put("id", dyn.getString("id"));
            info.put("number", selectedRows.get(0).getNumber());
            info.put("name", selectedRows.get(0).getName());
            result.put("reportReltypeInfo", info);
        }

        this.setDataToCustomControl("openReportReltypeF7", result, "200", "update");
    }

    private void afterHrPersonF7Select(ClosedCallBackEvent closedCallBackEvent) {
        ListSelectedRowCollection selectedRows = (ListSelectedRowCollection) closedCallBackEvent.getReturnData();
        Map<String, Object> result = new HashMap();
        if (!CollectionUtils.isEmpty(selectedRows) && selectedRows.size() > 0) {
