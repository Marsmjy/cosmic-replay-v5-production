    @Override
    public void afterCreateNewData(EventObject e) {
        super.afterCreateNewData(e);
        Long personId = queryPersonId();
        JSONObject paramsJsonObj = new JSONObject();
        // 设置默认值
        getModel().setValue("${ISV_FLAG}_hrperson",personId);
        // 汇报关系类型--默认行政
        paramsJsonObj.put("personId", personId);

        paramsJsonObj.put("reportReltypeNumber", "1010_S");
        // 层级--默认三层,展示两层
        paramsJsonObj.put("level", "3");

        paramsJsonObj.put("currentLevel", "1");
        // 默认向下展示
        paramsJsonObj.put("showDirection","down");
        // 根节点父Id
        paramsJsonObj.put("parentId", "");
        // 当前节点Id
        paramsJsonObj.put("nodeId", "");
        // 初始化数据
        queryEmpSuprelChartTreeNode(paramsJsonObj, "initData", "init");

