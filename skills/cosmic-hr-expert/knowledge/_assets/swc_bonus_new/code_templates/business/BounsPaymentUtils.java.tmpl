    /**
     * 奖金发放记录推送到前端业务数据中
     * @param entryBills 奖金发放记录
     * @param currencyId 币别
     * @param batchcode 批次号
     * @param effDate 生效日期
     * @param bonusCheckGroup 核定单单号
     */
    public static Map<String, String> pushItem(DynamicObjectCollection entryBills,Long currencyId,String batchcode,Date effDate,Map<String,String> bonusCheckGroup) {
        QFilter personFilter = new QFilter("id", QCP.equals, RequestContext.get().getCurrUserId());
        DynamicObject currentPerson = QueryServiceHelper.queryOne("bos_user", "id,number", personFilter.toArray());
        QFilter filter = new QFilter("employee.empnumber", QCP.equals, currentPerson.getString("number"));
        filter.and(new QFilter("isdeleted",QCP.equals,"0"));
        DynamicObject empPosRel = BusinessDataServiceHelper.loadSingle("hrpi_empposorgrel", "id,adminorg,position,company", new QFilter[]{filter});
        // 分录字段推送算薪
        List<Map<String, Object>> bizDataList = new ArrayList<>();
        for (DynamicObject entry : entryBills) {
            // 无需推送的数据过滤掉
            String pushStatus = entry.getString("${ISV_FLAG}_push_status");
            if ("F".equals(pushStatus)){
                continue;
            }

            Map<String, Object> bizDataObj = new HashMap();
            bizDataList.add(bizDataObj);

            //业务项目id
            bizDataObj.put("bizitemid", entry.getLong("${ISV_FLAG}_bonus_item.${ISV_FLAG}_business_item.id"));
            // 币别
            bizDataObj.put("currencyid", currencyId);
            // 是否加密
            bizDataObj.put("isencrypted", "false");
            // 前端业务数据识别码
            String bizdatacode = entry.getLong("id") + "&" + entry.getString("${ISV_FLAG}_person.empnumber");
            bizDataObj.put("bizdatacode", bizdatacode);
            // 批次号
            bizDataObj.put("batchcode", batchcode);
            // 业务数据模板id
            // bizDataObj.put("bizdataaccesstplid", "");
            //任职经历id  必填
             bizDataObj.put("empposorgrelid", empPosRel.getLong("id"));
            // 频度
            //bizDataObj.put("calfrequencyid", null);
            //业务数据生效日期
            bizDataObj.put("startdate", effDate);
            //失效日期
            //bizDataObj.put("enddate", null);
            // 数据来源系统 hpdi-前端 hcdm-薪酬管理 wtc-考勤
            bizDataObj.put("srcsystem", "奖金平台");
            // 数据来源 1-手工新增 2-前端集成 3-前端提报
            bizDataObj.put("datasources", "2");
            // 档案id
            long salaryfileid = entry.getLong("${ISV_FLAG}_salary_file_id");
            bizDataObj.put("salaryfileid", salaryfileid);
            // 业务数据值
            bizDataObj.put("value", String.valueOf(entry.getBigDecimal("${ISV_FLAG}_current_amount").doubleValue()));
            // 备注
            bizDataObj.put("description", bonusCheckGroup.get(entry.getString("${ISV_FLAG}_check_id")));
            // 业务数据生效日期
//            bizDataObj.put("bsed", effDate);
            // 所属周期
            bizDataObj.put("${ISV_FLAG}_period",entry.getDate("${ISV_FLAG}_period"));
            // 承担组织
            bizDataObj.put("${ISV_FLAG}_shoulder_orgid",entry.getLong("${ISV_FLAG}_shoulder_org.id"));
            // 奖金业务类别
            bizDataObj.put("${ISV_FLAG}_personalization",entry.getString("${ISV_FLAG}_personalization"));
            // 本次兑现金额
            bizDataObj.put("${ISV_FLAG}_current_amount", entry.getBigDecimal("${ISV_FLAG}_current_amount").doubleValue());
        }
        List<List<Map<String, Object>>> synListData = splitCollection(bizDataList, 500);
        Map<String, String> errorMap = new HashMap<>();
        int size = synListData.size()-1;
        int index = 0;
        synBizDataBySalaryFile(synListData, errorMap, size, index);
        return errorMap;
    }

    private static void synBizDataBySalaryFile(List<List<Map<String, Object>>> synListData, Map<String, String> errorMap, int size, int index) {
        List<Map<String, Object>> data = synListData.get(index);
        Map<String, Object> params = new HashMap<>();
        params.put("operate", "1");       // 是否新增,1新增 ,2更正
        params.put("opsystem", "hsas");   // 操作提报数据系统
        params.put("data", data);
        Map<String, Object> result = HSASBizDataServiceHelper.synBizData(params);
        List<Map<String, Object>>  resultList = (List)result.get("result");
        for (Map<String, Object> res : resultList) {
            if(!"1".equals(res.get("status"))) {
                String errorcode = (String) res.get("errorcode");
                String errerMessage = BizDataFailStatusEnum.getDesc(errorcode);
                errorMap.put((String)res.get("bizdatacode"),errerMessage);
            }
        }
        if (index == size){
            return;
        }
        synBizDataBySalaryFile(synListData, errorMap, size, index + 1);
    }

    public static List<List<Map<String, Object>>> splitCollection(List<Map<String, Object>> bizDataList,int size) {
        List<List<Map<String, Object>>> batches = new ArrayList<>();
        if (bizDataList.isEmpty()){
            return batches;
        }
        List<Map<String, Object>> currentBatch = new ArrayList<>(size);
        for (Map<String, Object> data : bizDataList) {
            currentBatch.add(data);
            if (currentBatch.size() == size){
                batches.add(currentBatch);
                currentBatch = new ArrayList<>(size);
            }
        }
        if (!currentBatch.isEmpty()){
            batches.add(currentBatch);
        }
        return batches;
    }





    /**
     * 删除已经推送的数据
     * @param entryBills 奖金发放记录
     * @param operate E 废弃，LD 删除，LDE先删除，删除不了后废弃
     */
    public static Map<String, String> delete(DynamicObjectCollection entryBills,String operate) {
        Map<String, Object> params = new HashMap<>();
        params.put("operate", operate);
        params.put("opsystem", "hsas");
        List<Map<String, Object>> bizDataList = new ArrayList<>();
        params.put("data", bizDataList);
        for (DynamicObject entry : entryBills) {
            // 无需推送的数据过滤掉
            String pushStatus = entry.getString("${ISV_FLAG}_push_status");
            if ("F".equals(pushStatus)){
                continue;
            }
            String bizdatacode = entry.getLong("id") + "&" + entry.getString("${ISV_FLAG}_person.empnumber");
            Map<String, Object> bizDataObj = new HashMap<>();
            bizDataList.add(bizDataObj);
            bizDataObj.put("bizitemid", entry.getLong("${ISV_FLAG}_bonus_item.${ISV_FLAG}_business_item.id"));
            bizDataObj.put("bizdatacode", bizdatacode);;
        }
        //删除数量为0，不调用标品接口
        Map<String, String> errorMap = new HashMap<>();
        if (bizDataList.size() == 0){
            return errorMap;
        }
        Map<String, Object> result = HSASBizDataServiceHelper.delBizData(params);

        if(!((boolean)result.get("success"))){
            throw new KDBizException("删除算薪失败。"+result);
        }
        // 整理错误信息并显示
        List<Map<String, Object>>  resultList = (List)result.get("result");
        for (Map<String, Object> res : resultList) {
            if(!"1".equals(res.get("status"))) {
                String errorcode = (String) res.get("errorcode");
                String errerMessage = BizDataFailStatusEnum.getDesc(errorcode);
                errorMap.put((String)res.get("bizdatacode"),errerMessage);
            }
        }
        return errorMap;
    }

