    public static DynamicObject[] getErmanfile(Long userId){
        // 查询生效中的人事业务档案
        QFilter personFilter = new QFilter("id", QCP.equals, userId);
        DynamicObject currentPerson = QueryServiceHelper.queryOne("bos_user", "id,number", personFilter.toArray());
