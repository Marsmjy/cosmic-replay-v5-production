        filter.and("filetype.number",QCP.not_equals,"1050_S");
        return BusinessDataServiceHelper.load("hspm_ermanfile", "org,empposrel.depemp", filter.toArray());
    }

    /**
     * 发放单，奖金代发，奖金终止，奖金发放校验
     */
    public static List<String> bounsPaymentvalidtor(List<Long> ids,String operateKey){
        List<String> errorMsg = new ArrayList<>();

        // 获取真正进行代发的发放单
        List<Long> bounsAgentApproveSourceIds = BounsPaymentUtils.getBounsAgentApproveSourceIds(ids);
        // 获取真正进行终止的发放单
        List<Long> bounsEndApproveSourceIds = BounsPaymentUtils.getBounsEndApproveSourceIds(ids);
        // 查询正在进行奖金发放的记录单
        List<Long> bounsRecordSourceIds = BounsPaymentUtils.getBounsRecordSourceIds(ids);

        // 查询发放单数据
        // 校验
        DynamicObject[] load = getBonusPaymentObjecys(ids);
        for (DynamicObject bill : load) {
            long id = bill.getLong("id");
            String personNumber = bill.getString("${ISV_FLAG}_person.empnumber");
            if (bounsAgentApproveSourceIds.contains(id)) {
                errorMsg.add("”" + personNumber + "“员工已存在正在处理中的代发，请处理后在进行其他业务。\n");
            }
            if (bounsEndApproveSourceIds.contains(id)) {
                errorMsg.add("”" + personNumber + "“员工已存在正在处理中的终止发放，请处理后在进行其他业务。\n");
            }
            if (bounsRecordSourceIds.contains(id)) {
                errorMsg.add("”" + personNumber + "“员工已存在正在处理中的发放记录，请处理后在进行其他业务。\n");
            }

            String billstatus = bill.getString("billstatus");
            if (!"C".equals(billstatus)){
                errorMsg.add("”" + personNumber + "“员工单据状态不为已审核，请重新选择执行数据。\n");
            }

            // 奖金代发
            if (BounsPaymentUtils.DonothingAgentDisbursement.equals(operateKey)){
                // 若所选人员已发金额大于0不允许代发，提醒“XXX员工存在已发放记录，不允许代发”
                DynamicObjectCollection entryentity = bill.getDynamicObjectCollection("entryentity");
                if (!CollectionUtils.isEmpty(entryentity)){
                    errorMsg.add("”" + personNumber + "“员工存在已发放记录，不允许代发。\n");
                }

                // 承担组织编码、所属公司编码
                /*String shoulderOrgNumber = bill.getString("${ISV_FLAG}_shoulder_org.number");
                String companyNumber = bill.getString("${ISV_FLAG}_company.number");
                if(StringUtils.isEmpty(shoulderOrgNumber) || StringUtils.isEmpty(companyNumber) || shoulderOrgNumber.equals(companyNumber)){
                    errorMsg.add("”" + personNumber + "“员工承担组织和所在公司相同不可代发。\n");
                }*/
            }

            // 奖金终止
            if (BounsPaymentUtils.DonothingBonusTermination.equals(operateKey)){
                BigDecimal redeemAoumt = bill.getBigDecimal("${ISV_FLAG}_redeem_amount");
                if (BigDecimal.ZERO.compareTo(redeemAoumt) == 0){
                    errorMsg.add("”" + personNumber + "“员工无可兑现奖金，无法终止\n");
                }
            }

            // 奖金发放
            if (BounsPaymentUtils.DonothingBonusPayment.equals(operateKey)){
                BigDecimal redeemAoumt = bill.getBigDecimal("${ISV_FLAG}_redeem_amount");
                if (BigDecimal.ZERO.compareTo(redeemAoumt) == 0){
                    errorMsg.add("”" + personNumber + "“员工无可兑现奖金，无法进行发放\n");
                }
            }

        }

        // 奖金代发
        if (BounsPaymentUtils.DonothingAgentDisbursement.equals(operateKey)){
            // 若所选人员所在公司不同不允许批量代发
            Map<String, List<DynamicObject>> collect = Arrays.stream(load).collect(Collectors.groupingBy(item -> {
                String orgNumber = item.getString("org.number");
                String companyNumber = item.getString("${ISV_FLAG}_company.number");
                return orgNumber + "&" + companyNumber;
            }));
            if (collect.size() > 1){
                errorMsg.add("所选人员不是相同奖金管理组织、相同所属公司，请重新择则执行数据。\n");
            }
        }

        // 奖金终止
        if (BounsPaymentUtils.DonothingBonusTermination.equals(operateKey)){
            // 若所选人员承担组织不同不允许批量代发
            Map<String, List<DynamicObject>> collect = Arrays.stream(load).collect(Collectors.groupingBy(item -> {
                String orgNumber = item.getString("org.number");
                String companyNumber = item.getString("${ISV_FLAG}_shoulder_org.number");
                return orgNumber + "&" + companyNumber;
            }));
            if (collect.size() > 1){
                errorMsg.add("所选人员不是相同奖金管理组织、相同承担组织，请重新选择执行数据。\n");
            }
        }

        // 奖金发放记录
        if (BounsPaymentUtils.DonothingBonusPayment.equals(operateKey)){
            // 所选人员发放公司不同时不允许发放
            Map<String, List<DynamicObject>> collect = Arrays.stream(load).collect(Collectors.groupingBy(item -> {
                String orgNumber = item.getString("org.number");
                String paymentCompanyNumber = item.getString("${ISV_FLAG}_payment_company.number");
                return orgNumber + "&" + paymentCompanyNumber;
            }));
            if (collect.size() > 1){
                errorMsg.add("所选人员不是相同奖金管理组织、相同发放公司，请重新选择执行数据。\n");
            }
        }

        // 错误结果返回;
        return IntStream.range(0, errorMsg.size()).mapToObj(i -> (i + 1) + "、" + errorMsg.get(i)).collect(Collectors.toList());
    }

