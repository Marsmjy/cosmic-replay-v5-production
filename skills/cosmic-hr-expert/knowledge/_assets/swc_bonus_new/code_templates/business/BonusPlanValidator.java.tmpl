package ${ISV_FLAG}.swc.hsbm.biz.swc.plugin.form.${ISV_FLAG}_bonus_plan.operation;

import kd.bos.dataentity.entity.DynamicObject;
import kd.bos.dataentity.utils.StringUtils;
import kd.bos.entity.ExtendedDataEntity;
import kd.bos.entity.validate.AbstractValidator;
import kd.bos.exception.KDBizException;
import kd.bos.orm.query.QCP;
import kd.bos.orm.query.QFilter;
import kd.bos.servicehelper.BusinessDataServiceHelper;

import java.util.ArrayList;
import java.util.Arrays;
import java.util.List;
import java.util.Map;
import java.util.Set;
import java.util.stream.Collectors;
import java.util.stream.IntStream;

/**
 * Author: wanghansheng
 * Date: 2025/03/13
 * FileName:
 * Description: 奖金计划校验
 */
public class BonusPlanValidator extends AbstractValidator {
    public static final String otherApprovalExplain = "4";
    @Override
    public void validate() {
        String operateKey = this.getOperateKey();
        ExtendedDataEntity[] dataEntities = this.getDataEntities();
        // 收集计划汇总单id
        Set<Long> planApprovelIds = Arrays.stream(dataEntities).filter(item -> !StringUtils.isEmpty(item.getDataEntity().getString("${ISV_FLAG}_plan_summary")))
                .map(item -> Long.valueOf(item.getDataEntity().getString("${ISV_FLAG}_plan_summary"))).collect(Collectors.toSet());
        // 查询计划汇总单
        DynamicObject[] bonusPlanApprovalList = BusinessDataServiceHelper.load("${ISV_FLAG}_bonus_plan_approval", "id,billstatus", new QFilter[]{new QFilter("id",QCP.in,planApprovelIds)});
        Map<String, String> resourseMap = Arrays.stream(bonusPlanApprovalList).collect(Collectors.toMap(key -> String.valueOf(key.getLong("id")), value -> value.getString("billstatus")));
        List<String> approvalExplains =Arrays.asList("1","2","3");//已报批、已发文、执行制度

        // 保存和提交并生效的校验
        if ("save".equals(operateKey) || "submiteffect".equals(operateKey)){
            for (ExtendedDataEntity bill : dataEntities) {
                DynamicObject dataEntity = bill.getDataEntity();
                String approvalExplain = dataEntity.getString("${ISV_FLAG}_approval_explain");
                StringBuilder errorList = new StringBuilder();
                if (approvalExplains.contains(approvalExplain)){
                    // 若报批说明选择已报批、已发文、执行制度，那么展示字段 “流程单号/发文文号/制度文件编号” 并且必填
                    String fileNumber = dataEntity.getString("${ISV_FLAG}_file_number");
                    // 附件树
                    int fileSize = dataEntity.getInt("${ISV_FLAG}_file_size");
                    if (StringUtils.isEmpty(fileNumber)){
                        errorList.append("请填写 ”流程单号/发文文号/制度文件编号“。");
                    }

                    if (fileSize == 0){
                        errorList.append("请为“报批说明”提供相关附件。");
                    }
                }

                // 奖金业务分类为个性化类、其他时，报批说明不能为非已报批/发文/执行制度
                String personalRewards = dataEntity.getString("${ISV_FLAG}_personal_rewards");
                if ("4".equals(approvalExplain) && Arrays.asList("0","1").contains(personalRewards)){
//                    errorList.append("【奖金业务分类】为“个性化类”“其他”时需提前进行报批。");
                }
                // 奖金业务分类为重大科创类
                if ("3".equals(personalRewards)){
                    String orgNumber = dataEntity.getString("org.number");
                    if (!"TW01".equals(orgNumber)){
                        errorList.append("【奖金业务分类】为“重大科创类”仅供股份选择。");
                    }else {
                        if ("4".equals(approvalExplain)){
                            errorList.append("【奖金业务分类】为“重大科创类”时需提前进行报批");
                        }
                    }
                }

                if(errorList.length() > 0){
                    this.addErrorMessage(bill,errorList.toString());
                }
            }
        }

        // 反审核校验
        if ("unaudit".equals(operateKey)){
            for (ExtendedDataEntity bill : dataEntities) {
                DynamicObject dataEntity = bill.getDataEntity();
                String planApprovelId = dataEntity.getString("${ISV_FLAG}_plan_summary");
                String planApprovelStatus = resourseMap.get(planApprovelId);
                // 如果汇总审批单的审批状态不为空，并且不为废弃状态，则不允许反审核
                if (!StringUtils.isEmpty(planApprovelStatus) && !"F".equals(planApprovelStatus)){
                    this.addErrorMessage(bill,"仅“已审核”且未生成审批单的数据可进行反审核。");
                }
            }
        }

        // 失效计划校验
        if ("donothing_fail_invalid_plan".equals(operateKey)){
            for (ExtendedDataEntity bill : dataEntities) {
                DynamicObject dataEntity = bill.getDataEntity();
                String planStatus = dataEntity.getString("${ISV_FLAG}_plan_status");
                String planApprovelId = dataEntity.getString("${ISV_FLAG}_plan_summary");
                String planApprovelStatus = resourseMap.get(planApprovelId);
                if ("0".equals(planStatus)){
                    this.addErrorMessage(bill,"已失效的计划无需再次失效。");
                }
                // 如果汇总审批单的审批状态不为空，并且不为已审核，则失效计划
                if (StringUtils.isEmpty(planApprovelStatus) || !"C".equals(planApprovelStatus)){
                    this.addErrorMessage(bill,"只能对汇总审批单审批通过的计划进行失效操作。");
                }
            }
        }

        // 生成审批单校验
        if ("donothing_push_check".equals(operateKey)){
            // 收集奖金业务类别
            Set<String> personalRewards = Arrays.stream(dataEntities).map(item -> item.getDataEntity().getString("${ISV_FLAG}_personal_rewards")).collect(Collectors.toSet());
            List<String> errorMsg = new ArrayList<>();
            if(personalRewards.contains("0") || personalRewards.contains("1")){
                if (personalRewards.contains("2") || personalRewards.contains("3") || personalRewards.contains("4")){
                    errorMsg.add("“个性化类”或“其他”数据请单独发起审批");
                }
            }

            Set<String> billstatusSet = Arrays.stream(dataEntities).map(item -> item.getDataEntity().getString("billstatus")).collect(Collectors.toSet());
            if (billstatusSet.contains("A")){
                errorMsg.add("请勿勾选暂存单生成审批单");
            }

            // ${ISV_FLAG}_approval_explain
            // 已报批/已发文/执行制度 1
            // 非已报批/发文/执行制度 4
            Set<String> explainKeys = Arrays.stream(dataEntities).filter(item ->
                    "1".equals(item.getDataEntity().getString("${ISV_FLAG}_approval_explain")) ||
                            "4".equals(item.getDataEntity().getString("${ISV_FLAG}_approval_explain"))
            ).map(item -> item.getDataEntity().getString("${ISV_FLAG}_approval_explain")).collect(Collectors.toSet());
            if(explainKeys != null && explainKeys.size() > 1){
                errorMsg.add("“已报批/已发文/执行制度”和“非已报批/已发文/执行制度”不能汇总生成审批单");
            }

            // 检测到错误信息直接抛出错误信息
            List<String> errorMessageList = IntStream.range(0, errorMsg.size()).mapToObj(i -> (i + 1) + "、" + errorMsg.get(i)).collect(Collectors.toList());
            if (errorMessageList.size() > 0){
                throw new KDBizException(String.join("",errorMessageList));
            }
        }
    }
}