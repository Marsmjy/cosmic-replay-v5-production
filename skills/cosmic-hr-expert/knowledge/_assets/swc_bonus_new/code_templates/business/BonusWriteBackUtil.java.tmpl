    /**
     * 通过属性获取json中的string类型值
     * @param data json对象
     * @param mainDataKey 主属性
     * @param fieldName 从属性
     * @return
     */
    public static String getFieldStringValue(JSONObject data, String mainDataKey, String fieldName) {
        String value = "";
        if(data != null){
            if(data.getJSONObject(mainDataKey) != null){
                value = data.getJSONObject(mainDataKey).get(fieldName).toString();
            }
        }
        return value;
    }

    /**
     * 奖金业务类别匹配
     */
    public static String mathcValue(String type){
        if ("0".equals(type)){
            return "其他";
        }

        if ("1".equals(type)){
            return "个性化类";
        }

        if ("2".equals(type)){
            return "工程建设类";
        }

        if ("3".equals(type)){
            return "重大科创类";
        }

        if ("4".equals(type)){
            return "年终奖类";
        }
        return "";
    }
