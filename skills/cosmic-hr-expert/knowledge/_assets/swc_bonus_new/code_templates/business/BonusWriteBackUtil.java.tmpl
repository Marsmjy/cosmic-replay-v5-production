    /**
     * @param checkIdList 核定单的id集合
     */
    public static void updateBonusPlanSure(List<Long> checkIdList) {
        QFilter bonusSureFilter = new QFilter("id", QCP.in, checkIdList);
        bonusSureFilter.and("billstatus", QFilter.equals, "C");
        // 奖金核定列表 id，核定总额，奖金计划id，奖金核定汇总单id
        DynamicObject[] bonusSureList = BusinessDataServiceHelper.load("${ISV_FLAG}_bonus_approval_2nd", "id,${ISV_FLAG}_approval_total,${ISV_FLAG}_plan_bill_id,${ISV_FLAG}_check_summary", bonusSureFilter.toArray());
        Map<String, List<DynamicObject>> bonusCheckGroup = Arrays.stream(bonusSureList).collect(Collectors.groupingBy(item -> item.getString("${ISV_FLAG}_plan_bill_id")));

        // 奖金计划id
        List<Long> planIds = bonusCheckGroup.keySet().stream().map(item -> Long.valueOf(item)).collect(Collectors.toList());
        QFilter bonusFilter = new QFilter("id", QCP.in, planIds);
        DynamicObject[] bizdatabills = BusinessDataServiceHelper.load("${ISV_FLAG}_bonus_plan", "id,${ISV_FLAG}_app_total_amount,${ISV_FLAG}_sur_total_amonut,${ISV_FLAG}_plan_money,${ISV_FLAG}_over", bonusFilter.toArray());

        // 更新已核定总额
        for (DynamicObject bizdatabill : bizdatabills) {
            Long billId = bizdatabill.getLong("id");
            List<DynamicObject> bonusCheckList = bonusCheckGroup.get(String.valueOf(billId));
            if (bonusCheckList == null){
                throw new KDBizException("数据异常，计划对应的核定信息不存在。");
            }
            // 核定总额
            BigDecimal aApprovalTotalAmount = bonusCheckList.stream().map(item -> item.getBigDecimal("${ISV_FLAG}_approval_total")).reduce(BigDecimal.ZERO, BigDecimal::add);
            // 已核定总额
            BigDecimal amount = bizdatabill.getBigDecimal("${ISV_FLAG}_app_total_amount") != null ? bizdatabill.getBigDecimal("${ISV_FLAG}_app_total_amount") : BigDecimal.ZERO;
            BigDecimal checkAmount = aApprovalTotalAmount.add(amount);
            bizdatabill.set("${ISV_FLAG}_app_total_amount", checkAmount);
            // 计划总额
            BigDecimal planMoney = bizdatabill.getBigDecimal("${ISV_FLAG}_plan_money");
            // 剩余总额
            BigDecimal suplyToalAmount = bizdatabill.getBigDecimal("${ISV_FLAG}_sur_total_amonut");
            // 是否超额
            if (checkAmount.compareTo(planMoney) > 0){
                bizdatabill.set("${ISV_FLAG}_over","1");
                bizdatabill.set("${ISV_FLAG}_sur_total_amonut",suplyToalAmount.subtract(aApprovalTotalAmount));
            }else {
                bizdatabill.set("${ISV_FLAG}_sur_total_amonut",suplyToalAmount.subtract(aApprovalTotalAmount));
            }
        }
        SaveServiceHelper.save(bizdatabills);
    }

    /**
     * 通过hr人员对象获取bosuser
     * @param subordinate
     */
    public static DynamicObject getBosUser(DynamicObject subordinate){
        String hrNumber = subordinate.getString("empnumber");
        QFilter bosUserQFilter = new QFilter("number", QCP.equals, hrNumber);
        DynamicObject bosUser = BusinessDataServiceHelper.loadSingle("bos_user", bosUserQFilter.toArray());
