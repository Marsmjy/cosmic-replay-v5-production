    }

    /**
     * 设置分配汇总单上级单据信息-核定单
     * @param distributeSumDynamicObject 分配汇总单
     * @param bill 上级单据-核定单
     */
    public static void setParentFromHd(DynamicObject distributeSumDynamicObject,DynamicObject bill){
        // 上级单据类型
        distributeSumDynamicObject.set("${ISV_FLAG}_parent_bill_type", BonusApprovalSheetBillSecondPushPlugin.TYPE_HE_DING);
        // 上级单据编号
        distributeSumDynamicObject.set("${ISV_FLAG}_parent_bill_no", bill.get("billno"));
        // 上级单据名称
        distributeSumDynamicObject.set("${ISV_FLAG}_parent_bill_name", bill.get("${ISV_FLAG}_approval_name"));
        // 上级创建人
        distributeSumDynamicObject.set("${ISV_FLAG}_pt_creator", bill.get("${ISV_FLAG}_dept_person"));
        // 上级创建人 公司
        distributeSumDynamicObject.set("${ISV_FLAG}_pt_company", bill.get("${ISV_FLAG}_attribut_company"));
        // 上级创建人 部门
        distributeSumDynamicObject.set("${ISV_FLAG}_pt_dept", bill.get("${ISV_FLAG}_attribut_dept"));
        // 上级创建人 岗位
        distributeSumDynamicObject.set("${ISV_FLAG}_pt_post", bill.get("${ISV_FLAG}_attribut_post"));
    }


    /**
     * 获取部门负责人 ids
     * @param adminOrgId 部门id
     * @return 部门负责人ids
     */
    public static List<Long> listOrgDutyPersonIds(long adminOrgId){
        DynamicObject[] chargepeople = getChargepeople(adminOrgId);
        // 根据生效日期逆序
        List<DynamicObject> chargepeopleList = Arrays.stream(chargepeople).sorted((o1, o2) -> o2.getDate("effdt").compareTo(o1.getDate("effdt"))).collect(Collectors.toList());
        // 部门负责人ids
        List<Long> dutyPersonIds = chargepeopleList.stream().map(item ->
                        item.getLong("chargeperson.person.id")
                ).collect(Collectors.toList());
        return dutyPersonIds;
    }

    private static DynamicObject[] getChargepeople(long adminOrgId) {
        //查询所有的部门负责人
        QFilter filter = new QFilter("datastatus",QCP.equals,"1");
        // 组织id
        filter.and(new QFilter("adminorg.id",QCP.equals, adminOrgId));
        // 是否主要负责人
        filter.and(new QFilter("ismain",QCP.equals,"1"));
        return getChargepeople(filter);
    }

    private static DynamicObject[] getChargepeople(QFilter filter) {
        return BusinessDataServiceHelper.load("hrpi_chargeperson",
                "id,chargeperson,chargeperson.person,adminorg,effdt"
                , filter.toArray());
    }

