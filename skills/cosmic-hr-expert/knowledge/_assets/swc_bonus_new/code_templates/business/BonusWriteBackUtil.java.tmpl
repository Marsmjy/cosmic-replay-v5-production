    /**
     *
     * @param dataEntity 实体
     * @param entryKey 分录key
     * @param propertyName 列对象key
     * @param numberKey 属性key
     * @param entryName 分录名称
     * @return
     */
    public static List<String> checkPsRelationCommon(DynamicObject dataEntity,String entryKey,String propertyName,String numberKey,String entryName){
        List<String> msgList = new ArrayList<>();
        DynamicObjectCollection orgCollection = dataEntity.getDynamicObjectCollection(entryKey);
        // 假定第一层循环均是父级，第二层循环均是子级
        for(int i = 0; i<orgCollection.size(); i++){
            // 长编码
            String structLongNumberI = orgCollection.get(i).getDynamicObject(propertyName).getString(numberKey);
            for(int j = 0; j<orgCollection.size(); j++){
                String structLongNumberJ = orgCollection.get(j).getDynamicObject(propertyName).getString(numberKey);
                if((i != j) && structLongNumberJ.startsWith(structLongNumberI)){
                    if("${ISV_FLAG}_award_sure_org".equals(entryKey)){
                        // 核定到组织分录控制调整：原为不允许存在上下级关系，
                        // 调整为：若存在上下级关系的分录“行政组织类型归属”均等于“公司”时，对应分录行不做控制，其他分录行正常校验
                        // 行政组织类型归属
                        String belongNumber = orgCollection.get(j).getDynamicObject(propertyName)
                                .getString("adminorgtype.number");
                        // 行政类型归属为公司
                        if("1020_S".equals(belongNumber)){
                            continue;
                        }
                    }
                    msgList.add(String.format("%s:%s行和%s行组织存在归属关系，请修改",entryName,(i + 1),(j + 1)));
                }
            }
        }
        return msgList;
    }

    /**
     *
     * @param dataEntity 实体
     * @param entryKey 分录key
     * @param propertyName 列对象key
     * @param numberKey 属性key
     * @param entryName 分录名称
     * @return
     */
    public static List<String> checkPsRelationCommonExt(DynamicObject dataEntity,String entryKey,String propertyName,String numberKey,String entryName){
        List<String> msgList = new ArrayList<>();
        DynamicObjectCollection orgCollection = dataEntity.getDynamicObjectCollection(entryKey);
        // 假定第一层循环均是父级，第二层循环均是子级
        for(int i = 0; i<orgCollection.size(); i++){
            // 长编码
            String structLongNumberI = orgCollection.get(i).getDynamicObject(propertyName).getString(numberKey);
            for(int j = 0; j<orgCollection.size(); j++){
                String structLongNumberJ = orgCollection.get(j).getDynamicObject(propertyName).getString(numberKey);
                // 排除重复组织的比较，即允许分录中重复组织的出现
                if((i != j) && structLongNumberJ.startsWith(structLongNumberI) && !structLongNumberJ.equals(structLongNumberI)){
                    msgList.add(String.format("%s:%s行和%s行组织存在归属关系，请修改",entryName,(i + 1),(j + 1)));
                }
            }
        }
        return msgList;
    }

    /**
     * 设置分配汇总单单据名称
     * @param distributeSumDynamicObject
     */
    public static void setSumBillName(DynamicObject distributeSumDynamicObject){
        Date belongPeriodDate = distributeSumDynamicObject.getDate("${ISV_FLAG}_belong_period");
        String billname = null;
        if (belongPeriodDate != null) {
            billname =  new SimpleDateFormat("yyyy-MM").format(belongPeriodDate);
        }
        String orgName = distributeSumDynamicObject.getString("${ISV_FLAG}_distribute_org.name");
        billname = billname + orgName;
        billname = billname + distributeSumDynamicObject.getString("${ISV_FLAG}_bonus_item.name");
        distributeSumDynamicObject.set("${ISV_FLAG}_bill_name",billname);
    }

    /**
     * 设置分配单的名称
     * @param distributeSumDynamicObject
     */
    public static void setDistributeBillName(DynamicObject distributeSumDynamicObject){
        Date belongPeriodDate = distributeSumDynamicObject.getDate("${ISV_FLAG}_belong_period");
        String billname = null;
        if (belongPeriodDate != null) {
            billname =  new SimpleDateFormat("yyyy-MM").format(belongPeriodDate);
        }
        String orgName = distributeSumDynamicObject.getString("${ISV_FLAG}_distribute_org.name");
        billname = billname + orgName;
        billname = billname + distributeSumDynamicObject.getString("${ISV_FLAG}_bonus_item.name")+"分配申请";
