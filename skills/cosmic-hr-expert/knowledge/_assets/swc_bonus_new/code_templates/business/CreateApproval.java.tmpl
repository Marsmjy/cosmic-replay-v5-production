package ${ISV_FLAG}.swc.hsbm.biz.swc.plugin.form.${ISV_FLAG}_bonus_plan;

import kd.bos.bill.BillShowParameter;
import kd.bos.bill.OperationStatus;
import kd.bos.dataentity.entity.DynamicObject;
import kd.bos.dataentity.entity.DynamicObjectCollection;
import kd.bos.dataentity.utils.StringUtils;
import kd.bos.entity.datamodel.ListSelectedRowCollection;
import kd.bos.entity.datamodel.events.BeforePackageDataEvent;
import kd.bos.entity.operate.Donothing;
import kd.bos.entity.operate.result.OperationResult;
import kd.bos.form.ShowType;
import kd.bos.form.events.AfterDoOperationEventArgs;
import kd.bos.form.events.BeforeDoOperationEventArgs;
import kd.bos.form.events.HyperLinkClickArgs;
import kd.bos.form.events.SetFilterEvent;
import kd.bos.list.IListView;
import kd.bos.list.plugin.AbstractListPlugin;
import kd.bos.logging.Log;
import kd.bos.logging.LogFactory;
import kd.bos.orm.query.QCP;
import kd.bos.orm.query.QFilter;
import kd.bos.servicehelper.BusinessDataServiceHelper;
import kd.bos.servicehelper.QueryServiceHelper;

import java.util.ArrayList;
import java.util.Arrays;
import java.util.EventObject;
import java.util.HashMap;
import java.util.List;
import java.util.Map;
import java.util.Objects;
import java.util.Set;
import java.util.stream.Collectors;


/**
 * Author: 王博纶
 * Date: 2024/3/27 10:46
 * FileName: CreateApproval
 * Description: 创建核定按钮的逻辑
 */
public class CreateApproval extends AbstractListPlugin{

    private static final Log log = LogFactory.getLog(CreateApproval.class);

    @Override
    public void registerListener(EventObject e) {
        this.addItemClickListeners("${ISV_FLAG}_baritemap,${ISV_FLAG}_abandoned");
    }

    @Override
    public void setFilter(SetFilterEvent e) {
        // 奖金计划汇总单审批状态的过滤
        super.setFilter(e);
        List<QFilter> qFilters = e.getQFilters();

        List<String> billStatus = new ArrayList<>();

        for (QFilter qFilter : qFilters) {
            if (Objects.isNull(qFilter)) {
                continue;
            }
            String property = qFilter.getProperty();
            if ("${ISV_FLAG}_check_summary_status".equals(property)) {
                Object filterValue = qFilter.getValue();
                List<String> value = new ArrayList<>();
                if (filterValue instanceof String){
                    value.add((String)filterValue);
                }else if (filterValue instanceof List){
                    value = (ArrayList<String>) qFilter.getValue();
                }
                billStatus.addAll(value);
            }
        }
        Map<String, DynamicObject> map = new HashMap<>();
        QFilter filter2 = new QFilter("billstatus", QCP.in, billStatus);
        DynamicObjectCollection bonusPlanApprovalObjects = QueryServiceHelper.query("${ISV_FLAG}_bonus_plan_approval", "id,billno,billstatus", filter2.toArray());
        for (DynamicObject bonusPlanApprovalObject : bonusPlanApprovalObjects) {
            map.put(bonusPlanApprovalObject.getString("billstatus"),bonusPlanApprovalObject);
        }

        for (int i = 0; i < qFilters.size(); i++) {
            if (Objects.isNull(qFilters.get(i))) {
                continue;
            }
            String property = qFilters.get(i).getProperty();
            if ("${ISV_FLAG}_plan_summary_status".equals(property)) {
                Object filterValue = qFilters.get(i).getValue();
                List<String> value = new ArrayList<>();
                if (filterValue instanceof String){
                    value.add((String)filterValue);
                }else if (filterValue instanceof List){
                    value = (ArrayList<String>) qFilters.get(i).getValue();
                }
                if (value.size() > 0) {
                    // 查询奖金分配汇总单
                    List<DynamicObject> bonusPlanApproval = new ArrayList<>();
                    for (String key : value) {
                        bonusPlanApproval.add(map.get(key));
                    }
                    Set<String> bonusPlanApprovalIds = bonusPlanApproval.stream().map(item -> String.valueOf(item.getLong("id"))).collect(Collectors.toSet());
                    qFilters.set(i,new QFilter("${ISV_FLAG}_plan_summary", QCP.in, bonusPlanApprovalIds));
                }
            }
        }
    }

    @Override
    public void beforeDoOperation(BeforeDoOperationEventArgs args) {
        Object source = args.getSource();
        if(source instanceof Donothing){
            // 获取当前空操作的名称
            String operationKey = ((Donothing)source).getOperateKey();
            // 判断是否是创建核定的按钮
            ListSelectedRowCollection listSelectedData = args.getListSelectedData();
            if("donothing_create_approval".equalsIgnoreCase(operationKey)){
                // 取消后续事件的操作
                args.setCancel(true);
                if(listSelectedData.size() > 1){
                    this.getView().showTipNotification("不允许选择多个计划创建核定单");
                    return;
                }
                // 获取对应计划单
                Object billPkId = listSelectedData.get(0).getPrimaryKeyValue();
                String selectField = "id,billstatus,${ISV_FLAG}_plan_name,${ISV_FLAG}_plan_summary,${ISV_FLAG}_plan_status";
                DynamicObject bonusPlan = BusinessDataServiceHelper.loadSingleFromCache(billPkId, "${ISV_FLAG}_bonus_plan", selectField);
                String billstatus = bonusPlan.getString("billstatus");
                String planSummary = bonusPlan.getString("${ISV_FLAG}_plan_summary");

                // 计划状态
                String planStatus = bonusPlan.getString("${ISV_FLAG}_plan_status");
                if(!"1".equals(planStatus)){
                    this.getView().showTipNotification("请勾选生效中的计划单。");
                    return;
                }

                //查询审批通过的汇总单id
                QFilter bonusPlanApprovalFilter = new QFilter("billstatus", QCP.equals, "C");
                DynamicObjectCollection bonusPlanApproval = QueryServiceHelper.query("${ISV_FLAG}_bonus_plan_approval", "id", bonusPlanApprovalFilter.toArray());
                Set<String> bonusPlanApprovalIds = bonusPlanApproval.stream().map(item -> String.valueOf(item.getLong("id"))).collect(Collectors.toSet());

                // 只有已审核，并且进行了汇总审批的单据才能进行核定
                if ("C".equals(billstatus) && bonusPlanApprovalIds.contains(planSummary)){
                    openBonusApprovedFrom(bonusPlan);
                }else {
                    this.getView().showTipNotification("请勾选已审核并且汇总审批通过的计划单。");
                }
            }
        }
    }

    @Override
    public void afterDoOperation(AfterDoOperationEventArgs args) {
        String operateKey = args.getOperateKey();
        if ("donothing_push_check".equals(operateKey) || "donothing_fail_invalid_plan".equals(operateKey)){
            this.getView().invokeOperation("refresh");
        }

        // 生成审批完成后，跳转到审批单界面
        if ("donothing_push_check".equals(operateKey)){
            OperationResult operationResult = args.getOperationResult();
            if (operationResult.isSuccess()){
                List<Object> successPkIds = operationResult.getSuccessPkIds();
                DynamicObject bill = BusinessDataServiceHelper.loadSingle("${ISV_FLAG}_bonus_plan", new QFilter[]{new QFilter("id", QCP.in,successPkIds)});
                showBonusPlanApproval(bill);
            }
        }
    }

    /**
     * 打开奖金核定单的页面
     * @param bonusPlan 奖金计划DynamicObject
     */
    private void openBonusApprovedFrom(DynamicObject bonusPlan) {
        // 放入参数奖金计划id
        HashMap<String, Object> customMap = new HashMap<>();
        HashMap<String, Object> bonusVerMap = new HashMap<>();
        bonusVerMap.put("bonusPlanId", bonusPlan.getLong("id")); // 奖金计划单id
        customMap.put("customMap",bonusVerMap);

        // 打开奖金核定单页面
        BillShowParameter bonusVerForm = new BillShowParameter();
        bonusVerForm.setFormId("${ISV_FLAG}_bonus_approval_2nd"); // 奖金核定单的单据标识
        bonusVerForm.setStatus(OperationStatus.ADDNEW);
        bonusVerForm.setCustomParams(customMap);
        bonusVerForm.getOpenStyle().setShowType(ShowType.MainNewTabPage);
        this.getView().showForm(bonusVerForm);
    }

    public void billListHyperLinkClick(HyperLinkClickArgs args) {
        String fieldName = args.getFieldName();
        if (fieldName.equals("${ISV_FLAG}_plan_summary_status")) {
            args.setCancel(true);
            IListView listView = (IListView) this.getView();
            long pkId = (Long) listView.getFocusRowPkId();
            DynamicObject bill = BusinessDataServiceHelper.loadSingle("${ISV_FLAG}_bonus_plan", new QFilter[]{new QFilter("id", QCP.equals, pkId)});
            showBonusPlanApproval(bill);
        }
    }

    /**
     * 跳转到计划汇总审批界面
     */
    private void showBonusPlanApproval(DynamicObject bill) {
        if (bill != null){
            OperationStatus operationStatus = OperationStatus.EDIT;
            BillShowParameter formShowParameter = new BillShowParameter();
            formShowParameter.getOpenStyle().setShowType(ShowType.MainNewTabPage);
            formShowParameter.setStatus(operationStatus);
            formShowParameter.setFormId("${ISV_FLAG}_bonus_plan_approval");
            formShowParameter.setPkId(bill.getString("${ISV_FLAG}_plan_summary"));
            this.getView().showForm(formShowParameter);
        }
    }

    @Override
    public void beforePackageData(BeforePackageDataEvent e) {
        // 构建奖金汇总审批状态字段
        DynamicObjectCollection pageData = e.getPageData();

        Set<Long> planSummaryIds = pageData.stream().filter(item -> !StringUtils.isEmpty(item.getString("${ISV_FLAG}_plan_summary")))
                .map(item -> Long.valueOf(item.getString("${ISV_FLAG}_plan_summary"))).collect(Collectors.toSet());
        DynamicObject[] bonusPlanApprovalList = BusinessDataServiceHelper.load("${ISV_FLAG}_bonus_plan_approval", "id,billstatus", new QFilter[]{new QFilter("id",QCP.in,planSummaryIds)});
        Map<String, String> resourseMap = Arrays.stream(bonusPlanApprovalList).collect(Collectors.toMap(key -> String.valueOf(key.getLong("id")), value -> value.getString("billstatus")));
        for (DynamicObject bill: pageData) {
            String planSummaryId = bill.getString("${ISV_FLAG}_plan_summary");
            bill.set("${ISV_FLAG}_plan_summary_status",resourseMap.get(planSummaryId));
        }
    }

}
