    @Override
    public void beforeF7Select(BeforeF7SelectEvent beforeF7SelectEvent) {
        String fieldKey = beforeF7SelectEvent.getProperty().getName();
        if ("${ISV_FLAG}_pay_period".equals(fieldKey)){
            DynamicObject bill = this.getModel().getDataEntity();
            DynamicObject accountGroup = bill.getDynamicObject("${ISV_FLAG}_salary_ccount_group");
//            QFilter filter = new QFilter("payrollsceneentry.payrollscene.${ISV_FLAG}_sencetype",QCP.equals,"1"); // 只取工资计算
//            filter.and("id",QCP.equals,accountGroup.getLong("id"));
            QFilter filter = new QFilter("id", QCP.equals, accountGroup.getLong("id"));
            DynamicObjectCollection payrollgrpCollection = QueryServiceHelper.query("hsas_payrollgrp", "payrollsceneentry.payrollscene.periodtype.id", filter.toArray());
            if (!CollectionUtils.isEmpty(payrollgrpCollection)){
                // 查询薪资期间
                QFilter calperiodtypeFilter = new QFilter("id",QCP.equals, payrollgrpCollection.get(0).getLong("payrollsceneentry.payrollscene.periodtype.id"));
                DynamicObjectCollection calperiodtypeQuery = QueryServiceHelper.query("hsbs_calperiodtype", "id,entryentity.id", calperiodtypeFilter.toArray());
                List<Long> collectIds = calperiodtypeQuery.stream().map(item -> item.getLong("entryentity.id")).collect(Collectors.toList());

                // 构建过滤条件
                QFilter qFilter = new QFilter("id", QCP.in, collectIds);
                ListShowParameter formShowParameter = (ListShowParameter) beforeF7SelectEvent.getFormShowParameter();
                formShowParameter.getListFilterParameter().getQFilters().add(qFilter);
            }
        }
    }

