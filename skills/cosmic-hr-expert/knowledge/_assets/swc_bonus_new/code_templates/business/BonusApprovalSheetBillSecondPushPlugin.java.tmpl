    /**
     * 生成奖金分配单的分录（在核定单的组织分配明细中）
     */
    private void genDistributeEntry(DynamicObject distributeDynamicObject, List<DynamicObject> personDetailCollection, List<DynamicObject> retentionDetailCollection) {
        if (CollectionUtils.isNotEmpty(personDetailCollection)) {
            DynamicObjectCollection personDisEntryCollection = distributeDynamicObject.getDynamicObjectCollection("${ISV_FLAG}_person_dis_entry");
            personDetailCollection.forEach(entry -> {
                BigDecimal ruleDistributeDecimal = entry.getBigDecimal("${ISV_FLAG}_check_amount2");
                BigDecimal realDistributeDecimal = ruleDistributeDecimal;
                // 分配单上的人员占分配比置空
                BigDecimal distributeRatio = null;
                DynamicObject personEntry = personDisEntryCollection.addNew();
                personEntry.set("${ISV_FLAG}_peson", entry.getDynamicObject("${ISV_FLAG}_employee_name")); // 员工姓名
                personEntry.set("${ISV_FLAG}_peson_number", entry.getDynamicObject("${ISV_FLAG}_employee_name").getString("number")); // 员工姓名
                personEntry.set("${ISV_FLAG}_per_business_entity", entry.getDynamicObject("${ISV_FLAG}_per_business_entity")); // 所属经营主体
                personEntry.set("${ISV_FLAG}_per_admin_company", entry.getDynamicObject("${ISV_FLAG}_per_admin_company")); // 所属公司
                personEntry.set("${ISV_FLAG}_admin_dept", entry.getDynamicObject("${ISV_FLAG}_admin_dept")); // 所属部门
                personEntry.set("${ISV_FLAG}_admin_post", entry.getDynamicObject("${ISV_FLAG}_admin_post")); // 所属部门
                // personEntry.set("${ISV_FLAG}_rule_dis_decimal", ruleDistributeDecimal); // 按规则分配金额
                personEntry.set("${ISV_FLAG}_real_dis_decimal", realDistributeDecimal); // 实际分配金额
                personEntry.set("${ISV_FLAG}_dis_ratio", distributeRatio); // 分配占比
                personEntry.set("${ISV_FLAG}_undertake_org2", entry.getDynamicObject("${ISV_FLAG}_undertake_org2")); // 承担组织
                personEntry.set("${ISV_FLAG}_is_upper_dis", IS_UPPER_DISTRIBUTE); // 上级分配
                personEntry.set("${ISV_FLAG}_locked_staff", 1);//锁定标记
                personEntry.set("${ISV_FLAG}_employment_history",entry.getDynamicObject("${ISV_FLAG}_employment_history"));
            });
        }

        if (CollectionUtils.isNotEmpty(retentionDetailCollection)) {
            DynamicObjectCollection retentionEntryCollection = distributeDynamicObject.getDynamicObjectCollection("${ISV_FLAG}_retention_entry");
            retentionDetailCollection.forEach(entry -> {
                DynamicObject retentionEntry = retentionEntryCollection.addNew();
                retentionEntry.set("${ISV_FLAG}_admin_org_keep", entry.getDynamicObject("${ISV_FLAG}_admin_org_keep")); // 行政组织
                retentionEntry.set("${ISV_FLAG}_bs_entity_org", entry.getDynamicObject("${ISV_FLAG}_bs_entity_org")); // 所属经营主体
                retentionEntry.set("${ISV_FLAG}_keep_company", entry.getDynamicObject("${ISV_FLAG}_keep_company")); // 所属公司
                retentionEntry.set("${ISV_FLAG}_undertake_org3", entry.getDynamicObject("${ISV_FLAG}_undertake_org3")); // 承担组织
                retentionEntry.set("${ISV_FLAG}_retention_decimal", entry.getBigDecimal("${ISV_FLAG}_check_amount3")); // 留存金额
                retentionEntry.set("${ISV_FLAG}_is_upper", IS_UPPER_DISTRIBUTE); // 上级分配
                retentionEntry.set("${ISV_FLAG}_locked_dept", 1);//锁定标记
            });
        }
    }

    /**
     * 生成分配汇总单
     *
     * @param entities    核定单的对象
     * @param currentTime 按钮点击执行的时间
     * @param bosUser     当前操作人用户
     * @return 准备生成的分配汇总的数组
     */
    private DynamicObject[] createDistributeSumBill(DynamicObject[] entities, Date currentTime, DynamicObject bosUser, Map<String, String> orgDisNoMap) {
        return Arrays.stream(entities).map(bill -> {
            // 生成奖金分配汇总单（在核定单的组织分配明细中）
            List<DynamicObject> collect = genDistributeSumByDeptDetail(currentTime, bill, bosUser, orgDisNoMap);
            // 生成奖金分配汇总单（不在核定单的组织分配明细中）
            collect.addAll(genDistributeSumByPersonDetail(currentTime, bill, bosUser));
            return collect;
        }).flatMap(List::stream).toArray(DynamicObject[]::new);
    }

    /**
     * 生成奖金分配汇总单（不在核定单的组织分配明细中）
     */
    private static List<DynamicObject> genDistributeSumByPersonDetail(Date currentTime, DynamicObject bill, DynamicObject bosUser) {
        DynamicObject distributeSumDynamicObject = null;
        DynamicObjectCollection awardSureOrgCollection = bill.getDynamicObjectCollection("${ISV_FLAG}_award_sure_org"); // 组织核定明细
        DynamicObjectCollection awardSureStaffCollection = bill.getDynamicObjectCollection("${ISV_FLAG}_award_sure_staff"); // 人员核定明细
        DynamicObjectCollection awardSureKeepCollection = bill.getDynamicObjectCollection("${ISV_FLAG}_award_keep_org"); // 留存部门明细
        // 获取[奖金核定单]的[组织核定明细]分录和[人员核定明细]分录的行政组织的长编码集合
        Set<String> deptOrgLongNumberSet = awardSureOrgCollection.stream().map(number -> number.getString("${ISV_FLAG}_admin_org.structlongnumber")).collect(Collectors.toSet());
        // 初始化【人员分配明细】和【部门留用明细】
        Set<DynamicObject> personDetailCollection = new HashSet<>();
        Set<DynamicObject> retentionDetailCollection = new HashSet<>();
        if (CollectionUtils.isNotEmpty(deptOrgLongNumberSet)) {
            // 1.遍历人员核定明细，判断是否存在不在组织核定中的数据
            // 2.遍历留存部门明细，判断是否存在不在组织核定中的数据
            if (CollectionUtils.isNotEmpty(awardSureStaffCollection)) {
                for (DynamicObject staff : awardSureStaffCollection) {
                    String deptPath = staff.getString("${ISV_FLAG}_admin_dept.structlongnumber");
                    int count = 0;
                    for (String longNumber : deptOrgLongNumberSet) {
                        if (deptPath.contains(longNumber)) {
                            count++;
                        }
                    }
                    if (count == 0) {
                        personDetailCollection.add(staff);
                    }
                }
            }
            if (CollectionUtils.isNotEmpty(awardSureKeepCollection)) {
                for (DynamicObject keep : awardSureKeepCollection) {
                    String deptPath = keep.getString("${ISV_FLAG}_admin_org_keep.structlongnumber");
                    int count = 0;
                    for (String longNumber : deptOrgLongNumberSet) {
                        if (deptPath.contains(longNumber)) {
                            count++;
                        }
                    }
                    if (count == 0) {
                        retentionDetailCollection.add(keep);
                    }
                }
            }

        } else {
            // 不存在【组织很顶明细】直接将【人员核定明细】和【留存部门经费】分录添加到集合中去
            personDetailCollection.addAll(awardSureStaffCollection);
            retentionDetailCollection.addAll(awardSureKeepCollection);
        }


        // 判断上面的两个set集合是否有值，存在值的话就需要单独生成一个【奖金分配汇总单】
        if (CollectionUtils.isNotEmpty(personDetailCollection) || CollectionUtils.isNotEmpty(retentionDetailCollection)) {
            distributeSumDynamicObject = BusinessDataServiceHelper.newDynamicObject(BonusUtil.DISTRIBUTE_SUM_BILL_FORM_ID);
            // 系统隐藏信息
            setSystemHiddenInfo(currentTime, bill, bosUser, distributeSumDynamicObject);
            // 基本信息
            setBaseInfo(bill, distributeSumDynamicObject);
            distributeSumDynamicObject.set("${ISV_FLAG}_distribute_org", bill.getDynamicObject("${ISV_FLAG}_belong_to_org")); // 分配组织
            // 生成奖金分配汇总单的分录数据
            genDistributeSumEntryByPersonEntry(bill, distributeSumDynamicObject, personDetailCollection, retentionDetailCollection);
            // 设置分配统计
            setDistributeStatistics(distributeSumDynamicObject);
            // “单据状态”为“无需处理”，“审批状态”为“无需处理”，无法生成审批单。
            distributeSumDynamicObject.set("auditstatus", "K");
            distributeSumDynamicObject.set("${ISV_FLAG}_approval_status", "K");
            distributeSumDynamicObject.set("billstatus", "K");
            // 设置创建人信息
            setCreatorDefaultSum(distributeSumDynamicObject);
            // 设置分配汇总单单据名称
            BonusWriteBackUtil.setSumBillName(distributeSumDynamicObject);
            // 设置分配汇总单上级单据信息-核定单
            BonusWriteBackUtil.setParentFromHd(distributeSumDynamicObject,bill);
        }
        return ObjectUtils.isEmpty(distributeSumDynamicObject) ? Collections.emptyList() : Collections.singletonList(distributeSumDynamicObject);
    }

    /**
     * 生成奖金分配汇总单（在核定单的组织分配明细中）
     */
    @NotNull
    private static List<DynamicObject> genDistributeSumByDeptDetail(Date currentTime, DynamicObject bill, DynamicObject bosUser, Map<String, String> orgDisNoMap) {
        DynamicObjectCollection awardSureOrgCollection = bill.getDynamicObjectCollection("${ISV_FLAG}_award_sure_org"); // 组织核定明细
        DynamicObjectCollection awardSureStaffCollection = bill.getDynamicObjectCollection("${ISV_FLAG}_award_sure_staff"); // 人员核定明细
        DynamicObjectCollection awardSureKeepCollection = bill.getDynamicObjectCollection("${ISV_FLAG}_award_keep_org"); // 留存部门明细
        DynamicObjectCollection awardSurePoolCollection = bill.getDynamicObjectCollection("${ISV_FLAG}_award_keep_pool"); // 留存奖金池

        return awardSureOrgCollection.stream().map(entry -> {
            // 获取到【组织核定明细】的行政组织的长编码
            String deptDetailOrgLongNumber = entry.getString("${ISV_FLAG}_admin_org.structlongnumber");
            BigDecimal orgMoneyTotal = entry.getBigDecimal("${ISV_FLAG}_check_amount");
            DynamicObject distributeSumDynamicObject = BusinessDataServiceHelper.newDynamicObject(BonusUtil.DISTRIBUTE_SUM_BILL_FORM_ID);
            // 设置系统隐藏信息
            setSystemHiddenInfo(currentTime, bill, bosUser, distributeSumDynamicObject);
            // 基本信息
            setBaseInfo(bill, distributeSumDynamicObject);
            distributeSumDynamicObject.set("${ISV_FLAG}_distribute_org", entry.getDynamicObject("${ISV_FLAG}_admin_org")); // 分配组织
            // 获取[奖金核定单]的[组织核定明细]分录和[人员核定明细]分录的行政组织的长编码集合
            List<DynamicObject> personDetailCollection = awardSureStaffCollection.stream().filter(number -> number.getString("${ISV_FLAG}_admin_dept.structlongnumber").contains(deptDetailOrgLongNumber)).collect(Collectors.toList());
            List<DynamicObject> retentionDetailCollection = awardSureKeepCollection.stream().filter(number -> number.getString("${ISV_FLAG}_admin_org_keep.structlongnumber").contains(deptDetailOrgLongNumber)).collect(Collectors.toList());
            // 生成奖金分配汇总单的分录数据
            genDistributeSumEntry(bill, distributeSumDynamicObject, personDetailCollection, retentionDetailCollection, orgMoneyTotal);
            // 设置分配统计
            setDistributeStatistics(distributeSumDynamicObject);
            orgDisNoMap.put(deptDetailOrgLongNumber, distributeSumDynamicObject.getString("billno"));
            // 设置创建人信息
            setCreatorDefaultSum(distributeSumDynamicObject);
            // 设置分配汇总单单据名称
            BonusWriteBackUtil.setSumBillName(distributeSumDynamicObject);
            // 设置分配汇总单上级单据信息-核定单
            BonusWriteBackUtil.setParentFromHd(distributeSumDynamicObject,bill);
            return distributeSumDynamicObject;
        }).collect(Collectors.toList());
    }

    /**
     * 生成奖金分配汇总单的分录（在核定单的组织分配明细中）
     */
    private static void genDistributeSumEntry(DynamicObject bill, DynamicObject distributeSumDynamicObject, List<DynamicObject> personDetailCollection, List<DynamicObject> retentionDetailCollection, BigDecimal orgMoneyTotal) {
        DynamicObjectCollection personDistributeDetailCollection = distributeSumDynamicObject.getDynamicObjectCollection("${ISV_FLAG}_person_dis_detail");
        DynamicObjectCollection deptRetentionDetailCollection = distributeSumDynamicObject.getDynamicObjectCollection("${ISV_FLAG}_dept_retentiion_deta");
        // 人员明细存在符合的数据
        if (CollectionUtils.isNotEmpty(personDetailCollection)) {
            personDetailCollection.forEach(entry -> {
                DynamicObject personDistributeDetail = personDistributeDetailCollection.addNew();
                // 构造分录赋值需要的key和value
                Map<String, String> basePropMap = new HashMap<>();
                basePropMap.put("${ISV_FLAG}_dept_person", "${ISV_FLAG}_employee_name");
                basePropMap.put("${ISV_FLAG}_employment_history", "${ISV_FLAG}_employment_history");
                personDistributeDetail.set("${ISV_FLAG}_peson_number", entry.getDynamicObject("${ISV_FLAG}_employee_name").getString("number"));
                basePropMap.put("${ISV_FLAG}_business_company", "${ISV_FLAG}_per_business_entity");
                basePropMap.put("${ISV_FLAG}_per_admin_company", "${ISV_FLAG}_per_admin_company");
                basePropMap.put("${ISV_FLAG}_admin_dept", "${ISV_FLAG}_admin_dept");
                basePropMap.put("${ISV_FLAG}_admin_post", "${ISV_FLAG}_admin_post");
                basePropMap.put("${ISV_FLAG}_dis_total_person", "${ISV_FLAG}_check_amount2");
                basePropMap.put("${ISV_FLAG}_undertake_organizati", "${ISV_FLAG}_undertake_org2");
                basePropMap.put("${ISV_FLAG}_warn_remark_person", "${ISV_FLAG}_ry_hdyj");
                basePropMap.put("${ISV_FLAG}_remark_person", "${ISV_FLAG}_per_remark");
                // 设置公共属性字段的值
                setPersonEntryBaseProp(bill, entry, personDistributeDetail, basePropMap);
            });
        }

        // 部门留用明细存在符合的数据
        if (CollectionUtils.isNotEmpty(retentionDetailCollection)) {
            retentionDetailCollection.forEach(entry -> {
                DynamicObject deptRetentionDetail = deptRetentionDetailCollection.addNew();
                BigDecimal distributeDecimal = entry.getBigDecimal("${ISV_FLAG}_check_amount3");
                // 设置公共属性字段的值
                setRetentionEntryBaseProp(bill, entry, deptRetentionDetail, distributeDecimal);
            });
        }
        BigDecimal personEntryDecimalTotal = personDistributeDetailCollection.stream().map(decimal -> decimal.getBigDecimal("${ISV_FLAG}_dis_total_person")).reduce(BigDecimal.ZERO, BigDecimal::add);
        BigDecimal retentionEntryDecimalTotal = deptRetentionDetailCollection.stream().map(decimal -> decimal.getBigDecimal("${ISV_FLAG}_retention_total_dept")).reduce(BigDecimal.ZERO, BigDecimal::add);
        // 设置单据头的【可分配总额】字段
        distributeSumDynamicObject.set("${ISV_FLAG}_enable_distribute_tl", orgMoneyTotal); // 可分配总额（元）
        BigDecimal enableDistributeTotal = orgMoneyTotal.add(personEntryDecimalTotal).add(retentionEntryDecimalTotal);
        // 总额
        distributeSumDynamicObject.set("${ISV_FLAG}_money_total", enableDistributeTotal); // 奖金总额（元）

        // 重新设置两个单据提上的【分配占比】
        personDistributeDetailCollection.forEach(decimal -> decimal.set("${ISV_FLAG}_dis_ratio_person", decimal.getBigDecimal("${ISV_FLAG}_dis_total_person").divide(enableDistributeTotal, 4, RoundingMode.HALF_UP)));
        deptRetentionDetailCollection.forEach(decimal -> decimal.set("${ISV_FLAG}_dis_ratio_dept", decimal.getBigDecimal("${ISV_FLAG}_retention_total_dept").divide(enableDistributeTotal, 4, RoundingMode.HALF_UP)));
    }

    /**
     * 生成奖金分配汇总单的分录（不在核定单的组织分配明细中）
