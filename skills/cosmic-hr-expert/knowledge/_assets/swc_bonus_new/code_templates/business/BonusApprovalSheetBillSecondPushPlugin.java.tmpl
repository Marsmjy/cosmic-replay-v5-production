/**
 * 奖金核定-操作插件————该插件作用与奖金核定详情——${ISV_FLAG}_bonus_approval_2nd
 */
public class BonusApprovalSheetBillSecondPushPlugin extends AbstractOperationServicePlugIn {
    private static final Log logger = LogFactory.getLog(BonusApprovalSheetBillSecondPushPlugin.class);
    private static final String BTN_GEN_DIS_AND_DIS_SUM = "donothing_gen"; // 生成【分配单】和【分配汇总单】和【奖金发放】
    private static final String BTN_AUDIT = "audit"; // 审核按钮

    public static final String TYPE_HE_DING = "A"; // 单据类型为"核定单"
    public static final String TYPE_FEN_PEI = "B"; // 单据类型为"分配单"
    private static final String IS_UPPER_DISTRIBUTE = "1"; // 是上级分配
    private static final String NOT_UPPER_DISTRIBUTE = "0"; // 不是上级分配

    @Override
    public void onPreparePropertys(PreparePropertysEventArgs e) {
        try {
            List<String> fieldKeys = e.getFieldKeys();
            String name = this.billEntityType.getName();
            Map<String, IDataEntityProperty> fieldMap = EntityMetadataCache.getDataEntityType(name).getAllFields();
            Set<String> keyNumbers = fieldMap.keySet();
            fieldKeys.addAll(keyNumbers);
        } catch (Exception ex) {
            throw new RuntimeException("onPrepareProperties all filed fail", ex);
        }
    }

    @Override
    public void onAddValidators(AddValidatorsEventArgs e) {
        super.onAddValidators(e);
        e.addValidator(new BonusApprovalSecValidator());
    }

    @Override
    public void beginOperationTransaction(BeginOperationTransactionArgs e) {
        DynamicObject[] entities = e.getDataEntities();
        String operationKey = e.getOperationKey();
        if ("donothing_push_check".equals(operationKey)) {
            List<ListSelectedRow> rows = new ArrayList<>();
            for (DynamicObject bill : entities) {
                ListSelectedRow row = new ListSelectedRow();
                row.setPrimaryKeyValue(bill.getLong("id"));
                rows.add(row);
            }
            try {
                PushResult pushResult = BotpUtils.push(false, "${ISV_FLAG}_bonus_approval_2nd", "${ISV_FLAG}_bonus_approval_flow", rows, "2373964054609038336");
                // 下推是否成功
                if (pushResult.isSuccess()) {
                    // 收集计划汇总审批单id
                    HashMap<Long, Long> resourseMap = new HashMap<>();
                    DynamicObject[] dataPacks = pushResult.getDatapacks();
                    for (DynamicObject dataPack : dataPacks) {
                        Long bonusPlanApprovalId = dataPack.getLong("id");
                        DynamicObjectCollection tdkwEntryPlanDetail = dataPack.getDynamicObjectCollection("${ISV_FLAG}_hd_details");
                        Set<Long> srcbillIds = tdkwEntryPlanDetail.stream().map(item -> Long.valueOf(item.getString("${ISV_FLAG}_billid"))).collect(Collectors.toSet());
                        srcbillIds.forEach(srcbillId -> resourseMap.put(srcbillId, bonusPlanApprovalId));
                        // 保存数据
                        OperateChain.of(dataPack).save().failThenDeleteAndThrow();
                    }
                    for (DynamicObject bill : entities) {
                        bill.set("${ISV_FLAG}_check_summary", resourseMap.get(bill.getLong("id")));
                    }
                } else {
                    String errMsg = pushResult.getErrMsg();
                    throw new KDBizException("生成汇总审批失败。" + errMsg);
                }
                SaveServiceHelper.update(entities);
            } catch (Exception ex) {
                throw new KDBizException(ex.getMessage());
            }
        }

        // 审核按钮 --- 审批通过后生成【分配单】和【分配汇总单】的逻辑
        else if (BTN_GEN_DIS_AND_DIS_SUM.equals(operationKey)) {
            logger.info("start.payment");
            Date currentTime = Calendar.getInstance().getTime();
            DynamicObject bosUser = BusinessDataServiceHelper.loadSingle(RequestContext.get().getCurrUserId(), "bos_user");
            // 组织长编码作为key  分配汇总单编号作为value
            Map<String, String> orgDisNoMap = new HashMap<>();

            // 判断那些需要生成分配单，那些直接生成奖金发放数据
            ArrayList<DynamicObject> paymentDynamicObjects = new ArrayList<>();
            ArrayList<DynamicObject> distributeDynamicObjects = new ArrayList<>();
            Arrays.stream(entities).forEach(item -> {
                // 组织核定明细
                DynamicObjectCollection awardSureOrg = item.getDynamicObjectCollection("${ISV_FLAG}_award_sure_org");
                if (CollectionUtils.isEmpty(awardSureOrg)) {
                    // 直接生成奖金发放数据
                    paymentDynamicObjects.add(item);
                } else {
                    // 生成分配数据
                    distributeDynamicObjects.add(item);
                }
            });


            // 1.生成分配汇总的逻辑
            DynamicObject[] distributeSumBills = createDistributeSumBill(distributeDynamicObjects.toArray(new DynamicObject[0]), currentTime, bosUser, orgDisNoMap);
            // 2.生成分配单的逻辑
            DynamicObject[] distributeBills = createDistributeBill(distributeDynamicObjects.toArray(new DynamicObject[0]), currentTime, bosUser, orgDisNoMap);
            logger.info("ready create distribute_sum info :{}", (Object) distributeSumBills);
            logger.info("ready create distribute info :{}", (Object) distributeBills);
            // 3.生成奖金发放数据
            List<DynamicObject> bonusPayments = creatBounsPayments(paymentDynamicObjects.toArray(new DynamicObject[0]));
            // 4.生成部门经费数据
            List<DynamicObject> departmentFunds = creatDepartmentFunds(paymentDynamicObjects.toArray(new DynamicObject[0]));

            // 生成分配汇总单、分配单
            if (distributeDynamicObjects.size() > 0) {
                Object[] distributeSumBillsSaveResult = BonusUtil.saveBill(distributeSumBills);
                Object[] distributeBillsSaveResult = BonusUtil.saveBill(distributeBills);
                logger.info("batch save distribute_sum result:{}", distributeSumBillsSaveResult);
                logger.info("batch save distribute result:{}", distributeBillsSaveResult);
                List<Long> ids = Arrays.stream(distributeBills).map(s -> s.getLong("id")).collect(Collectors.toList());
                // 跳过权限
                OperateOption operateOption = OperateOption.create();
                operateOption.setVariableValue(OperateOptionConst.ISHASRIGHT, String.valueOf(true));
                operateOption.setVariableValue(OperateOptionConst.SKIPCHECKPERMISSION, String.valueOf(true));
                OperationResult saveResult = OperationServiceHelper.executeOperate("submit", "${ISV_FLAG}_bonus_dis_detail", ids.toArray(), operateOption);
                logger.info("batch save distribute result:{}", saveResult);
            }

            // 5.无需处理的分配汇总单，生成奖金发放，部门经费数据
            List<DynamicObject> unprocessedData = Arrays.stream(distributeSumBills)
                    .filter(item -> "K".equals(item.getString("auditstatus")) && "K".equals(item.getString("${ISV_FLAG}_approval_status")) && "K".equals(item.getString("billstatus"))).collect(Collectors.toList());
            if (unprocessedData.size() > 0){
                // 奖金发放
                BonusSumApprovalOperatePlugin bonusSumApprovalOperatePlugin = new BonusSumApprovalOperatePlugin();
                bonusPayments.addAll(bonusSumApprovalOperatePlugin.creatBounsPayments(unprocessedData.toArray(new DynamicObject[0]),"isChecked"));
                // 部门经费
                departmentFunds.addAll(bonusSumApprovalOperatePlugin.creatDepartmentFunds(unprocessedData.toArray(new DynamicObject[0]),"isChecked"));
            }

            // 生成奖金发放，部门经费
            // 跳过权限
            OperateOption operateOption = OperateOption.create();
            operateOption.setVariableValue(OperateOptionConst.ISHASRIGHT, String.valueOf(true));
            operateOption.setVariableValue(OperateOptionConst.SKIPCHECKPERMISSION, String.valueOf(true));
            if (bonusPayments.size() > 0) {
                // 生成奖金发放
                // 提交
                OperationResult submitResult = OperationServiceHelper.executeOperate("submit", "${ISV_FLAG}_bonus_payment", bonusPayments.toArray(new DynamicObject[0]), operateOption.copy());
                List<Object> submitSuccessPkIds = submitResult.getSuccessPkIds();
                checkOperationResult(submitResult,"生成奖金发放失败\n");
                // 审核
                OperationResult auditResult = OperationServiceHelper.executeOperate("audit", "${ISV_FLAG}_bonus_payment", submitSuccessPkIds.toArray(), operateOption.copy());
                checkOperationResult(auditResult,"生成奖金发放失败\n");
            }
            logger.info("start.payment.count{}",bonusPayments.size());
            if (departmentFunds.size() > 0) {
                // 部门经费
                // 提交
                OperationResult submitResult = OperationServiceHelper.executeOperate("submit", "${ISV_FLAG}_department_funds", departmentFunds.toArray(new DynamicObject[0]), operateOption.copy());
                List<Object> submitSuccessPkIds = submitResult.getSuccessPkIds();
                checkOperationResult(submitResult,"生成部门经费失败\n");
                // 审核
                OperationResult auditResult = OperationServiceHelper.executeOperate("audit", "${ISV_FLAG}_department_funds", submitSuccessPkIds.toArray(), operateOption.copy());
                checkOperationResult(auditResult,"生成部门经费失败\n");
            }
        }
    }

    @Override
    public void afterExecuteOperationTransaction(AfterOperationArgs e) {
        super.afterExecuteOperationTransaction(e);
        String operationKey = e.getOperationKey();
        DynamicObject[] entities = e.getDataEntities();
        if ("submiteffect".equals(operationKey)){
            List<String> approvalExplains =Arrays.asList("1","2","3");//已报批、已发文、执行制度
            for (DynamicObject bill : entities) {
                String approvalExplain = bill.getString("${ISV_FLAG}_bpsm");
                String buOrgNum = bill.getString("org.number");
                if (approvalExplains.contains(approvalExplain) && !"TW04".equals(buOrgNum)){
                    List<ListSelectedRow> rows = new ArrayList<>();
                    ListSelectedRow row = new ListSelectedRow();
                    row.setPrimaryKeyValue(bill.getLong("id"));
                    rows.add(row);

                    try {
                        PushResult pushResult = BotpUtils.push(false, "${ISV_FLAG}_bonus_approval_2nd", "${ISV_FLAG}_bonus_approval_flow", rows, "2373964054609038336");
                        // 下推是否成功
                        if (pushResult.isSuccess()) {
                            // 收集计划汇总审批单id
                            HashMap<Long, Long> resourseMap = new HashMap<>();
                            DynamicObject[] dataPacks = pushResult.getDatapacks();
                            for (DynamicObject dataPack : dataPacks) {
                                Long bonusPlanApprovalId = dataPack.getLong("id");
                                DynamicObjectCollection tdkwEntryPlanDetail = dataPack.getDynamicObjectCollection("${ISV_FLAG}_hd_details");
                                Set<Long> srcbillIds = tdkwEntryPlanDetail.stream().map(item -> Long.valueOf(item.getString("${ISV_FLAG}_billid"))).collect(Collectors.toSet());
                                srcbillIds.forEach(srcbillId -> resourseMap.put(srcbillId, bonusPlanApprovalId));
                                // 保存数据，已报批、已发文、执行制度，提交审批后直接生成汇总审批单
                                OperateChain.of(dataPack).save().submit().failThenDeleteAndThrow();
                            }
                            bill.set("${ISV_FLAG}_check_summary", resourseMap.get(bill.getLong("id")));
                        } else {
                            String errMsg = pushResult.getErrMsg();
                            throw new KDBizException("生成汇总审批失败。" + errMsg);
                        }

                    } catch (Exception ex) {
                        throw new KDBizException(ex.getMessage());
                    }
                }
            }
            SaveServiceHelper.update(entities);
        }
    }

    /**
     * 创建奖金分配单
     */
    private DynamicObject[] createDistributeBill(DynamicObject[] entities, Date currentTime, DynamicObject bosUser, Map<String, String> orgDisNoMap) {
        // 1.核定单存在核定到组织的数据
        return Arrays.stream(entities).map(bill -> {
            // 属于【组织核定明细】的数据生成一张【奖金分配单】
            List<DynamicObject> collect = genDistributeByDeptDetail(currentTime, bill, bosUser, orgDisNoMap);
            return collect;
        }).flatMap(List::stream).toArray(DynamicObject[]::new);
    }

    /**
     * 生成奖金分配单（在核定单的组织分配明细中）
     */
    private List<DynamicObject> genDistributeByDeptDetail(Date currentTime, DynamicObject bill, DynamicObject bosUser, Map<String, String> orgDisNoMap) {
        DynamicObjectCollection awardSureOrgCollection = bill.getDynamicObjectCollection("${ISV_FLAG}_award_sure_org"); // 组织核定明细
        DynamicObjectCollection awardSureStaffCollection = bill.getDynamicObjectCollection("${ISV_FLAG}_award_sure_staff"); // 人员核定明细
        DynamicObjectCollection awardSureKeepCollection = bill.getDynamicObjectCollection("${ISV_FLAG}_award_keep_org"); // 留存部门明细
        return awardSureOrgCollection.stream().map(entry -> {
            String orgLongNumber = entry.getString("${ISV_FLAG}_admin_org.structlongnumber"); // 组织上下级长编码
            DynamicObject distributeDynamicObject = BusinessDataServiceHelper.newDynamicObject(BonusUtil.DISTRIBUTE_BILL_FORM_ID);

            // 隐藏信息
            distributeDynamicObject.set("${ISV_FLAG}_approval", bill); // 核定单单据
            distributeDynamicObject.set("${ISV_FLAG}_distribute", null); // 分配单单据
            distributeDynamicObject.set("${ISV_FLAG}_approval_id", bill.getLong("id")); // 核定单id
            distributeDynamicObject.set("${ISV_FLAG}_distribute_id", null); // 分配单id
            /*distributeDynamicObject.set("creator", bosUser); // 创建人
            distributeDynamicObject.set("modifier", bosUser); // 修改人*/
            distributeDynamicObject.set("createtime", currentTime); // 创建时间
            distributeDynamicObject.set("modifytime", currentTime); // 修改时间
            distributeDynamicObject.set("billstatus", "A"); // 单据状态
            distributeDynamicObject.set("auditstatus", "A"); // 审批状态
            distributeDynamicObject.set("${ISV_FLAG}_currencyfield", BonusUtil.currency); // 币别

            // 基本信息
            distributeDynamicObject.set("org", entry.getDynamicObject("${ISV_FLAG}_admin_org.org")); // 奖金管理组织
            distributeDynamicObject.set("${ISV_FLAG}_subordinate", entry.getDynamicObject("${ISV_FLAG}_subordinate")); // 分配人（从上级单据带来）
            distributeDynamicObject.set("${ISV_FLAG}_distribute_org", entry.getDynamicObject("${ISV_FLAG}_admin_org")); // 分配组织
            distributeDynamicObject.set("${ISV_FLAG}_pt_undertake_org", entry.getDynamicObject("${ISV_FLAG}_undertake_org")); // 上级单承担组织
            distributeDynamicObject.set("${ISV_FLAG}_bonus_item", bill.getDynamicObject("${ISV_FLAG}_award_project")); // 奖金项目
            distributeDynamicObject.set("${ISV_FLAG}_belong_period", bill.getDate("${ISV_FLAG}_approval_period")); // 归属周期
            distributeDynamicObject.set("${ISV_FLAG}_distribute_rule", bill.get("${ISV_FLAG}_distribute_rules")); // 分配规则
            distributeDynamicObject.set("${ISV_FLAG}_warn_rule", bill.get("${ISV_FLAG}_warning_rules")); // 预警规则
            distributeDynamicObject.set("${ISV_FLAG}_enable_distribute_tl", entry.getBigDecimal("${ISV_FLAG}_check_amount")); // 可分配总额 --- 来源与核定单则取“核定金额”

            // 单据处理人
            DynamicObject handler = BonusWriteBackUtil.getBosUser(entry.getDynamicObject("${ISV_FLAG}_subordinate"));
            distributeDynamicObject.set("${ISV_FLAG}_handler", handler);
            distributeDynamicObject.set("creator", handler);
            distributeDynamicObject.set("modifier", handler);
            // 分配组织 是否是经营主体
            int jY = 0;
            DynamicObject adminOrg = entry.getDynamicObject("${ISV_FLAG}_admin_org");
            if (adminOrg != null) {
                DynamicObject orgTypeObject = adminOrg.getDynamicObject("adminorgtype");
                if (orgTypeObject != null && "1025_S".equals(orgTypeObject.getString("number"))) {
                    jY = 1;
                }
            }
            // 经营主体分配 0 否  1 是
            distributeDynamicObject.set("${ISV_FLAG}_jyztfp", jY);
            // 上级单据类型
            distributeDynamicObject.set("${ISV_FLAG}_parent_bill_type", TYPE_HE_DING);
            // 上级单据编号
            distributeDynamicObject.set("${ISV_FLAG}_parent_bill_no", bill.get("billno"));
            // 上级单据名称
            distributeDynamicObject.set("${ISV_FLAG}_parent_bill_name", bill.get("${ISV_FLAG}_approval_name"));
            // 上级创建人
            distributeDynamicObject.set("${ISV_FLAG}_pt_creator", bill.get("${ISV_FLAG}_dept_person"));
            // 上级创建人 公司
            distributeDynamicObject.set("${ISV_FLAG}_pt_company", bill.get("${ISV_FLAG}_attribut_company"));
            // 上级创建人 部门
            distributeDynamicObject.set("${ISV_FLAG}_pt_dept", bill.get("${ISV_FLAG}_attribut_dept"));
            // 上级创建人 岗位
            distributeDynamicObject.set("${ISV_FLAG}_pt_post", bill.get("${ISV_FLAG}_attribut_post"));

            // 核定单据信息赋值
            distributeDynamicObject.set("${ISV_FLAG}_approval_no", bill.get("billno"));
            distributeDynamicObject.set("${ISV_FLAG}_approval_name", bill.get("${ISV_FLAG}_approval_name"));
            distributeDynamicObject.set("${ISV_FLAG}_award_type", bill.get("${ISV_FLAG}_award_type"));
            distributeDynamicObject.set("${ISV_FLAG}_award_project", bill.get("${ISV_FLAG}_award_project"));
            distributeDynamicObject.set("${ISV_FLAG}_personalization", bill.get("${ISV_FLAG}_personalization"));
            distributeDynamicObject.set("${ISV_FLAG}_approval_period", bill.get("${ISV_FLAG}_approval_period"));
            distributeDynamicObject.set("${ISV_FLAG}_approval_end_date", bill.get("${ISV_FLAG}_approval_end_date"));
            distributeDynamicObject.set("${ISV_FLAG}_cost_duty",bill.get("${ISV_FLAG}_cost_duty"));
            distributeDynamicObject.set("${ISV_FLAG}_approval_describe", bill.get("${ISV_FLAG}_approval_describe"));
            distributeDynamicObject.set("${ISV_FLAG}_ap_creator", bill.get("${ISV_FLAG}_dept_person"));
            distributeDynamicObject.set("${ISV_FLAG}_ap_company", bill.get("${ISV_FLAG}_attribut_company"));
            distributeDynamicObject.set("${ISV_FLAG}_ap_dept", bill.get("${ISV_FLAG}_attribut_dept"));
            distributeDynamicObject.set("${ISV_FLAG}_ap_post", bill.get("${ISV_FLAG}_attribut_post"));

            // 调用自动编码规则
            CodeRuleInfo codeRule = CodeRuleServiceHelper.getCodeRule(distributeDynamicObject.getDataEntityType().getName(), distributeDynamicObject, null);
            // 获取单据编码
            String billno = CodeRuleServiceHelper.getNumber(codeRule, distributeDynamicObject);
            distributeDynamicObject.set("billno", billno);
            // 编码路径
            distributeDynamicObject.set("${ISV_FLAG}_billno_path_tag", billno);
            // 创建人信息
            setCreatorDefault(distributeDynamicObject,entry);

            // 单据体
            // 获取[奖金核定单]的[组织核定明细]分录和[人员核定明细]分录的行政组织的长编码集合
            List<DynamicObject> personDetailCollection = awardSureStaffCollection.stream().filter(number -> number.getString("${ISV_FLAG}_admin_dept.structlongnumber").contains(orgLongNumber)).collect(Collectors.toList());
            List<DynamicObject> retentionDetailCollection = awardSureKeepCollection.stream().filter(number -> number.getString("${ISV_FLAG}_admin_org_keep.structlongnumber").contains(orgLongNumber)).collect(Collectors.toList());
            genDistributeEntry(distributeDynamicObject, personDetailCollection, retentionDetailCollection);

            // 分配统计
            BigDecimal personDistributeTotal = distributeDynamicObject.getDynamicObjectCollection("${ISV_FLAG}_person_dis_entry").stream().filter(upper -> !upper.getBoolean("${ISV_FLAG}_is_upper_dis")).map(decimal -> decimal.getBigDecimal("${ISV_FLAG}_real_dis_decimal")).reduce(BigDecimal.ZERO, BigDecimal::add);
            BigDecimal personUpperDistributeTotal = distributeDynamicObject.getDynamicObjectCollection("${ISV_FLAG}_person_dis_entry").stream().filter(upper -> upper.getBoolean("${ISV_FLAG}_is_upper_dis")).map(decimal -> decimal.getBigDecimal("${ISV_FLAG}_real_dis_decimal")).reduce(BigDecimal.ZERO, BigDecimal::add);
            BigDecimal deptDistributeTotal = distributeDynamicObject.getDynamicObjectCollection("${ISV_FLAG}_dept_dis_entry").stream().map(decimal -> decimal.getBigDecimal("${ISV_FLAG}_distribute_decimal")).reduce(BigDecimal.ZERO, BigDecimal::add);
            BigDecimal retentionTotal = distributeDynamicObject.getDynamicObjectCollection("${ISV_FLAG}_retention_entry").stream().filter(upper -> !upper.getBoolean("${ISV_FLAG}_is_upper")).map(decimal -> decimal.getBigDecimal("${ISV_FLAG}_retention_decimal")).reduce(BigDecimal.ZERO, BigDecimal::add);
            BigDecimal retentionUpperTotal = distributeDynamicObject.getDynamicObjectCollection("${ISV_FLAG}_retention_entry").stream().filter(upper -> upper.getBoolean("${ISV_FLAG}_is_upper")).map(decimal -> decimal.getBigDecimal("${ISV_FLAG}_retention_decimal")).reduce(BigDecimal.ZERO, BigDecimal::add);
            BigDecimal currentDistributeTotal = personDistributeTotal.add(deptDistributeTotal);
            BigDecimal upperDistributeTotal = personUpperDistributeTotal.add(retentionUpperTotal);
            // 可分配总额
            BigDecimal enableDisTotal = distributeDynamicObject.getBigDecimal("${ISV_FLAG}_enable_distribute_tl");
            distributeDynamicObject.set("${ISV_FLAG}_current_dis_total", currentDistributeTotal); // 本次分配总金额
            distributeDynamicObject.set("${ISV_FLAG}_org_dis_total", deptDistributeTotal); // 组织分配总额
            distributeDynamicObject.set("${ISV_FLAG}_person_dis_total", personDistributeTotal); // 人员分配总额
            distributeDynamicObject.set("${ISV_FLAG}_rentention_dis_total", retentionTotal); // 部门留存总额
            distributeDynamicObject.set("${ISV_FLAG}_upper_dis_total", upperDistributeTotal); // 上级分配总额
            distributeDynamicObject.set("${ISV_FLAG}_money_total", enableDisTotal.add(upperDistributeTotal)); // 奖金总额=可分配总额+上级分配总额

            // 可分配总额
            BigDecimal availTotal2 = distributeDynamicObject.getBigDecimal("${ISV_FLAG}_enable_distribute_tl");
            // 本次分配
            BigDecimal currTotal2 = distributeDynamicObject.getBigDecimal("${ISV_FLAG}_current_dis_total");
            // 剩余未用金额
            distributeDynamicObject.set("${ISV_FLAG}_leave_total",availTotal2.subtract(currTotal2));
            // 分配单记录汇总单编码
            distributeDynamicObject.set("${ISV_FLAG}_dis_billno", orgDisNoMap.get(orgLongNumber));
            // 设置分配单单据名称
            BonusWriteBackUtil.setDistributeBillName(distributeDynamicObject);
            return distributeDynamicObject;
        }).collect(Collectors.toList());
    }

