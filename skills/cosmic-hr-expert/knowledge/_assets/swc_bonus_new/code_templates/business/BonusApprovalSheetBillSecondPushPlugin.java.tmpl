    /**
     * 生成奖金发放
     */
    private List<DynamicObject> creatBounsPayments(DynamicObject[] dataEntities) {
        // 收集人员核定明细分录id
        List<Long> entryIds = new ArrayList<>();
        Arrays.stream(dataEntities).map(item -> item.getDynamicObjectCollection("${ISV_FLAG}_award_sure_staff"))
                .flatMap(DynamicObjectCollection::stream)
                .forEach(item -> {
                    entryIds.add(item.getLong("id"));
                });

        // 查询奖金发放数据
        QFilter filter = new QFilter("${ISV_FLAG}_source_bill_type", QCP.equals, "A");
        filter.and("${ISV_FLAG}_sourceid", QCP.in, entryIds);
        DynamicObjectCollection bonusPaymentQuery = QueryServiceHelper.query("${ISV_FLAG}_bonus_payment", "id", filter.toArray());
        if (!CollectionUtils.isEmpty(bonusPaymentQuery)) {
            throw new KDBizException("存在核定单已生成了奖金发放，请联系相关人员查看。");
        }

        // 默认为人民币
        List<DynamicObject> bonusPayments = new ArrayList<>();
        for (DynamicObject checkBill : dataEntities) {
            String disSumBillno = checkBill.getString("billno");// 核定单号
            DynamicObject bonusItem = checkBill.getDynamicObject("${ISV_FLAG}_award_project"); // 奖金项目
            Date belongPeriod = checkBill.getDate("${ISV_FLAG}_approval_period"); // 归属期间
            // 分配组织
            DynamicObject distributeOrg = checkBill.getDynamicObject("${ISV_FLAG}_belong_to_org");
            // 分配时间
            Date distributeTime = checkBill.getDate("createtime");
            // 分配人
            DynamicObject distributePerson = checkBill.getDynamicObject("${ISV_FLAG}_dept_person");
            // 所在公司
            DynamicObject distributeCompany = checkBill.getDynamicObject("${ISV_FLAG}_attribut_company");

            // 获取人员分配明细
            DynamicObjectCollection personCheckDetailEntry = checkBill.getDynamicObjectCollection("${ISV_FLAG}_award_sure_staff");
            for (DynamicObject personCheckEntry : personCheckDetailEntry) {
                long entryId = personCheckEntry.getLong("id");
                BigDecimal disTotalPerson = personCheckEntry.getBigDecimal("${ISV_FLAG}_check_amount2"); // 核定金额（元）
                DynamicObject person = personCheckEntry.getDynamicObject("${ISV_FLAG}_employee_name"); // 人员
                DynamicObject company = personCheckEntry.getDynamicObject("${ISV_FLAG}_per_admin_company"); // 所属公司
                DynamicObject dept = personCheckEntry.getDynamicObject("${ISV_FLAG}_admin_dept"); // 所属部门
                DynamicObject underTakeCompany = personCheckEntry.getDynamicObject("${ISV_FLAG}_undertake_org2"); // 承担组织
                DynamicObject org = underTakeCompany.getDynamicObject("org"); // 承担组织的bu


                // 生成奖金发放
                DynamicObject bonusPayment = BusinessDataServiceHelper.newDynamicObject("${ISV_FLAG}_bonus_payment");
                bonusPayment.set("billstatus", "A");
                bonusPayment.set("org", org); // 承担组织的bu
                bonusPayment.set("${ISV_FLAG}_person", person.getDynamicObject("employee")); // 人员
                bonusPayment.set("${ISV_FLAG}_company", company); // 所属公司
                bonusPayment.set("${ISV_FLAG}_dept", dept);  // 所属部门
                bonusPayment.set("${ISV_FLAG}_is_agent", "0");  // 是否代发
                bonusPayment.set("${ISV_FLAG}_payment_company", underTakeCompany); // 发放公司
                bonusPayment.set("${ISV_FLAG}_shoulder_org", underTakeCompany); // 承担组织
                bonusPayment.set("${ISV_FLAG}_bonus_item", bonusItem); // 奖金项目
                bonusPayment.set("${ISV_FLAG}_period", belongPeriod); // 所属期间
                bonusPayment.set("${ISV_FLAG}_amount", disTotalPerson); // 分配总额
                bonusPayment.set("${ISV_FLAG}_currency", BonusUtil.currency); // 币别
                bonusPayment.set("${ISV_FLAG}_distribute_org", distributeOrg); // 分配组织
                bonusPayment.set("${ISV_FLAG}_distribute_time", distributeTime); // 分配时间
                bonusPayment.set("${ISV_FLAG}_distribute_person", distributePerson); // 分配人
//                bonusPayment.set("${ISV_FLAG}_distribute_company",distributeCompany); // 分配人所在公司
                bonusPayment.set("${ISV_FLAG}_redeem_amount", disTotalPerson); // 可兑现金额
                bonusPayment.set("${ISV_FLAG}_is_zero",disTotalPerson.compareTo(BigDecimal.ZERO) == 0? "1" : "0"); // 可兑现金额是否为0
                bonusPayment.set("${ISV_FLAG}_cancelled_amount", BigDecimal.ZERO); // 作废金额
                bonusPayment.set("${ISV_FLAG}_sourceid", entryId); // 数据来源
                bonusPayment.set("${ISV_FLAG}_source_billno", disSumBillno); // 来源单号
                bonusPayment.set("${ISV_FLAG}_source_bill_type", "A"); // 来源类型 A核定单 B分配汇总单
                bonusPayment.set("${ISV_FLAG}_check_id",checkBill.getLong("id")); // 核定单id
                bonusPayment.set("${ISV_FLAG}_check_number",checkBill.getString("billno")); //核定单编码
                bonusPayment.set("${ISV_FLAG}_check_name",checkBill.getString("${ISV_FLAG}_approval_name")); //核定单名称
                bonusPayment.set("${ISV_FLAG}_grant_per_count", 0); // 发放次数
                bonusPayment.set("${ISV_FLAG}_grant_amount", BigDecimal.ZERO); // 发放总额
                bonusPayment.set("${ISV_FLAG}_dept_funds_number",""); // 部门经费编码
                bonusPayment.set("${ISV_FLAG}_personalization", checkBill.getString("${ISV_FLAG}_personalization")); // 奖金业务类别
                bonusPayments.add(bonusPayment);
            }
        }
        return bonusPayments;
    }

    /**
     * 生成部门经费
     */
    private List<DynamicObject> creatDepartmentFunds(DynamicObject[] dataEntities) {
        // 收集留存部门经费分录id
        List<Long> entryIds = new ArrayList<>();
        Arrays.stream(dataEntities).map(item -> item.getDynamicObjectCollection("${ISV_FLAG}_award_keep_org"))
                .flatMap(DynamicObjectCollection::stream)
                .forEach(item -> {
                    entryIds.add(item.getLong("id"));
                });

        // 查询部门留存数据
        QFilter filter = new QFilter("${ISV_FLAG}_source_bill_type", QCP.equals, "A");
        filter.and("${ISV_FLAG}_sourceid", QCP.in, entryIds);
        DynamicObjectCollection departmentFundsQuery = QueryServiceHelper.query("${ISV_FLAG}_department_funds", "id", filter.toArray());
        if (!CollectionUtils.isEmpty(departmentFundsQuery)) {
            throw new RuntimeException("存在核定单已生成了部门留存数据，请联系相关人员查看。");
        }

        List<DynamicObject> departmentFunds = new ArrayList<>();
        for (DynamicObject checkBill : dataEntities) {
            String disSumBillno = checkBill.getString("billno");// 核定单号
            DynamicObject bonusItem = checkBill.getDynamicObject("${ISV_FLAG}_award_project"); // 奖金项目
            Date belongPeriod = checkBill.getDate("${ISV_FLAG}_approval_period"); // 归属期间
            // 创建人信息
            DynamicObject deptPerson = checkBill.getDynamicObject("${ISV_FLAG}_dept_person");
            DynamicObject attributPost = checkBill.getDynamicObject("${ISV_FLAG}_attribut_post");
            DynamicObject attributDept = checkBill.getDynamicObject("${ISV_FLAG}_attribut_dept");
            DynamicObject attributCompany = checkBill.getDynamicObject("${ISV_FLAG}_attribut_company");

            // 获取留存部门经费
            DynamicObjectCollection departmentKeepEntrys = checkBill.getDynamicObjectCollection("${ISV_FLAG}_award_keep_org");
            for (DynamicObject departmentKeepEntry : departmentKeepEntrys) {
                long entryId = departmentKeepEntry.getLong("id");
                BigDecimal amount = departmentKeepEntry.getBigDecimal("${ISV_FLAG}_check_amount3"); // 留存金额（元）
                DynamicObject company = departmentKeepEntry.getDynamicObject("${ISV_FLAG}_keep_company"); // 所属公司
                DynamicObject dept = departmentKeepEntry.getDynamicObject("${ISV_FLAG}_admin_org_keep"); // 行政组织
                DynamicObject underTakeCompany = departmentKeepEntry.getDynamicObject("${ISV_FLAG}_undertake_org3"); // 承担组织
                String remark = departmentKeepEntry.getString("${ISV_FLAG}_per_remark1");
                DynamicObject org = company.getDynamicObject("org"); // org


                // 生成部门经费
                DynamicObject departmentFund = BusinessDataServiceHelper.newDynamicObject("${ISV_FLAG}_department_funds");
                departmentFund.set("billstatus", "A");
                departmentFund.set("auditstatus", "A");
                departmentFund.set("org", org); // 承担组织的bu
                departmentFund.set("${ISV_FLAG}_bonus_item", bonusItem); // 奖金项目
                departmentFund.set("${ISV_FLAG}_keep_company",company); // 公司
                departmentFund.set("${ISV_FLAG}_admin_org_keep", dept); // 部门
                departmentFund.set("${ISV_FLAG}_undertake_org", underTakeCompany); // 承担组织
                departmentFund.set("${ISV_FLAG}_belong_period", belongPeriod); // 承归属期间
                departmentFund.set("${ISV_FLAG}_currency",BonusUtil.currency); // 币别
                departmentFund.set("${ISV_FLAG}_dept_amount",amount); // 部门经费总额
                departmentFund.set("${ISV_FLAG}_surplus_amount",amount); // 剩余可用总额
                departmentFund.set("${ISV_FLAG}_is_zero",amount.compareTo(BigDecimal.ZERO) == 0? "1" : "0");// 剩余可用总额是否为0
                departmentFund.set("${ISV_FLAG}_used_amount", BigDecimal.ZERO); // 已用总额
                departmentFund.set("${ISV_FLAG}_redistribut_amount", BigDecimal.ZERO); // 再分配总额
                departmentFund.set("${ISV_FLAG}_sub_finance_amount", BigDecimal.ZERO); // 提交财务总额
                departmentFund.set("${ISV_FLAG}_finance_use_amount", BigDecimal.ZERO); // 财务已用金额
                departmentFund.set("${ISV_FLAG}_finance_unuse_amount", BigDecimal.ZERO); // 财务未用总额
                departmentFund.set("${ISV_FLAG}_sourceid", entryId); // 数据来源
                departmentFund.set("${ISV_FLAG}_source_billno", disSumBillno); // 来源单号
                departmentFund.set("${ISV_FLAG}_source_bill_type", "A"); // 来源类型 A核定单 B分配单
                departmentFund.set("${ISV_FLAG}_check_id",checkBill.getLong("id")); // 核定单id
                departmentFund.set("${ISV_FLAG}_remark_dept",remark); // 备注

                // 创建人信息
                departmentFund.set("${ISV_FLAG}_dept_person",deptPerson);
                departmentFund.set("${ISV_FLAG}_attribut_post",attributPost);
                departmentFund.set("${ISV_FLAG}_attribut_dept",attributDept);
                departmentFund.set("${ISV_FLAG}_attribut_company",attributCompany);
                departmentFunds.add(departmentFund);
            }
        }
        return departmentFunds;
    }

    /**
     * 操作结果校验
     */
    private static void checkOperationResult(OperationResult auditResult,String message) {
        if (!auditResult.isSuccess()){
            List<IOperateInfo> allErrorOrValidateInfo = auditResult.getAllErrorOrValidateInfo();
            if (allErrorOrValidateInfo != null && allErrorOrValidateInfo.size() > 0) {
                List<String> messages = allErrorOrValidateInfo.stream().map(item -> item.getMessage() + "\n").collect(Collectors.toList());
                List<String> collect = IntStream.range(0, messages.size()).mapToObj(i -> (i + 1) + "、" + messages.get(i)).collect(Collectors.toList());
                throw new RuntimeException(message + String.join("", collect));
            }
            if (!StringUtils.isEmpty(auditResult.getMessage())){
                throw new RuntimeException(message + auditResult.getMessage());
            }
            logger.info("error{}",auditResult);
            throw new KDBizException("出现未知结果，请联系相关人员查看");
        }
    }
