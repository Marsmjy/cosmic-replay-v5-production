    /**
     * 设置系统隐藏信息
     */
    private static void setSystemHiddenInfo(Date currentTime, DynamicObject bill, DynamicObject bosUser, DynamicObject distributeSumDynamicObject) {
        // 系统隐藏信息
        distributeSumDynamicObject.set("billstatus", "A"); // 单据状态
        distributeSumDynamicObject.set("auditstatus", "A"); // 审批状态
        distributeSumDynamicObject.set("createtime", currentTime); // 创建时间
        distributeSumDynamicObject.set("modifytime", currentTime); // 修改时间
        distributeSumDynamicObject.set("creator", bosUser); // 创建人
        distributeSumDynamicObject.set("modifier", bosUser); // 修改人
        distributeSumDynamicObject.set("${ISV_FLAG}_approval_bill_id", bill.getLong("id")); // 关联核定单id
        distributeSumDynamicObject.set("${ISV_FLAG}_approval_bill", bill); // 关联核定单单据
        distributeSumDynamicObject.set("${ISV_FLAG}_currencyfield", BonusUtil.currency); // 币别
        // 关联核定信息
        distributeSumDynamicObject.set("${ISV_FLAG}_approval_no", bill.getString("billno")); // 关联核定单单号
        distributeSumDynamicObject.set("${ISV_FLAG}_approval_name", bill.getString("${ISV_FLAG}_approval_name")); // 关联核定单核定名称
        distributeSumDynamicObject.set("${ISV_FLAG}_belong_to_org", bill.getString("${ISV_FLAG}_belong_to_org")); // 关联核定单的单据所属组织
    }

    /**
     * 设置分配统计信息
     */
    public static void setDistributeStatistics(DynamicObject distributeSumDynamicObject) {
        // 获取准备生成的[奖金分配汇总单]的[人员分配明细]分录和[部门留用明细]分录的各个总金额
        DynamicObjectCollection personDisDetailList = distributeSumDynamicObject.getDynamicObjectCollection("${ISV_FLAG}_person_dis_detail");
        BigDecimal personDistributeDetailTotal = personDisDetailList.stream().map(decimal -> decimal.getBigDecimal("${ISV_FLAG}_dis_total_person")).reduce(BigDecimal.ZERO, BigDecimal::add);
        BigDecimal deptRetentionDetailTotal = distributeSumDynamicObject.getDynamicObjectCollection("${ISV_FLAG}_dept_retentiion_deta").stream().map(decimal -> decimal.getBigDecimal("${ISV_FLAG}_retention_total_dept")).reduce(BigDecimal.ZERO, BigDecimal::add);
        BigDecimal alreadyDistributeTotal = personDistributeDetailTotal.add(deptRetentionDetailTotal);
        // 总金额
        BigDecimal moneyTotal = distributeSumDynamicObject.getBigDecimal("${ISV_FLAG}_money_total");
        BigDecimal distributeRatio = alreadyDistributeTotal.divide(moneyTotal, 4, RoundingMode.HALF_UP);
        Long warnPersonCount = personDisDetailList.stream().filter(warn -> HRStringUtils.isNotBlank(warn.getString("${ISV_FLAG}_warn_remark_person"))).count();
        BigDecimal maxDistributeRatio = personDisDetailList.stream().max(Comparator.comparing(decimal -> decimal.getBigDecimal("${ISV_FLAG}_dis_ratio_person"))).map(decimal -> decimal.getBigDecimal("${ISV_FLAG}_dis_ratio_person")).orElse(BigDecimal.ZERO);

        // 分配统计
        distributeSumDynamicObject.set("${ISV_FLAG}_already_dis_total", alreadyDistributeTotal); // 已分配总额（元）
        distributeSumDynamicObject.set("${ISV_FLAG}_already_dis_count", personDisDetailList.size()); // 已分配人员数量
        distributeSumDynamicObject.set("${ISV_FLAG}_already_dis_count_to", personDistributeDetailTotal); // 已分配人员总额（元）
        distributeSumDynamicObject.set("${ISV_FLAG}_dept_retention_total", deptRetentionDetailTotal); // 部门留用总额（元）
        distributeSumDynamicObject.set("${ISV_FLAG}_warn_count", warnPersonCount.intValue()); // 触发预警人数
        distributeSumDynamicObject.set("${ISV_FLAG}_distribute_ratio", distributeRatio); // 分配进度
        if (new BigDecimal(1).compareTo(distributeRatio) == 0) {
            // 取最后一条分配单提交时间（分配进度达到100%）
            distributeSumDynamicObject.set("${ISV_FLAG}_finish_dis_date", new Date());
            // H 待复核 I 已复核 K 无需处理
            if (!"K".equals(distributeSumDynamicObject.getString("billstatus"))) {
                distributeSumDynamicObject.set("billstatus", "H");
            }
        } else{
            // 待分配
            distributeSumDynamicObject.set("billstatus","A");
        }
        distributeSumDynamicObject.set("${ISV_FLAG}_max_ratio", maxDistributeRatio); // 人员最高占比
    }

