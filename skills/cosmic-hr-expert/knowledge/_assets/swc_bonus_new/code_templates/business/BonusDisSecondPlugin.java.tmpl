    @Override
    public void beforeF7Select(BeforeF7SelectEvent beforeF7SelectEvent) {
        String name = beforeF7SelectEvent.getProperty().getName();
        ListShowParameter showParameter = (ListShowParameter) beforeF7SelectEvent.getFormShowParameter();
        DynamicObject dataEntity = this.getModel().getDataEntity(true);

        ArrayList<Long> orgIdList = new ArrayList<>();
        switch (name){
            case "${ISV_FLAG}_peson":
                // 允许查询离职员工
                showParameter.setCustomParam("isAllowInfoClassifyEdit",Boolean.TRUE);
                break;
            case "${ISV_FLAG}_undertake_org3":
            case "${ISV_FLAG}_undertake_org2":
            case "${ISV_FLAG}_undertake_org":
                // 行政组织类型为“子公司”及虚拟组织股份总部
                QFilter orgFilter = new QFilter("adminorgtype.number",QCP.equals, "1028_S");
                orgFilter.or("number",QCP.in,Arrays.asList("10017990","YX.10.30","10000050","10000268","10012991"));
                showParameter.getListFilterParameter().getQFilters().add(orgFilter);
                // F7基础资料-组织树过滤
                this.filterOrgTreeByF7Limit(showParameter,orgFilter);
                break;
            case "${ISV_FLAG}_dept_person":
                QFilter personFilter = new QFilter("id", QCP.equals, RequestContext.get().getCurrUserId());
                DynamicObject currentPerson = QueryServiceHelper.queryOne("bos_user", "id,number", personFilter.toArray());
                // 组织人过滤
                QFilter personOrgFilter = new QFilter("employee.number",QCP.equals, currentPerson.getString("number"));
                showParameter.getListFilterParameter().getQFilters().add(personOrgFilter);
                break;
            case "${ISV_FLAG}_org":
                // 设置列表过滤条件
                // 组织分配明细
                // 留存部门经费
                // 不显示行政组织类型为“1043_S 业务组\1050_S 工厂\1070_S 车间/工段”的组织
                // 增量  1010_S 1015_S 1025_S
                QFilter orgTemp = new QFilter("adminorgtype.number",QCP.not_in, Arrays.asList("1043_S","1050_S","1070_S"
                        ,"1010_S","1015_S","1025_S"));
                showParameter.getListFilterParameter().getQFilters().add(orgTemp);
                // F7基础资料-组织树过滤
                this.filterOrgTreeByF7Limit(showParameter,orgTemp);
                break;
            case "${ISV_FLAG}_admin_org_keep":
                // 行政组织类型为一级部门、二级部门、虚拟组织
                QFilter orgtypeFilter = new QFilter("adminorgtype.number",QCP.in, Arrays.asList("1040_S","1041_S","1080_S"));
                showParameter.getListFilterParameter().getQFilters().add(orgtypeFilter);
                // F7基础资料-组织树过滤
                this.filterOrgTreeByF7Limit(showParameter,orgtypeFilter);
                break;
            default:
                break;
        }
    }

    @Override
    public void beforeDoOperation(BeforeDoOperationEventArgs args) {
        super.beforeDoOperation(args);
        Object source = args.getSource();
        // 分录中删行事件监听
        if(source instanceof DeleteEntry) {
            String operateKey = ((DeleteEntry) source).getOperateKey();
            if("deleteentry_staff".equals(operateKey)) {
                // 人员分配明细-删行
                EntryGrid entryGrid = this.getControl("${ISV_FLAG}_person_dis_entry");
                int [] selectIndexArr = entryGrid.getSelectRows();
                DynamicObject dataEntity = this.getModel().getDataEntity(true);
                // 人员分配分录
                DynamicObjectCollection personEntry = dataEntity.getDynamicObjectCollection("${ISV_FLAG}_person_dis_entry");
                for(int selectIndex : selectIndexArr) {
                    DynamicObject rowObject = personEntry.get(selectIndex);
                    // 是否锁定行
                    String locked = rowObject.getString("${ISV_FLAG}_locked_staff");
                    if("1".equals(locked)){
                        throw new KDBizException("人员分配明细分录存在上级分配数据，不允许删除！");
                    }
                }
            } else if("deleteentry_dept".equals(operateKey)) {
                // 部门分配明细-删行
                EntryGrid entryGrid = this.getControl("${ISV_FLAG}_retention_entry");
                int [] selectIndexArr = entryGrid.getSelectRows();
                DynamicObject dataEntity = this.getModel().getDataEntity(true);
                // 部门分配分录
                DynamicObjectCollection deptEntry = dataEntity.getDynamicObjectCollection("${ISV_FLAG}_retention_entry");
                for(int selectIndex : selectIndexArr) {
                    DynamicObject rowObject = deptEntry.get(selectIndex);
                    // 是否锁定行
                    String locked = rowObject.getString("${ISV_FLAG}_locked_dept");
                    if("1".equals(locked)){
                        throw new KDBizException("留存部门经费分录存在上级分配数据，不允许删除！");
                    }
                }
            }
        }
    }




    @Override
    public void afterDoOperation(AfterDoOperationEventArgs afterDoOperationEventArgs) {
        Object source = afterDoOperationEventArgs.getSource();
        FormOperate operate = (FormOperate) afterDoOperationEventArgs.getSource();
        String operateKey = operate.getOperateKey();
        // 分录中增行监听
        if(source instanceof NewEntry) {
            DynamicObject dataEntity = this.getModel().getDataEntity(true);
            // 人员分配增行
            if("newentry_staff".equals(operateKey)) {
                // 人员分配分录
                DynamicObjectCollection personEntry = dataEntity.getDynamicObjectCollection("${ISV_FLAG}_person_dis_entry");
                int lastIndex = personEntry.size() - 1;
                // 设置人员分配明细-承担组织
                this.updatePersonUnderTakeOrg(lastIndex);
            } else if("newentry_org".equals(operateKey)) {
                // 组织分配分录
                DynamicObjectCollection entry = dataEntity.getDynamicObjectCollection("${ISV_FLAG}_dept_dis_entry");
                int lastIndex = entry.size() - 1;
                // 设置组织分配明细-承担组织
                this.updateOrgUnderTakeOrg(lastIndex);
            } else if("newentry_dept".equals(operateKey)) {
                // 部门留存分录
                DynamicObjectCollection entry = dataEntity.getDynamicObjectCollection("${ISV_FLAG}_retention_entry");
                int lastIndex = entry.size() - 1;
                // 设置部门留存分配明细-承担组织
                this.updateKeepUnderTakeOrg(lastIndex);
            }
            // 分录公共控制
            this.entryCommonControl();
        } else if(source instanceof DeleteEntry) {
            this.entryCommonControl();
        }

    }


