    /**
     * 获取承担组织
     * @param dataEntity
     * @param rowObject
     * @param entryOrgKey 行政组织
     * @param entryJyKey 经营主体
     * @return
     */
    private DynamicObject getUndertakeOrg(DynamicObject dataEntity,DynamicObject rowObject,String entryOrgKey,String entryJyKey,DynamicObject belongCompany){
        DynamicObject realUndertakeOrg = null;
        String costDuty = dataEntity.getString("${ISV_FLAG}_cost_duty");
        String jyzt = dataEntity.getString("${ISV_FLAG}_jyztfp");
        if("B".equals(costDuty) && "1".equals(jyzt)){
            // 受奖方承担 且 核定到经营主体
            // 奖金管理组织id
            long orgId = dataEntity.getLong("org.id");
            // 分录所属经营主体组织id
            long entryOrgId = rowObject.getLong(entryJyKey);
            if(entryOrgId == orgId){
                // 所属公司 company
                DynamicObject company = null;
                if(belongCompany == null){
                    DynamicObject adminorg = rowObject.getDynamicObject(entryOrgKey);
                    if(adminorg != null){
                        company = adminorg.getDynamicObject("company");
                    }
                } else{
                    // 人员分录上的所属公司
                    company = belongCompany;
                }
                // 分录行所属公司
                realUndertakeOrg = company;
            } else{
                 // realUndertakeOrg = dataEntity.getDynamicObject("${ISV_FLAG}_attribut_company");
            }
        }
        return realUndertakeOrg;
    }

    /**
     * 设置部门留存分配明细-承担组织
     * @param rowIndex
     */
    private void updateKeepUnderTakeOrg(int rowIndex){
        int lastIndex = rowIndex;
        DynamicObject dataEntity = this.getModel().getDataEntity(true);
        DynamicObjectCollection personEntry = dataEntity.getDynamicObjectCollection("${ISV_FLAG}_retention_entry");
        // 分录行对象
        DynamicObject rowObject = (DynamicObject) personEntry.get(lastIndex);
        // 上级单承担组织
        DynamicObject ptUndertakeOrg = dataEntity.getDynamicObject("${ISV_FLAG}_pt_undertake_org");
        // 新增分录时
