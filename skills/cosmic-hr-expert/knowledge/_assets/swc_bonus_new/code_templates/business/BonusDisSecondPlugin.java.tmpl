    @Override
    public void afterBindData(EventObject e) {
        // 获取工作流中设置的业务标识
        String bizIdentifyKey = this.getView().getFormShowParameter().getCustomParam("bizIdentifyKey");
        DynamicObject dataEntity = this.getModel().getDataEntity(true);
        // 判断是否在工作流中打开
        if("bonusDisV2".equalsIgnoreCase(bizIdentifyKey)){
            // 将奖金分配单的主键id传递到父页面的页面缓存中
            IPageCache parentPageCache = this.getView().getParentView().getPageCache();
            parentPageCache.put("workFlowBonusIdFromSecondVersion",dataEntity.getString("id"));
            // 工作流中打开可编辑，显示按钮
            this.getView().setVisible(true,"${ISV_FLAG}_advcontoolbarap","${ISV_FLAG}_advcontoolbarap1","${ISV_FLAG}_advcontoolbarap2");
        }else{
            // 别的途径打开不可编辑，隐藏按钮
            this.getView().setVisible(false,"${ISV_FLAG}_advcontoolbarap","${ISV_FLAG}_advcontoolbarap1","${ISV_FLAG}_advcontoolbarap2");
        }
        entryCommonControl();
    }

    /**
     * 值改变事件
     * @param e
     */
    @Override
    public void propertyChanged(PropertyChangedArgs e) {
        String name = e.getProperty().getName();
        ChangeData changeData = e.getChangeSet()[0];
        boolean entryChanged = false;
        switch(name){
            case "${ISV_FLAG}_peson":
                // 人员分配明细-新选择了员工
                this.employeeChange(changeData);
                entryChanged = true;
                break;
            case "${ISV_FLAG}_real_dis_decimal":
                // 人员分配明细-实际分配金额发生变化
                this.staffMoneyChange(changeData);
                entryChanged = true;
                break;
            case "${ISV_FLAG}_distribute_decimal":
                // 组织分配明细-实际分配金额发生变化
                entryChanged = true;
                break;
            case "${ISV_FLAG}_retention_decimal":
                // 部门留存经费-实际分配金额发生变化
                entryChanged = true;
                break;
            case "${ISV_FLAG}_org":
                // 组织分配明细-行政组织发生变化
                this.adminOrgChange(changeData);
                break;
            case "${ISV_FLAG}_admin_org_keep":
                // 留存部门经费-行政组织发生变化
                this.orgKeepChange(changeData);
            case "${ISV_FLAG}_dept_person":
                this.valueChangeCreateStaffSelect();
                break;
            default:

                break;
        }
        // 分录有变化
        if(entryChanged){
            // 分录公共控制
            this.entryCommonControl();
        }
    }

    /**
     * >>留存部门经费分配明细-行政组织发生变化
     * @param changeData
     */
    private void orgKeepChange(ChangeData changeData) {
        //组织核定信息单据体中行政组织发生变化
        DynamicObject adminorg =(DynamicObject) changeData.getNewValue();
        if (adminorg != null){
            //1.带出所选行政组织所属的经营主体
            //1.1经营主体
            DynamicObject haosCompanytype = adminorg.getDynamicObject("org");
            int rowIndex = changeData.getRowIndex();
            this.getModel().setValue("${ISV_FLAG}_bs_entity_org",haosCompanytype,rowIndex);
            // 所属公司
            this.getModel().setValue("${ISV_FLAG}_keep_company",adminorg.getDynamicObject("belongcompany"),rowIndex);
            // 设置组织分配明细-承担组织
            this.updateKeepUnderTakeOrg(rowIndex);
        }
    }

    /**
     * >>组织分配明细-行政组织发生变化
     * @param changeData
     */
    private void adminOrgChange(ChangeData changeData) {
        //组织核定信息单据体中行政组织发生变化
        DynamicObject adminorg =(DynamicObject) changeData.getNewValue();
        if (adminorg != null){
            //1.带出所选行政组织所属的经营主体
            //1.1经营主体
            DynamicObject haosCompanytype = adminorg.getDynamicObject("org");
            int rowIndex = changeData.getRowIndex();
            this.getModel().setValue("${ISV_FLAG}_business_org",haosCompanytype,rowIndex);
            //2默认带出所选组织负责人
            List<Long> orgIds = new ArrayList<>();
            long orgId = adminorg.getLong("id");
            orgIds.add(orgId);
            //2默认带出所选组织负责人
            Map<Long, List<Map<String, Object>>> personIds = HAOSServiceHelper.queryPastChargeByOrgId(orgIds, TimeServiceHelper.now());
            // 一个组织出现多个负责人的时候取哪一个
//            List<Long> dutyPersonIds = BonusWriteBackUtil.listOrgDutyPersonIds(adminorg.getLong("id"));
            // 一个组织出现多个负责人的时候取哪一个
            if (!personIds.isEmpty() && personIds.containsKey(orgId)){
                //person
                List<Map<String, Object>> personMap = personIds.get(orgId);
                Map<String, Object> map = personMap.get(0);
                if (!map.isEmpty() && map.containsKey("person")) {
                    this.getModel().setValue("${ISV_FLAG}_distribute_person", Long.valueOf(String.valueOf(map.get("person"))), rowIndex);
                }
            }
            // 设置组织分配明细-承担组织
            this.updateOrgUnderTakeOrg(rowIndex);
        }
    }

    /**
     * >>F7基础资料-组织树过滤
     * @param showParameter
     * @param orgFilter
     */
    private void filterOrgTreeByF7Limit(ListShowParameter showParameter,QFilter orgFilter){
        // 过滤左树
        DynamicObjectCollection adminorgCollection = QueryServiceHelper.query("haos_adminorg", "id,structlongnumber", orgFilter.toArray());
        List<String> orgList = adminorgCollection.stream().map(item -> item.getString("structlongnumber")).collect(Collectors.toList());
        List<String> structnumber = new ArrayList<>();
        for (String structlongnumber : orgList) {
            String[] split = structlongnumber.split("!");
            structnumber.addAll(Arrays.stream(split).collect(Collectors.toList()));
        }
        QFilter filter = new QFilter("structnumber",QCP.in,structnumber);
        DynamicObjectCollection orgTree = QueryServiceHelper.query("haos_adminorg", "id", filter.toArray());
        showParameter.getCustomParams().put(TreeTemplateConstants.BIZ_QFILTER_KEY, new QFilter("adminorg.id", QCP.in, orgTree.stream().map(item -> item.getLong("id")).collect(Collectors.toSet())).toSerializedString());
    }

    /**
     * >>人员分配明细单据体中人员发生变化
     * @param changeData
     */
    private void employeeChange(ChangeData changeData) {
        //1人员核定明细单据体中人员发生变化
        DynamicObject hrPerson =(DynamicObject) changeData.getNewValue();
        //1.1所属经营主体,所属公司,所属部门,查询人员的任职经历,最新的历史版本，承担组织,默认为人员所属公司，支持修改
        if (hrPerson != null){
            String employeeNumber = hrPerson.getString("number");
            long staffId = hrPerson.getLong("id");
            // 查找最新任职
            QFilter hrpiEmpposorgrelFilter = new QFilter("id", QCP.equals,staffId);
            DynamicObject hrpiEmpposorgrel = QueryServiceHelper.queryOne("hrpi_empposorgrel","id,company,adminorg,adminorg.org,position", hrpiEmpposorgrelFilter.toArray());


            int rowIndex = changeData.getRowIndex();
            if (hrpiEmpposorgrel != null){
                // 员工工号
                this.getModel().setValue("${ISV_FLAG}_peson_number",employeeNumber,rowIndex);

                //任职经历历史版本
                this.getModel().setValue("${ISV_FLAG}_employment_history",hrpiEmpposorgrel.getLong("id"),rowIndex);
                // 所属经营主体
                this.getModel().setValue("${ISV_FLAG}_per_business_entity",hrpiEmpposorgrel.getLong("adminorg.org"),rowIndex);
                // 所属公司
                this.getModel().setValue("${ISV_FLAG}_per_admin_company",hrpiEmpposorgrel.getLong("company"),rowIndex);
                // 所属部门-行政组织
                this.getModel().setValue("${ISV_FLAG}_admin_dept",hrpiEmpposorgrel.getLong("adminorg"),rowIndex);
                // 岗位
                this.getModel().setValue("${ISV_FLAG}_admin_post",hrpiEmpposorgrel.getLong("position"),rowIndex);
            }
            // 设置人员分配明细-承担组织
            this.updatePersonUnderTakeOrg(rowIndex);
        }
    }


    /**
     * 设置人员分配明细-承担组织
     * @param rowIndex
     */
    private void updatePersonUnderTakeOrg(int rowIndex){
        int lastIndex = rowIndex;
        DynamicObject dataEntity = this.getModel().getDataEntity(true);
        DynamicObjectCollection personEntry = dataEntity.getDynamicObjectCollection("${ISV_FLAG}_person_dis_entry");
        // 分录行对象
        DynamicObject rowObject = (DynamicObject) personEntry.get(lastIndex);
        // 上级单承担组织
        DynamicObject ptUndertakeOrg = dataEntity.getDynamicObject("${ISV_FLAG}_pt_undertake_org");
        // 新增分录时
        // ①默认带出本单“分配组织”在上级单对应的“承担组织”，若为空，则默认赋值分录行的“所属公司”
        // ②若本张分配单的“经营主体分配”为“是”，则此字段可编辑：行政组织类型为“子公司”及虚拟组织股份总部
        // 否则，不可编辑
        DynamicObject realUndertakeOrg = null;
        if(ptUndertakeOrg != null){
            realUndertakeOrg = ptUndertakeOrg;
        } else{
            realUndertakeOrg = getUndertakeOrg(dataEntity,rowObject,null,"${ISV_FLAG}_per_business_entity.id",rowObject.getDynamicObject("${ISV_FLAG}_per_admin_company"));
        }
        this.getModel().setValue("${ISV_FLAG}_undertake_org2",realUndertakeOrg,lastIndex);
    }

    /**
     * 设置组织分配明细-承担组织
     * @param rowIndex
     */
    private void updateOrgUnderTakeOrg(int rowIndex){
        int lastIndex = rowIndex;
        DynamicObject dataEntity = this.getModel().getDataEntity(true);
        DynamicObjectCollection personEntry = dataEntity.getDynamicObjectCollection("${ISV_FLAG}_dept_dis_entry");
        // 分录行对象
        DynamicObject rowObject = (DynamicObject) personEntry.get(lastIndex);
        // 上级单承担组织
        DynamicObject ptUndertakeOrg = dataEntity.getDynamicObject("${ISV_FLAG}_pt_undertake_org");
        // 新增分录时
        // ①默认带出本单“分配组织”在上级单对应的“承担组织”，若为空，则默认赋值分录行的“所属公司”
        // ②若本张分配单的“经营主体分配”为“是”，则此字段可编辑：行政组织类型为“子公司”及虚拟组织股份总部
        // 否则，不可编辑
        DynamicObject realUndertakeOrg = null;
        if(ptUndertakeOrg != null){
            realUndertakeOrg = ptUndertakeOrg;
