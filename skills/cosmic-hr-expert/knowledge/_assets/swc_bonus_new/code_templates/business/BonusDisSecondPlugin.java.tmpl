    /**
     * 计算总额
     * @param distributeDynamicObject
     */
    private void calcTotalMoney(DynamicObject distributeDynamicObject){
        // 分配统计
        // 人员分配-当前已分配总额
        BigDecimal personDistributeTotal = distributeDynamicObject.getDynamicObjectCollection("${ISV_FLAG}_person_dis_entry")
                .stream().filter(upper -> ! upper.getBoolean("${ISV_FLAG}_is_upper_dis"))
                .map(decimal -> decimal.getBigDecimal("${ISV_FLAG}_real_dis_decimal")).reduce(BigDecimal.ZERO, BigDecimal::add);
        // 人员分配-上级分配总额
        BigDecimal personUpperDistributeTotal = distributeDynamicObject.getDynamicObjectCollection("${ISV_FLAG}_person_dis_entry")
                .stream().filter(upper -> upper.getBoolean("${ISV_FLAG}_is_upper_dis"))
                .map(decimal -> decimal.getBigDecimal("${ISV_FLAG}_real_dis_decimal")).reduce(BigDecimal.ZERO, BigDecimal::add);
        // 组织分配-分配总额
        BigDecimal deptDistributeTotal = distributeDynamicObject.getDynamicObjectCollection("${ISV_FLAG}_dept_dis_entry")
                .stream().map(decimal -> decimal.getBigDecimal("${ISV_FLAG}_distribute_decimal")).reduce(BigDecimal.ZERO, BigDecimal::add);
        // 留存部门-当前已分配总额
        BigDecimal retentionTotal = distributeDynamicObject.getDynamicObjectCollection("${ISV_FLAG}_retention_entry")
                .stream().filter(upper -> ! upper.getBoolean("${ISV_FLAG}_is_upper"))
                .map(decimal -> decimal.getBigDecimal("${ISV_FLAG}_retention_decimal")).reduce(BigDecimal.ZERO, BigDecimal::add);
        // 留存部门-上级分配总额
        BigDecimal retentionUpperTotal = distributeDynamicObject.getDynamicObjectCollection("${ISV_FLAG}_retention_entry")
                .stream().filter(upper -> upper.getBoolean("${ISV_FLAG}_is_upper"))
                .map(decimal -> decimal.getBigDecimal("${ISV_FLAG}_retention_decimal")).reduce(BigDecimal.ZERO, BigDecimal::add);
        BigDecimal currentDistributeTotal = personDistributeTotal.add(deptDistributeTotal).add(retentionTotal);
        BigDecimal upperDistributeTotal = personUpperDistributeTotal.add(retentionUpperTotal);
        // 可分配总额
        BigDecimal enableDisTotal = distributeDynamicObject.getBigDecimal("${ISV_FLAG}_enable_distribute_tl");
        this.getModel().setValue("${ISV_FLAG}_current_dis_total", currentDistributeTotal); // 本次分配总金额
        this.getModel().setValue("${ISV_FLAG}_org_dis_total", deptDistributeTotal); // 组织分配总额
        this.getModel().setValue("${ISV_FLAG}_person_dis_total", personDistributeTotal); // 人员分配总额
        this.getModel().setValue("${ISV_FLAG}_rentention_dis_total", retentionTotal); // 部门留存总额
        this.getModel().setValue("${ISV_FLAG}_upper_dis_total", upperDistributeTotal); // 上级分配总额
        this.getModel().setValue("${ISV_FLAG}_money_total", enableDisTotal.add(upperDistributeTotal)); // 奖金总额=可分配总额+上级分配总额

        // 可分配总额
        BigDecimal availTotal2 = distributeDynamicObject.getBigDecimal("${ISV_FLAG}_enable_distribute_tl");
        // 本次分配
        BigDecimal currTotal2 = distributeDynamicObject.getBigDecimal("${ISV_FLAG}_current_dis_total");
        // 剩余未用金额
        this.getModel().setValue("${ISV_FLAG}_leave_total",availTotal2.subtract(currTotal2));
    }

    /**
     * >>值改变事件-组织人发生变化
     */
    private void valueChangeCreateStaffSelect(){
        // 组织人发生变化
        DynamicObject bill = this.getView().getModel().getDataEntity();
        DynamicObject deptPerson = bill.getDynamicObject("${ISV_FLAG}_dept_person");
        IDataModel model = this.getModel();
        if (deptPerson != null){
            DynamicObject position = deptPerson.getDynamicObject("position");
            model.setValue("${ISV_FLAG}_attribut_post",position);

            model.setValue("${ISV_FLAG}_attribut_dept",deptPerson.getDynamicObject("adminorg"));
            model.setValue("${ISV_FLAG}_attribut_company",deptPerson.getDynamicObject("company"));
        }else {
            model.setValue("${ISV_FLAG}_attribut_post",null);
            model.setValue("${ISV_FLAG}_attribut_dept",null);
            model.setValue("${ISV_FLAG}_attribut_company",null);
        }
    }

