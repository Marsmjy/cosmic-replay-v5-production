/**
 *
 * 奖金分配汇总审批插件，${ISV_FLAG}_bonus_approval_2nd
 *
 */
public class BonusDisSumAllPlugin extends AbstractBillPlugIn implements BeforeF7SelectListener, RowClickEventListener {
    private static final Log log = LogFactory.getLog(BonusDisSumAllPlugin.class);


    @Override
    public void entryRowClick(RowClickEvent evt) {
        IDataModel model = this.getModel();
        IFormView view = this.getView();
        int rowIndex = evt.getRow();
        EntryGrid entryGrid = (EntryGrid)evt.getSource();
        String entryKey = entryGrid.getEntryKey();
        if (rowIndex >= 0 && "${ISV_FLAG}_person_dis_entry".equals(entryKey)) {
            DynamicObjectCollection entryentity = model.getEntryEntity("${ISV_FLAG}_person_dis_entry");
            DynamicObject dynamicObject = entryentity.get(rowIndex);
            // 分配汇总单编码
            String disNo = dynamicObject.getString("${ISV_FLAG}_tdkw_distribute_no");
            if(HRStringUtils.isBlank(disNo)){
                throw new KDBizException("未找到分配汇总单编码");
            }
            DynamicObject bill = QueryServiceHelper.queryOne("${ISV_FLAG}_bonus_distribute_sum"
                    , "id,billno", new QFilter("billno", QCP.equals, disNo).toArray());
            long approvalId = ObjectUtils.isEmpty(bill) ? 0L : bill.getLong("id");
            if(approvalId != 0L){
                BonusUtil.openInfoBill(view, approvalId,"${ISV_FLAG}_bonus_distribute_sum",null);
            }
        }
    }

    @Override
    public void registerListener(EventObject e) {
        // 创建人信息过滤
        BasedataEdit deptPerson = this.getView().getControl("${ISV_FLAG}_dept_person");
        deptPerson.addBeforeF7SelectListener(this);
        EntryGrid entryGrid = this.getControl("${ISV_FLAG}_person_dis_entry");
        entryGrid.addRowClickListener(this);

        // 事件注册-发起组织
        BasedataEdit actionOrg = this.getView().getControl("${ISV_FLAG}_bill_belong_org");
        actionOrg.addBeforeF7SelectListener(this);
    }

    @Override
    public void beforeF7Select(BeforeF7SelectEvent beforeF7SelectEvent) {
        String name = beforeF7SelectEvent.getProperty().getName();
        ListShowParameter showParameter = (ListShowParameter) beforeF7SelectEvent.getFormShowParameter();
        switch (name){
            case "${ISV_FLAG}_dept_person":
                QFilter personFilter = new QFilter("id", QCP.equals, RequestContext.get().getCurrUserId());
                DynamicObject currentPerson = QueryServiceHelper.queryOne("bos_user", "id,number", personFilter.toArray());
                // 组织人过滤
                QFilter personOrgFilter = new QFilter("person.number",QCP.equals, currentPerson.getString("number"));
                showParameter.getListFilterParameter().getQFilters().add(personOrgFilter);
                break;
            case "${ISV_FLAG}_bill_belong_org":
                // 所属组织”、“发起组织”选择弹窗需要做过滤，仅保留行政“组织类型归属”为“公司”
                QFilter orgFilter30 = new QFilter("${ISV_FLAG}_administrative_org.number",QCP.in
                        , Arrays.asList("1020_S"));
                showParameter.getListFilterParameter().getQFilters().add(orgFilter30);
                // F7基础资料-组织树过滤
                this.filterOrgTreeByF7Limit(showParameter,orgFilter30);
                break;
            default:
                break;
        }
    }

    /**
     * >>F7基础资料-组织树过滤
     * @param showParameter
     * @param orgFilter
     */
    private void filterOrgTreeByF7Limit(ListShowParameter showParameter,QFilter orgFilter){
        // 过滤左树
        DynamicObjectCollection adminorgCollection = QueryServiceHelper.query("haos_adminorghr", "id,structlongnumber", orgFilter.toArray());
        List<String> orgList = adminorgCollection.stream().map(item -> item.getString("structlongnumber")).collect(Collectors.toList());
        List<String> structnumber = new ArrayList<>();
        for (String structlongnumber : orgList) {
            String[] split = structlongnumber.split("!");
            structnumber.addAll(Arrays.stream(split).collect(Collectors.toList()));
        }
        QFilter filter = new QFilter("structnumber",QCP.in,structnumber);
        DynamicObjectCollection orgTree = QueryServiceHelper.query("haos_adminorghr", "id", filter.toArray());
        showParameter.getCustomParams().put(TreeTemplateConstants.BIZ_QFILTER_KEY, new QFilter("adminorg.id", QCP.in, orgTree.stream().map(item -> item.getLong("id")).collect(Collectors.toSet())).toSerializedString());
    }

    @Override
    public void afterBindData(EventObject e) {
        // 默认设置创建人信息
        this.setCreatorDefault();
    }

    /**
     * 当单据已经保存，并以查看或修改模式打开时触发。此时，单据数据会从数据库加载
     * @param e
     */
    @Override
    public void afterLoadData(EventObject e) {
        super.afterLoadData(e);

    }

    /**
     * 当单据是全新创建时触发
     * @param e
     */
    @Override
    public void afterCreateNewData(EventObject e) {

    }

    /**
     * 值改变事件
     * @param e
     */
    @Override
    public void propertyChanged(PropertyChangedArgs e) {
        String name = e.getProperty().getName();
        ChangeData changeData = e.getChangeSet()[0];
        switch(name){
            case "${ISV_FLAG}_dept_person":
                this.valueChangeCreateStaffSelect();
                break;
            default:

                break;
        }

    }


    @Override
    public void beforeDoOperation(BeforeDoOperationEventArgs args) {
        super.beforeDoOperation(args);
        Object source = args.getSource();

    }

    @Override
    public void afterDoOperation(AfterDoOperationEventArgs afterDoOperationEventArgs) {
        Object source = afterDoOperationEventArgs.getSource();


    }




    /**
     * >>值改变事件-组织人发生变化
     */
    private void valueChangeCreateStaffSelect(){
        // 组织人发生变化
        DynamicObject bill = this.getView().getModel().getDataEntity();
        DynamicObject deptPerson = bill.getDynamicObject("${ISV_FLAG}_dept_person");
        IDataModel model = this.getModel();
        if (deptPerson != null){
            Long adminOrgId = deptPerson.getLong("adminorg.id");
            DynamicObject position = deptPerson.getDynamicObject("position");
            model.setValue("${ISV_FLAG}_attribut_post",position);

            QFilter filter = new QFilter("id",QCP.equals,adminOrgId);
            DynamicObject org = BusinessDataServiceHelper.loadSingle("haos_adminorghr", "id, ${ISV_FLAG}_admin_dept, company", filter.toArray());
            model.setValue("${ISV_FLAG}_attribut_dept",org.getDynamicObject("${ISV_FLAG}_admin_dept"));
            model.setValue("${ISV_FLAG}_attribut_company",org.getDynamicObject("company"));
        }else {
            model.setValue("${ISV_FLAG}_attribut_post",null);
            model.setValue("${ISV_FLAG}_attribut_dept",null);
            model.setValue("${ISV_FLAG}_attribut_company",null);
        }
    }



    /**
     * >>默认设置创建人信息
     */
    private void setCreatorDefault(){
        // 创建人员信息绑定
        DynamicObject deptPerson = this.getView().getModel().getDataEntity().getDynamicObject("${ISV_FLAG}_dept_person");
        if(deptPerson == null){
            // 组织人设置默认值
            QFilter personFilter = new QFilter("id", QCP.equals, RequestContext.get().getCurrUserId());
            DynamicObject currentPerson = QueryServiceHelper.queryOne("bos_user", "id,number", personFilter.toArray());
            QFilter filter = new QFilter("employee.empnumber", QCP.equals, currentPerson.getString("number"));
            filter.and(new QFilter("isdeleted",QCP.equals,"0"));
            DynamicObject empPosRel = BusinessDataServiceHelper.loadSingle("hrpi_empposorgrel", "id,adminorg,position,company", new QFilter[]{filter});
            if (Objects.nonNull(empPosRel)){
                this.getView().getModel().setValue("${ISV_FLAG}_dept_person",empPosRel);
                this.getView().updateView("${ISV_FLAG}_dept_person");
            }
        }
    }

}
