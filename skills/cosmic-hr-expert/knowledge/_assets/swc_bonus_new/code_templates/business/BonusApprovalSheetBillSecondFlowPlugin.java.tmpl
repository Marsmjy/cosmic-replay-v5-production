package ${ISV_FLAG}.swc.hsbm.biz.swc.plugin.form.${ISV_FLAG}_bonus_approval_sheet.second;

import kd.bos.bill.AbstractBillPlugIn;
import kd.bos.bill.BillOperationStatus;
import kd.bos.bill.BillShowParameter;
import kd.bos.bill.OperationStatus;
import kd.bos.context.RequestContext;
import kd.bos.dataentity.entity.DynamicObject;
import kd.bos.dataentity.entity.DynamicObjectCollection;
import kd.bos.entity.datamodel.IDataModel;
import kd.bos.entity.datamodel.events.ChangeData;
import kd.bos.entity.datamodel.events.PropertyChangedArgs;
import kd.bos.entity.operate.Submit;
import kd.bos.exception.KDBizException;
import kd.bos.form.control.EntryGrid;
import kd.bos.form.events.AfterDoOperationEventArgs;
import kd.bos.form.events.HyperLinkClickEvent;
import kd.bos.form.events.HyperLinkClickListener;
import kd.bos.form.field.BasedataEdit;
import kd.bos.form.field.events.BeforeF7SelectEvent;
import kd.bos.form.field.events.BeforeF7SelectListener;
import kd.bos.list.ListShowParameter;
import kd.bos.orm.query.QCP;
import kd.bos.orm.query.QFilter;
import kd.bos.servicehelper.BusinessDataServiceHelper;
import kd.bos.servicehelper.QueryServiceHelper;
import kd.hr.hbp.common.constants.org.TreeTemplateConstants;
import kd.hr.hbp.common.util.HRStringUtils;
import ${ISV_FLAG}.swc.hsbm.biz.swc.plugin.other.util.BonusUtil;

import java.util.ArrayList;
import java.util.Arrays;
import java.util.EventObject;
import java.util.List;
import java.util.stream.Collectors;

/**
 *
 * 奖金核定审批单据插件，${ISV_FLAG}_bonus_approval_flow
 *
 */
public class BonusApprovalSheetBillSecondFlowPlugin extends AbstractBillPlugIn implements BeforeF7SelectListener, HyperLinkClickListener {



    @Override
    public void registerListener(EventObject e) {
        // 创建人信息过滤
        BasedataEdit deptPerson = this.getView().getControl("${ISV_FLAG}_dept_person2");
        deptPerson.addBeforeF7SelectListener(this);
        EntryGrid deptEntry = this.getControl("${ISV_FLAG}_hd_details");
        deptEntry.addHyperClickListener(this);

        // 事件注册-发起组织
        BasedataEdit actionOrg = this.getView().getControl("${ISV_FLAG}_init_org");
        actionOrg.addBeforeF7SelectListener(this);
    }

    @Override
    public void beforeF7Select(BeforeF7SelectEvent beforeF7SelectEvent) {
        String name = beforeF7SelectEvent.getProperty().getName();
        ListShowParameter showParameter = (ListShowParameter) beforeF7SelectEvent.getFormShowParameter();
        switch (name){
            case "${ISV_FLAG}_dept_person2":
                QFilter personFilter = new QFilter("id", QCP.equals, RequestContext.get().getCurrUserId());
                DynamicObject currentPerson = QueryServiceHelper.queryOne("bos_user", "id,number", personFilter.toArray());
                // 组织人过滤
                QFilter personOrgFilter = new QFilter("employee.number",QCP.equals, currentPerson.getString("number"));
                personOrgFilter.and("businessstatus",QCP.equals,"1");
                showParameter.getListFilterParameter().getQFilters().add(personOrgFilter);
                break;
            case "${ISV_FLAG}_init_org":
                // 所属组织”、“发起组织”选择弹窗需要做过滤，仅保留行政“组织类型归属”为“公司”
                QFilter orgFilter30 = new QFilter("${ISV_FLAG}_administrative_org.number",QCP.in
                        , Arrays.asList("1020_S"));
                showParameter.getListFilterParameter().getQFilters().add(orgFilter30);
                // F7基础资料-组织树过滤
                this.filterOrgTreeByF7Limit(showParameter,orgFilter30);
                break;
            default:
                break;
        }
    }

    /**
     * >>F7基础资料-组织树过滤
     * @param showParameter
     * @param orgFilter
     */
    private void filterOrgTreeByF7Limit(ListShowParameter showParameter,QFilter orgFilter){
        // 过滤左树
        DynamicObjectCollection adminorgCollection = QueryServiceHelper.query("haos_adminorg", "id,structlongnumber", orgFilter.toArray());
        List<String> orgList = adminorgCollection.stream().map(item -> item.getString("structlongnumber")).collect(Collectors.toList());
        List<String> structnumber = new ArrayList<>();
        for (String structlongnumber : orgList) {
            String[] split = structlongnumber.split("!");
            structnumber.addAll(Arrays.stream(split).collect(Collectors.toList()));
        }
        QFilter filter = new QFilter("structnumber",QCP.in,structnumber);
        DynamicObjectCollection orgTree = QueryServiceHelper.query("haos_adminorg", "id", filter.toArray());
        showParameter.getCustomParams().put(TreeTemplateConstants.BIZ_QFILTER_KEY, new QFilter("adminorg.id", QCP.in, orgTree.stream().map(item -> item.getLong("id")).collect(Collectors.toSet())).toSerializedString());
    }

    /**
     * 值改变事件
     * @param e
     */
    @Override
    public void propertyChanged(PropertyChangedArgs e) {
        String name = e.getProperty().getName();
        ChangeData changeData = e.getChangeSet()[0];
        switch(name){
            case "${ISV_FLAG}_dept_person2":
                this.valueChangeCreateStaffSelect();
                break;
            default:
                break;
        }
    }

    @Override
    public void afterDoOperation(AfterDoOperationEventArgs afterDoOperationEventArgs) {
        Object source = afterDoOperationEventArgs.getSource();
        if (source instanceof Submit){
            BillShowParameter billShowParameter= (BillShowParameter)  this.getView().getFormShowParameter();
            billShowParameter.setBillStatus(BillOperationStatus.SUBMIT);
            this.getView().setStatus(OperationStatus.EDIT);

        }
    }


    /**
     * >>值改变事件-组织人发生变化
     */
    private void valueChangeCreateStaffSelect(){
        // 组织人发生变化
        DynamicObject bill = this.getView().getModel().getDataEntity();
        DynamicObject deptPerson = bill.getDynamicObject("${ISV_FLAG}_dept_person2");
        IDataModel model = this.getModel();
        if (deptPerson != null){
            DynamicObject position = deptPerson.getDynamicObject("position");
            model.setValue("${ISV_FLAG}_attribut_post2",position);
            model.setValue("${ISV_FLAG}_attribut_dept2",deptPerson.getDynamicObject("adminorg"));
            model.setValue("${ISV_FLAG}_attribut_company2",deptPerson.getDynamicObject("company"));
            model.setValue("${ISV_FLAG}_init_org",deptPerson.getDynamicObject("company"));
        }else {
            model.setValue("${ISV_FLAG}_attribut_post2",null);
            model.setValue("${ISV_FLAG}_attribut_dept2",null);
            model.setValue("${ISV_FLAG}_attribut_company2",null);
            model.setValue("${ISV_FLAG}_attribut_company2",null);
        }
    }

    @Override
    public void hyperLinkClick(HyperLinkClickEvent hyperLinkClickEvent) {
        String fieldName = hyperLinkClickEvent.getFieldName();
        if (HRStringUtils.equals(fieldName,"${ISV_FLAG}_billno")) {
            int rowIndex = hyperLinkClickEvent.getRowIndex();
            long billId = this.getModel().getDataEntity(true).getLong("id");
            DynamicObject bill = BusinessDataServiceHelper.loadSingle(billId, "${ISV_FLAG}_bonus_approval_flow");
            String planBillNo = bill.getDynamicObjectCollection("${ISV_FLAG}_hd_details").get(rowIndex).getString("${ISV_FLAG}_billno");;
            QFilter bonusFilter = new QFilter("billno", QCP.equals, planBillNo);
            DynamicObject plan = QueryServiceHelper.queryOne("${ISV_FLAG}_bonus_approval_2nd", "id,billno", bonusFilter.toArray());
            if(plan == null){
                throw new KDBizException("未找到当前核定单");
            }
            BonusUtil.openInfoBill(this.getView(),plan.getLong("id"),"${ISV_FLAG}_bonus_approval_2nd",null);
        }
    }

}
