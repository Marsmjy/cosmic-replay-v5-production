    @Override
    public void afterDoOperation(AfterDoOperationEventArgs afterDoOperationEventArgs) {
        Object source = afterDoOperationEventArgs.getSource();
        if (source instanceof Save){

        }

        if (source instanceof Submit){
            BillShowParameter billShowParameter= (BillShowParameter)  this.getView().getFormShowParameter();
            billShowParameter.setBillStatus(BillOperationStatus.SUBMIT);
            this.getView().setStatus(OperationStatus.EDIT);

        }

        String operateKey = afterDoOperationEventArgs.getOperateKey();
        if("donothing_push_check".equals(operateKey)){
            OperationResult operationResult = afterDoOperationEventArgs.getOperationResult();
            if(operationResult.isSuccess()){
                Long sumApprovalId = null;
                List<Object> successPkIds = afterDoOperationEventArgs.getOperationResult().getSuccessPkIds();
                if(!CollectionUtils.isEmpty(successPkIds)){
                    Object successPkId = successPkIds.get(0);
                    DynamicObject oneOfSuccessDate = QueryServiceHelper.queryOne(BonusUtil.AP_CHECK_DETAIL_ID, "${ISV_FLAG}_check_summary", new QFilter("id", QCP.equals, successPkId).toArray());
                    sumApprovalId = Optional.ofNullable(oneOfSuccessDate).map(a -> a.getLong("${ISV_FLAG}_check_summary")).orElse(null);
                }
                if(sumApprovalId != null){
                    // 打开奖金核定审批单的页面
                    BonusUtil.openBill(this.getView(),sumApprovalId,BonusUtil.AP_CHECK_SUM_ID,null);
                }
            }
        }

        if ("submiteffect".equals(operateKey) || "donothing_push_check".equals(operateKey)){
            OperationResult operationResult = afterDoOperationEventArgs.getOperationResult();
            if(operationResult.isSuccess()){
                this.getView().invokeOperation("refresh");
            }
        }
    }


    /**
     * >>组织核定明细-行政组织发生变化
     * @param changeData
     */
    private void adminOrgChange(ChangeData changeData) {
        //组织核定信息单据体中行政组织发生变化
        DynamicObject adminorg =(DynamicObject) changeData.getNewValue();
        if (adminorg != null){
            //1.带出所选行政组织所属的经营主体
            //1.1经营主体
            DynamicObject haosCompanytype = adminorg.getDynamicObject("org");
            int rowIndex = changeData.getRowIndex();
            this.getModel().setValue("${ISV_FLAG}_business_entity",haosCompanytype,rowIndex);
            List<Long> orgIds = new ArrayList<>();
            long orgId = adminorg.getLong("id");
            orgIds.add(orgId);
            //2默认带出所选组织负责人
            Map<Long, List<Map<String, Object>>> personIds = HAOSServiceHelper.queryPastChargeByOrgId(orgIds, TimeServiceHelper.now());
            // 一个组织出现多个负责人的时候取哪一个
            if (!personIds.isEmpty() && personIds.containsKey(orgId)){
                List<Map<String, Object>> personMap = personIds.get(orgId);
                Map<String, Object> map = personMap.get(0);
                if (!map.isEmpty() && map.containsKey("person")) {
                    this.getModel().setValue("${ISV_FLAG}_subordinate", Long.valueOf(String.valueOf(map.get("person"))), rowIndex);
                }
            }
        }
    }

