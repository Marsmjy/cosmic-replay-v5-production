    /**
     * >>根据奖金计划，在核定单单据中填写相关奖金信息
     */
    private void setBonusPlanChangeFormItemValue(DynamicObject bonusPlan) {
        //1关联计划信息

        // 计划编号
        this.getModel().setValue("${ISV_FLAG}_plan_no",bonusPlan.getString("billno"));
        // 计划名称
        this.getModel().setValue("${ISV_FLAG}_plan_name",bonusPlan.getString("${ISV_FLAG}_plan_name"));
        // 奖金分类
        this.getModel().setValue("${ISV_FLAG}_plan_category",bonusPlan.getString("${ISV_FLAG}_bonus_types"));
        // 奖金项目
        this.getModel().setValue("${ISV_FLAG}_plan_project",bonusPlan.getString("${ISV_FLAG}_bonus_items"));
        // 生效日期
        this.getModel().setValue("${ISV_FLAG}_plan_date_sx",bonusPlan.getString("${ISV_FLAG}_effective_date"));
        // 失效日期
        this.getModel().setValue("${ISV_FLAG}_plan_date_snx",bonusPlan.getString("${ISV_FLAG}_expiring_date"));
        // 计划总额
        this.getModel().setValue("${ISV_FLAG}_plan_total",bonusPlan.getString("${ISV_FLAG}_plan_money"));
        // 适用范围
        this.setsCopeUse(bonusPlan);
        // 个性化奖金
        String awardPlan = bonusPlan.getString("${ISV_FLAG}_personal_rewards");
        this.getModel().setValue("${ISV_FLAG}_plan_award",BonusWriteBackUtil.mathcValue(awardPlan));
        // 核定基本信息-是否个性化奖金
        this.getModel().setValue("${ISV_FLAG}_personalization",awardPlan);
        // 计划说明
        this.getModel().setValue("${ISV_FLAG}_plan_describle",bonusPlan.getString("${ISV_FLAG}_notes"));
        // 组织人
        this.getModel().setValue("${ISV_FLAG}_plan_creator",bonusPlan.getString("${ISV_FLAG}_dept_person"));
        // 所在公司
        this.getModel().setValue("${ISV_FLAG}_plan_company",bonusPlan.getString("${ISV_FLAG}_attribut_company"));
        // 所在部门
        this.getModel().setValue("${ISV_FLAG}_plan_dept",bonusPlan.getString("${ISV_FLAG}_attribut_dept"));
        // 所在岗位
        this.getModel().setValue("${ISV_FLAG}_plan_post",bonusPlan.getString("${ISV_FLAG}_attribut_post"));


        //2核定基本信息

        // 奖金类型
