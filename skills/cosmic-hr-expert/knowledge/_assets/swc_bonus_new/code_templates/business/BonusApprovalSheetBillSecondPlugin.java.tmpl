    /**
     * 值改变事件
     * @param e
     */
    @Override
    public void propertyChanged(PropertyChangedArgs e) {
        String name = e.getProperty().getName();
        ChangeData changeData = e.getChangeSet()[0];
        switch(name){
            case "${ISV_FLAG}_plan_bill_id":
                // 使用范围类型的改变
                //1.奖金计划id
                long bonusPlanId =  Long.parseLong((String)changeData.getNewValue());
                DynamicObject bonusPlan = queryBonusPlanById(bonusPlanId);
                //2.设置表单其他信息
                this.setBonusPlanChangeFormItemValue(bonusPlan);
                break;
            case "${ISV_FLAG}_cost_duty":
                // 值改变事件-单选成本承担方式
                this.valueChangeActionCostDuty(true);
                break;
            case "${ISV_FLAG}_admin_org":
                // 组织核定明细-行政组织发生变化
                this.adminOrgChange(changeData);
                break;
            case "${ISV_FLAG}_employee_name":
                // 人员核定明细-新选择了员工
                this.employeeChange(changeData);
                break;
            case "${ISV_FLAG}_admin_org_keep":
                // 留存部门经费-新选择了行政组织
                this.adminOrgKeepChange(changeData);
                break;
            case "${ISV_FLAG}_admin_org11":
                // 留存奖金池-新选择了行政组织
                this.keepPoolChange(changeData);
                break;
            case "${ISV_FLAG}_subordinate":
                // 若自己选择组织分配人，则将分配人转换成用户赋值到用户字段
                this.subordinateChange(changeData);
                break;
            case "${ISV_FLAG}_dept_person":
                this.valueChangeCreateStaffSelect();
                break;
            case "${ISV_FLAG}_bpsm":
                // 流程单号/发文文号/制度文件编号设置
                this.bpsmChange();
                break;
            case "${ISV_FLAG}_approval_total":
                // 核定总额改变
                this.operationAmount();
                break;
            default:

                break;
        }
        //计算核算金额
        if(getEntriesAmountSumRelations().stream().filter(item ->item.getEntriesItemKey().contains(name)).count() > 0l){
            operationAmount();
        }
        // 指定承担组织  或 单据所属组织 值改变事件监听
        // 分录成本承担组织赋值监听值改变事件key
        // 成本承担方式枚举、指定承担组织、单据所属组织、组织核定明细-行政组织发生变化、人员核定明细-新选择了员工、留存部门经费-新选择了行政组织、留存奖金池-新选择了行政组织
        Set<String> entriesAmountUndertakeKeys = Stream.of("${ISV_FLAG}_cost_duty"
                ,"${ISV_FLAG}_cost_duty_org"
                ,"${ISV_FLAG}_belong_to_org"
                ,"${ISV_FLAG}_admin_org"
                ,"${ISV_FLAG}_employee_name"
                ,"${ISV_FLAG}_admin_org_keep"
                ,"${ISV_FLAG}_admin_org11"
        ).collect(Collectors.toSet());
        if(entriesAmountUndertakeKeys.contains(name)){
            // 设置分录中的奖金成本-承担组织
            int rowIndex = changeData.getRowIndex();
            String entryKey = null;
            List<EntriesAmountSumRelation> entriesAmountSumRelationList = getEntriesAmountSumRelations();
            if("${ISV_FLAG}_admin_org".equals(name)){
                // 组织核定-行政组织
                entryKey = entriesAmountSumRelationList.get(0).getEntriesKey();
            } else if("${ISV_FLAG}_employee_name".equals(name)){
                // 人员核定-员工
                entryKey = entriesAmountSumRelationList.get(1).getEntriesKey();
            } else if("${ISV_FLAG}_admin_org_keep".equals(name)){
                // 留存部门-行政组织
                entryKey = entriesAmountSumRelationList.get(2).getEntriesKey();
            } else if("${ISV_FLAG}_admin_org11".equals(name)){
                // 留存奖金池-行政组织
                entryKey = entriesAmountSumRelationList.get(3).getEntriesKey();
            }
            this.setEntriesAmountUndertakeOrg(entryKey,rowIndex);
        }
    }


