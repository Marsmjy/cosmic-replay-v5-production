    /**
     * >>设置分录中的奖金成本-承担组织
     * @param entryChangeKey 值改变-分录key
     * @param rowChangeIndex 值改变-分录行号
     */
    private void setEntriesAmountUndertakeOrg(String entryChangeKey,int rowChangeIndex){
        DynamicObject bill = this.getModel().getDataEntity();
        // 成本承担 枚举
        String newValue = bill.getString("${ISV_FLAG}_cost_duty");
        // 发起方承担，找单据所属组织
        DynamicObject dataEntity = this.getModel().getDataEntity(true);
        // 遍历分录
        for(EntriesAmountSumRelation relation: getEntriesAmountSumRelations()){
            // 当前分录标识
            String currEntriesKey = relation.getEntriesKey();
            if(HRStringUtils.isNotBlank(entryChangeKey) && !currEntriesKey.equals(entryChangeKey)){
                // 正在改分录某行的值但不是当前分录-跳过
                continue;
            }
            DynamicObjectCollection perDetailEntry = dataEntity.getDynamicObjectCollection(relation.getEntriesKey());
            for (int rowIndex = 0; rowIndex < perDetailEntry.size(); rowIndex++) {
                if(HRStringUtils.isNotBlank(entryChangeKey) && rowChangeIndex != rowIndex){
                    // 正在改分录某行的值但不是当前行-跳过
                    continue;
                }
                // 分录行对象
                DynamicObject rowObject = (DynamicObject) perDetailEntry.get(rowIndex);
                // 分录承担组织赋值的源组织
                DynamicObject sourceOrg = getSourceOrg(newValue,dataEntity,rowObject,currEntriesKey);

                // 给分录承担组织赋值及设置禁用属性
                this.getModel().setValue(relation.getUnderTakeOrgKey(),sourceOrg,rowIndex);
                this.getView().setEnable(false,rowIndex,relation.getUnderTakeOrgKey());
            }
        }
    }

    /**
     * 获取成本承担组织-界面操作
     * @param newValue 成本承担方式
     * @param dataEntity
     * @param rowObject 行记录对象
     * @param currEntriesKey 当前分录标识
     * @return
     */
    private DynamicObject getSourceOrg(String newValue,DynamicObject dataEntity,DynamicObject rowObject,String currEntriesKey){
        DynamicObject sourceOrg = null;
        if (newValue == null){
            return null;
        }
        switch (newValue){
            case "A":
                // 发起方承担
                // 选择发起方承担时核定明细均默认为单据所属组织
                sourceOrg = dataEntity.getDynamicObject("${ISV_FLAG}_belong_to_org");
                break;
            case "B":
                // 受奖方承担
                // 选择受奖方承担时核定明细均默认为核定组织/人员主任职所属公司
                List<EntriesAmountSumRelation> entriesAmountSumRelationList = getEntriesAmountSumRelations();
                if(entriesAmountSumRelationList.get(0).getEntriesKey().equals(currEntriesKey)) {
                    // 组织核定-经营主体判断
                    DynamicObject adminOrg = rowObject.getDynamicObject("${ISV_FLAG}_admin_org");
                    if(adminOrg != null){
                        DynamicObject orgTypeObject = adminOrg.getDynamicObject("adminorgtype");
                        if(orgTypeObject != null && "1025_S".equals(orgTypeObject.getString("number"))){
                            // 首先判断核定的行政组织类型是否为经营主体，若为经营主体，则承担组织为空
                        } else {
                            // 组织核定-选择受奖方承担时默认为核定组织所属公司
                            sourceOrg = getCompanyFromEntryRow(rowObject,"${ISV_FLAG}_admin_org");
                        }
                    }
                } else if (entriesAmountSumRelationList.get(1).getEntriesKey().equals(currEntriesKey)) {
                    // 人员核定-选择受奖方承担时默认为核定人员所属公司
                    sourceOrg = rowObject.getDynamicObject("${ISV_FLAG}_per_admin_company");
                } else if (entriesAmountSumRelationList.get(2).getEntriesKey().equals(currEntriesKey)) {
                    // 留存部门经费-默认为核定组织所属公司
                    sourceOrg = getCompanyFromEntryRow(rowObject,"${ISV_FLAG}_admin_org_keep");
                } else if (entriesAmountSumRelationList.get(3).getEntriesKey().equals(currEntriesKey)) {
                    // 留存奖金池-默认为核定组织所属公司
                    sourceOrg = getCompanyFromEntryRow(rowObject,"${ISV_FLAG}_admin_org11");
                }
                break;
            case "C":
                // 指定承担
                // 选择指定承担时，核定明细均默认为指定的成本承担组织
                sourceOrg = dataEntity.getDynamicObject("${ISV_FLAG}_cost_duty_org");
                break;
            default:

                break;
        }
        return sourceOrg;
    }

