        private EntriesAmountSumRelation(String entriesKey, String entriesItemKey, String sumTargetKey,String underTakeOrgKey){
            this.entriesKey = entriesKey;
            this.entriesItemKey = entriesItemKey;
            this.sumTargetKey = sumTargetKey;
            this.underTakeOrgKey = underTakeOrgKey;
        }

        public String getEntriesKey() {
            return entriesKey;
        }

        public void setEntriesKey(String entriesKey) {
            this.entriesKey = entriesKey;
        }

        public String getEntriesItemKey() {
            return entriesItemKey;
        }

        public void setEntriesItemKey(String entriesItemKey) {
            this.entriesItemKey = entriesItemKey;
        }

        public String getSumTargetKey() {
            return sumTargetKey;
        }

        public void setSumTargetKey(String sumTargetKey) {
            this.sumTargetKey = sumTargetKey;
        }

        public String getUnderTakeOrgKey() {
            return underTakeOrgKey;
        }

        public void setUnderTakeOrgKey(String underTakeOrgKey) {
            this.underTakeOrgKey = underTakeOrgKey;
        }
    }

