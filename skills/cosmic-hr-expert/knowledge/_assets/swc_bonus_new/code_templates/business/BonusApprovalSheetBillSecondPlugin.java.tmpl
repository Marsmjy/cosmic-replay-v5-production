    /**
     * >>计算金额
     */
    private void operationAmount() {
        BigDecimal sumAllAmount = BigDecimal.ZERO;
        // 遍历 四个分录金额数据汇总赋值
        for(EntriesAmountSumRelation itemRelation: getEntriesAmountSumRelations()){
            DynamicObjectCollection currentEntry = this.getModel().getDataEntity(true)
                    .getDynamicObjectCollection(itemRelation.getEntriesKey());
            Optional<BigDecimal> checkAmount = currentEntry.stream().map(item ->
                    item.getBigDecimal(itemRelation.getEntriesItemKey())).reduce(BigDecimal::add);
            BigDecimal sumAmount = checkAmount.orElse(BigDecimal.ZERO);
            // 核定统计-核定组织总额赋值
            this.getModel().setValue(itemRelation.getSumTargetKey(),sumAmount);
            sumAllAmount = sumAllAmount.add(sumAmount);
        }
        this.getModel().setValue("${ISV_FLAG}_currtotal",sumAllAmount);
        // 核定基本信息-核定总额（元）
        BigDecimal approvalTotal = this.getModel().getDataEntity(true).getBigDecimal("${ISV_FLAG}_approval_total");
        // 剩余未用金额
        this.getModel().setValue("${ISV_FLAG}_leave_total",approvalTotal.subtract(sumAllAmount));
    }

