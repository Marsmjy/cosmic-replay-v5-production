    private void addCardEntryData(CardEntry cardEntry, int index, String dataKey, Map<String, Object> dataVal) {
        Map mapNewNumber = new HashMap<>();
        mapNewNumber.put(dataKey, dataVal);
        cardEntry.setCustomProperties(cardEntry.getKey(), index, mapNewNumber);
    }

