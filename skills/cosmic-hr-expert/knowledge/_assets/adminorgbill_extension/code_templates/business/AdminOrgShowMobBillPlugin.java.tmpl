    static class OrgChgBillMobileBo {
        /**
         * flex区域标识
         */
        private String contentFlexCoin;
        /**
         * 卡片分录标识
         */
        private String entryCoin;
        /**
         * 变动类型编码
         */
        private String changeTypeNumber;

        OrgChgBillMobileBo(String contentFlexCoin, String entryCoin, String changeTypeNumber) {
            this.contentFlexCoin = contentFlexCoin;
            this.entryCoin = entryCoin;
            this.changeTypeNumber = changeTypeNumber;
        }

        public String getContentFlexCoin() {
            return contentFlexCoin;
        }

        public void setContentFlexCoin(String contentFlexCoin) {
            this.contentFlexCoin = contentFlexCoin;
        }

        public String getEntryCoin() {
            return entryCoin;
        }

        public void setEntryCoin(String entryCoin) {
            this.entryCoin = entryCoin;
        }

        public String getChangeTypeNumber() {
            return changeTypeNumber;
        }

        public void setChangeTypeNumber(String changeTypeNumber) {
            this.changeTypeNumber = changeTypeNumber;
        }
    }

    static class EntryChgBo {
        /**
