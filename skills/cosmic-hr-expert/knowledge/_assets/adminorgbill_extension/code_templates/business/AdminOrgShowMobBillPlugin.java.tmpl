public class AdminOrgShowMobBillPlugin extends AbstractMobBillPlugIn {

    private static final Log Logger = LogFactory.getLog(AdminOrgShowMobBillPlugin.class);

    //变动类型为haos_orgchangetype实体中的数据
    private List<OrgChgBillMobileBo> entryType2ChangeType = new ArrayList() {
        {
            this.add(new OrgChgBillMobileBo("${ISV_FLAG}_add", "entryentity_add", "1010_S"));
            this.add(new OrgChgBillMobileBo("${ISV_FLAG}_parent", "entryentity_parent", "1020_S"));
            this.add(new OrgChgBillMobileBo("${ISV_FLAG}_info", "entryentity_info", "1030_S"));
            this.add(new OrgChgBillMobileBo("${ISV_FLAG}_disable", "entryentity_disable", "1040_S"));
        }
    };


    public void afterBindData(EventObject e) {
        super.afterBindData(e);
        this.updateTabPageText();
    }


    /**
     * @description: 渲染卡片分录数据
     * @param: []
     * @return: void
     * @author ningjie
     * @date: 2025/8/12 10:21
     */
    private void updateTabPageText() {

        Long billId = this.getModel().getDataEntity().getLong("id");
        QFilter billIdFilter = new QFilter("billid", "=", billId);
        Set<String> changeTypeNumberSet = entryType2ChangeType.stream().map(OrgChgBillMobileBo::getChangeTypeNumber).collect(Collectors.toSet());
        QFilter changeTypeFilter = new QFilter("changetype.number", "in", changeTypeNumberSet);
        HRBaseServiceHelper batchOrgEntityHelper = new HRBaseServiceHelper("homs_batchorgentity");
        //查询当前单据且在需要展示的变动类型数据
        DynamicObject[] batchOrgEntryEntityDynArr = batchOrgEntityHelper.loadDynamicObjectArray(new QFilter[]{billIdFilter, changeTypeFilter});
        if (ObjectUtils.isEmpty(batchOrgEntryEntityDynArr)) return;

        Map<String, List<DynamicObject>> entryMap =
                Arrays.stream(batchOrgEntryEntityDynArr).collect(Collectors.groupingBy(data -> data.getString("changetype.number")));

        entryType2ChangeType.stream().forEach(data -> {
            List<DynamicObject> entryData = entryMap.get(data.getChangeTypeNumber());
            dealChangeTypeData(data, entryData);
        });

    }

    /**
     * @description: 数据处理
     * @param: [orgChgBillMobileBo, entryData]
     * @return: void
     * @author ningjie
     * @date: 2025/8/12 10:40
     */
    private void dealChangeTypeData(OrgChgBillMobileBo orgChgBillMobileBo, List<DynamicObject> entryData) {
        //如果此类型分录数据为空，则隐藏此分录，如果有数据则显示
        this.getView().setVisible(!ObjectUtils.isEmpty(entryData), orgChgBillMobileBo.getContentFlexCoin());

        if (ObjectUtils.isEmpty(entryData)) return;
        //渲染各个变动类型分录数据
        switch (orgChgBillMobileBo.changeTypeNumber) {
            //新增
            case "1010_S":
                this.showAddEntryData(orgChgBillMobileBo, entryData);
                break;
            //调整上级
            case "1020_S":
                this.showParentEntryData(orgChgBillMobileBo, entryData);
                break;
            //信息变更
            case "1030_S":
                this.showInfoEntryData(orgChgBillMobileBo, entryData);
                break;
            //禁用
            case "1040_S":
                this.showDisabledEntryData(orgChgBillMobileBo, entryData);
                break;
            default:
                break;
        }

    }

    /**
     * @description: 展示组织新增分录数据
     * @param: [orgChgBillMobileBo, entryData]
     * @return: void
     * @author ningjie
     * @date: 2025/8/12 14:35
     */
    private void showAddEntryData(OrgChgBillMobileBo orgChgBillMobileBo, List<DynamicObject> entryData) {

        CardEntry cardEntry = this.getControl(orgChgBillMobileBo.getEntryCoin());

        //设置分录title中的数量值
        Label titleLabel = this.getControl("${ISV_FLAG}_addlablenum");
        titleLabel.setText("（" + entryData.size() + "）");

        entryData.stream().forEach(dynamicObject -> {

            int index = this.getModel().createNewEntryRow(orgChgBillMobileBo.getEntryCoin());

            this.getModel().setValue("add_name", dynamicObject.getString("name"), index);

            addCardEntryData(cardEntry, index, "${ISV_FLAG}_add_number", ImmutableBiMap.of("text", dynamicObject.getString("number")));

            addCardEntryData(cardEntry, index, "${ISV_FLAG}_add_adminorgtype", ImmutableBiMap.of("text", dynamicObject.getString("adminorgtype") == null ? "-" : dynamicObject.getString("adminorgtype.name")));

            addCardEntryData(cardEntry, index, "${ISV_FLAG}_add_parentorg", ImmutableBiMap.of("text", dynamicObject.getString("parentorg") == null ? "-" : dynamicObject.getString("parentorg.name")));

            addCardEntryData(cardEntry, index, "${ISV_FLAG}_add_establishmentdat", ImmutableBiMap.of("text", dynamicObject.getString("establishmentdate") == null ? "-" : dynamicObject.getString("establishmentdate")));

            addCardEntryData(cardEntry, index, "${ISV_FLAG}_add_changedescriptio", ImmutableBiMap.of("text", dynamicObject.getString("changedescription") == null ? "-" : dynamicObject.getString("changedescription")));

        });

    }

    /**
     * @description: 展示调整上级分录信息
     * @param: [orgChgBillMobileBo, entryData]
     * @return: void
     * @author ningjie
     * @date: 2025/8/12 14:36
     */
    private void showParentEntryData(OrgChgBillMobileBo orgChgBillMobileBo, List<DynamicObject> entryData) {

        CardEntry cardEntry = this.getControl(orgChgBillMobileBo.getEntryCoin());

        //设置分录title中的数量值
        Label titleLabel = this.getControl("${ISV_FLAG}_parentlablenum");
        titleLabel.setText("（" + entryData.size() + "）");

        // 查询所有组织当前版本对应的历史版本id
        Set<Long> orgHisDataIdSet = entryData.stream().map(data -> data.getLong("${ISV_FLAG}_chgsourcevid")).collect(Collectors.toSet());
        DynamicObject[] orgDataArr = OrgBatchBillInfoHelper.getAllDataByIdSet(orgHisDataIdSet);
        Map<Long, DynamicObject> hisOrgMap =
                Arrays.stream(orgDataArr).collect(Collectors.toMap(data -> data.getLong("id"), data -> data, (v1, v2) -> v2));


        entryData.stream().forEach(dynamicObject -> {

            int index = this.getModel().createNewEntryRow(orgChgBillMobileBo.getEntryCoin());

            this.getModel().setValue("parent_name", dynamicObject.getString("name"), index);

            addCardEntryData(cardEntry, index, "${ISV_FLAG}_parent_number", ImmutableBiMap.of("text", dynamicObject.getString("number")));

            addCardEntryData(cardEntry, index, "${ISV_FLAG}_parent_adminorgtype", ImmutableBiMap.of("text", dynamicObject.getString("adminorgtype") == null ? "-" : dynamicObject.getString("adminorgtype.name")));

            addCardEntryData(cardEntry, index, "${ISV_FLAG}_parent_parentorg", ImmutableBiMap.of("text", dynamicObject.getString("parentorg") == null ? "-" : dynamicObject.getString("parentorg.name")));

            addCardEntryData(cardEntry, index, "${ISV_FLAG}_parent_establishment", ImmutableBiMap.of("text", dynamicObject.getString("establishmentdate") == null ? "-" : dynamicObject.getString("establishmentdate")));

            addCardEntryData(cardEntry, index, "${ISV_FLAG}_parent_changedescrip", ImmutableBiMap.of("text", dynamicObject.getString("changedescription") == null ? "-" : dynamicObject.getString("changedescription")));

            Long vId = dynamicObject.getLong("${ISV_FLAG}_chgsourcevid");
            if (hisOrgMap.get(vId) == null) return;
            DynamicObject org = hisOrgMap.get(vId);

            //展示变更前后对比信息
            showParentChgEntryData(cardEntry, index, dynamicObject, org);

        });

    }

