    /**
     * 获取最近的组织结构编号
     */
    private String getClosestOrgStructNumber(String structNumber, String structlongnumber, Set<String> orgStructNumbers) {
        if (!orgStructNumbers.contains(structNumber)) {
            String[] split = structlongnumber.split("!");

            for (int j = split.length - 1; j > 0; j--) {
                if (orgStructNumbers.contains(split[j])) {
                    structNumber = split[j];
                    break;
                }
            }
        }
        return structNumber;
    }

    /**
     * 向上级组织汇总人数
     */
    private void aggregateToParentOrgs(List<DynamicObject> bzObjs, Map<String, Integer> countMap, String hierarchy) {
        int level = Integer.valueOf(hierarchy);
        Map<String, List<DynamicObject>> objlevelMap = new HashMap<>();

        for (DynamicObject bzObj : bzObjs) {
            String levelstr = bzObj.getString("${ISV_FLAG}_layer");
            if (levelstr != null && !levelstr.isEmpty()) {
                List<DynamicObject> bzlist = new ArrayList<>();
                if (objlevelMap.containsKey(levelstr)) {
                    bzlist = objlevelMap.get(levelstr);
                }
                bzlist.add(bzObj);
                objlevelMap.put(levelstr, bzlist);
            }
        }

        for (int j = level; j > 1; j--) {
            List<DynamicObject> bzlist = objlevelMap.get(String.valueOf(j));
            if (bzlist == null || bzlist.size() == 0) {
                continue;
            }
            for (DynamicObject bz : bzlist) {
                String key = bz.getString("${ISV_FLAG}_key");
                // jl-修改
                DynamicObject bz_adminorg = bz.getDynamicObject("${ISV_FLAG}_bz_adminorg" + (j - 1));
                if (bz_adminorg == null) {
                    continue;
                }
                String parentornstruct = bz_adminorg.getString("structnumber");
                String adminorgstruct = bz.getDynamicObject("adminorg").getString("structnumber");

                String parentkey = key.replace(adminorgstruct, parentornstruct);
                Integer detailsize = countMap.get(key);
                Integer parentydetailsize = countMap.get(parentkey);
                if (parentydetailsize == null) {
                    parentydetailsize = 0;
                }
                if (detailsize == null) {
                    detailsize = 0;
                }
                parentydetailsize = parentydetailsize + detailsize;
                countMap.put(parentkey, parentydetailsize);
            }
        }
    }

    /**
     * 更新编制对象的实际人数
     */
    private void updateBillActualCount(List<DynamicObject> bzObjs, Map<String, Integer> countMap) {
        for (DynamicObject bzObj : bzObjs) {
            // 末级组织
            String key = bzObj.getString("${ISV_FLAG}_key");
            // 岗位属性
            String property = kd.bos.util.StringUtils.isEmpty(bzObj.getString("${ISV_FLAG}_bz_jobproperty")) ? "" : bzObj.getString("${ISV_FLAG}_bz_jobproperty");
            // 用工关系类型
            String type = kd.bos.util.StringUtils.isEmpty(bzObj.getString("${ISV_FLAG}_bz_laborreltype")) ? "" : bzObj.getString("${ISV_FLAG}_bz_laborreltype");
            Integer detailsize = countMap.get(key);

            // 实际人数
            if (detailsize == null) {
                bzObj.set("${ISV_FLAG}_bz_actual", 0);
            } else {
                // 人员明细
                bzObj.set("${ISV_FLAG}_bz_actual", detailsize);
            }
        }
    }

    /**
     * 批量数据容器类
     */
    private static class BatchData {
        Map<Object, List<DynamicObject>> groupByPlanMonthMap;
        Map<String, List<Long>> orgListMap;
        Map<String, List<DynamicObject>> adminByOrgMap;

        public BatchData(Map<Object, List<DynamicObject>> groupByPlanMonthMap,
                         Map<String, List<Long>> orgListMap,
                         Map<String, List<DynamicObject>> adminByOrgMap) {
            this.groupByPlanMonthMap = groupByPlanMonthMap;
            this.orgListMap = orgListMap;
            this.adminByOrgMap = adminByOrgMap;
        }
    }



    /**
     *
     * @param orgNumberList  月度编制计划中【编制规划单位】编码集合
     * @return
     */
    private Map<String, List<Long>>  getOrgList(Set<String> orgNumberList) {
        //获取当前子集团下所选层级的行政组织
        QFilter orgQFilter = new QFilter("datastatus", QCP.equals, "1")
                .and("org.number", QCP.in, orgNumberList)
                .and("enable", QCP.equals, "1")
                .and("iscurrentversion", QCP.equals, "1");

        return Arrays.stream(BusinessDataServiceHelper.load("haos_adminorg",
                        "id,org.number",
                        orgQFilter.toArray()))
                .collect(Collectors.groupingBy(o -> o.getString("org.number"),
                        Collectors.mapping(o -> o.getLong("id"),
                                Collectors.toList())));
    }


    private Map<String, List<DynamicObject>> getAdminByOrg(Set<String> orgNumberList) {
        //获取当前子集团下所选层级的行政组织
        QFilter orgQFilter = new QFilter("datastatus", QCP.equals, "1")
                .and("org.number", QCP.in, orgNumberList)
//                .and("adminorglayer.number", QCP.in, orghierarchyList)
                .and("iscurrentversion", QCP.equals, "1");


        return Arrays.stream(BusinessDataServiceHelper.load("haos_adminorg",
                        "id,org.number,number,parent.number,structlongnumber,structnumber,adminorglayer.number",
                        orgQFilter.toArray()))
                .collect(Collectors.groupingBy(o -> o.getString("org.number")));
    }
}
