/**
 * @Description:月度编制计划实际人数同步
 * @Author: zhangjun
 * @Since: 2024/3/20
 **/
public class PlanMonthBillCreateTask extends AbstractTask {
    private static final Log logger = LogFactory.getLog(PlanMonthBillCreateTask.class);


    /**
     * 任职经历获取字段
     */
    private final static String EMP_FILED = "id as empId,employee.id as personId," +
            "adminorg.structnumber as structnumber," +
            "adminorg.structlongnumber as structlongnumber," +
            "job.${ISV_FLAG}_jobproperty.id as jobpropertyId," +
            "job.${ISV_FLAG}_joblabel.fbasedataid as jobLabelBasedataid";

    /**
     * 岗位i属性
     */
    private final static String[] PROPERTY_ARR = new String[]{"job1", "job2"};


    /**
     * 用工关系类型
     * 1030_S   实习（在职）
     * 1040_S   劳务派遣（在职）
     * 1050_S   退休返聘（在职）
     * 1200_S   正式工（在职）
     * 1220_S   合作伙伴（在职）
     */
    private final static String[] FILE_TYPE = new String[]{"1030_S", "1040_S", "1050_S", "1200_S", "1220_S"};

    /**
     * 档案业务类型
     */
    private final static String[] ERM_TYPE = new String[]{"1010_S", "1070_S", "1110_S", "1150_S", "1190_S"};


    /**
     * @param requestContext
     * @param requestMap
     * @throws KDException
     * @description
     */
    @Override
    public void execute(RequestContext requestContext, Map<String, Object> requestMap) throws KDException {
        // 获取启用中的月度计划
        DynamicObject[] planMonths = getPlanMonths(requestMap);
        if (planMonths.length == 0) {
            logger.info("未找到启用中的月度计划");
            return;
        }

        List<Long> allId = Arrays.stream(planMonths).map(plan -> plan.getLong("id")).collect(Collectors.toList());
        logger.info("PlanMonthBillCreateTask启用中的编制计划=" + allId);

        // 获取编制信息管理对象
        DynamicObject[] bzBillObjs = BusinessDataServiceHelper.load("${ISV_FLAG}_planmonth_bill", "id,billno,${ISV_FLAG}_planmonth",
                new QFilter("${ISV_FLAG}_planmonth.id", QCP.in, allId).toArray());

        // 准备批量查询的数据
        BatchData batchData = prepareBatchData(bzBillObjs);

        // 处理编制信息管理对象
        ArrayList<DynamicObject> resultList = processBillObjects(bzBillObjs, batchData);

        // 批量更新结果
        if (!resultList.isEmpty()) {
            SaveServiceHelper.update(resultList.toArray(new DynamicObject[]{}));
        }
    }

    /**
     * 获取启用中的月度计划
     */
    private DynamicObject[] getPlanMonths(Map<String, Object> requestMap) {
        QFilter planQFilter = new QFilter("enable", QCP.equals, "1").and("iscurrentversion", QCP.equals, "1");
        Object plannumber = requestMap.get("plannumber");
        if (plannumber != null && !plannumber.toString().isEmpty()) {
            planQFilter.and("number", QCP.equals, plannumber);
        }
        return BusinessDataServiceHelper.load("${ISV_FLAG}_planmonth", "id,number", planQFilter.toArray());
    }

    /**
     * 批量查询数据
     */
    private BatchData prepareBatchData(DynamicObject[] bzBillObjs) {
        // 查询月度编制信息管理编制明细
        Set<Object> ${ISV_FLAG}_planmonthSet = Arrays.stream(bzBillObjs)
                .map(b -> b.getDynamicObject("${ISV_FLAG}_planmonth").getPkValue())
                .collect(Collectors.toSet());

        DynamicObject[] ${ISV_FLAG}_planmonth_bzArray = BusinessDataServiceHelper.load("${ISV_FLAG}_planmonth_bz",
                "adminorg.structnumber,${ISV_FLAG}_key,${ISV_FLAG}_bz_jobproperty,${ISV_FLAG}_bz_laborreltype,${ISV_FLAG}_layer,${ISV_FLAG}_bz_actual," +
                        "${ISV_FLAG}_bz_adminorg1.structnumber,${ISV_FLAG}_bz_adminorg2.structnumber,${ISV_FLAG}_bz_adminorg3.structnumber," +
                        "${ISV_FLAG}_bz_adminorg4.structnumber,${ISV_FLAG}_bz_adminorg5.structnumber,${ISV_FLAG}_bz_adminorg6.structnumber," +
                        "${ISV_FLAG}_mulperson,${ISV_FLAG}_planmonth_bill.${ISV_FLAG}_planmonth.id",
                new QFilter("${ISV_FLAG}_planmonth_bill.${ISV_FLAG}_planmonth.id", QCP.in, ${ISV_FLAG}_planmonthSet).toArray());

        Map<Object, List<DynamicObject>> groupByPlanMonthMap = Arrays.stream(${ISV_FLAG}_planmonth_bzArray)
                .collect(Collectors.groupingBy(o -> o.get("${ISV_FLAG}_planmonth_bill.${ISV_FLAG}_planmonth.id")));

        // 批量查询组织
        Set<String> bzBillObjsSet = Arrays.stream(bzBillObjs)
                .map(b -> b.getDynamicObject("${ISV_FLAG}_planmonth").getDynamicObject("${ISV_FLAG}_org").getString("number"))
                .collect(Collectors.toSet());
        Map<String, List<Long>> orgListMap = getOrgList(bzBillObjsSet);

        // 批量查询行政组织
        Map<String, List<DynamicObject>> adminByOrgMap = getAdminByOrg(bzBillObjsSet);

        return new BatchData(groupByPlanMonthMap, orgListMap, adminByOrgMap);
    }

    /**
     * 处理编制信息管理对象
     */
    private ArrayList<DynamicObject> processBillObjects(DynamicObject[] bzBillObjs, BatchData batchData) {
        ArrayList<DynamicObject> resultList = new ArrayList<>();

        for (DynamicObject bzBillObj : bzBillObjs) {
            // 编制计划
            DynamicObject planMonth = bzBillObj.getDynamicObject("${ISV_FLAG}_planmonth");

            // 获取层级和组织信息
            String hierarchy = planMonth.getString("${ISV_FLAG}_orghierarchy");
            DynamicObject dgdlOrg = planMonth.getDynamicObject("${ISV_FLAG}_org");
            String sonNumber = dgdlOrg.getString("number");

            // 获取组织管理体系的所有行政组织
            List<DynamicObject> adminOrgList = batchData.adminByOrgMap.get(sonNumber);
            Map<String, DynamicObject> hierarchyMap = adminOrgList.stream()
                    .filter(o -> o.getDynamicObject("adminorglayer") != null)
                    .filter(o -> Integer.parseInt(o.getString("adminorglayer.number")) <= (Integer.parseInt(hierarchy) + 1))
                    .collect(Collectors.toMap(o -> o.getString("structnumber"), o -> o));

            Set<String> orgStructNumbers = hierarchyMap.keySet();
            List<Long> orgList = batchData.orgListMap.get(sonNumber);

            // 计算员工人数
            Map<String, Integer> countMap = calculateEmployeeCount(planMonth, orgList, orgStructNumbers);

            // 当前计划下所有编制详情
            List<DynamicObject> bzObjs = batchData.groupByPlanMonthMap.get(planMonth.getPkValue());
            if (bzObjs == null) {
                continue;
            }

            // 向上级组织汇总人数
            aggregateToParentOrgs(bzObjs, countMap, hierarchy);

            // 更新编制对象的实际人数
            updateBillActualCount(bzObjs, countMap);

            resultList.addAll(bzObjs);
        }

        return resultList;
    }

