    @Override
    public void beforeExecuteOperationTransaction(BeforeOperationArgs e) {
        List<ExtendedDataEntity> selectedRows = e.getSelectedRows();
        for (ExtendedDataEntity selectedRow : selectedRows) {
            DynamicObject bill = selectedRow.getDataEntity();
            DynamicObjectCollection entryentity = bill.getDynamicObjectCollection("entryentity");

            for (DynamicObject dynamicObject : entryentity) {
                String isMobile = dynamicObject.getString("${ISV_FLAG}_is_mobile");
                if ("true".equals(isMobile)) {
                    //变更后银行卡
                    DynamicObject modifyperbankcard = dynamicObject.getDynamicObject("modifyperbankcard");
                    if (modifyperbankcard == null){
                        //变更前银行卡
                        modifyperbankcard = dynamicObject.getDynamicObject("perbankcard");
                    }

                    //todo如果变更前和变更后银行卡为空，则新生成一张银行卡
                    if (modifyperbankcard == null){
                        addNewBankCard(dynamicObject);
                    }else {
                        modifBank(dynamicObject);
                    }
                }
            }
        }
    }

