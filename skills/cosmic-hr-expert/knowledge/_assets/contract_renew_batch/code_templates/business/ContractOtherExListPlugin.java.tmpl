    @Override
    public void beforeDoOperation(BeforeDoOperationEventArgs args) {
        FormOperate opreate = (FormOperate) args.getSource();
        String operateKey = opreate.getOperateKey();
        if ("delete".equals(operateKey)) {
            BillList list = this.getControl(AbstractListPlugin.BILLLISTID);
            ListSelectedRowCollection selectedRows = list.getSelectedRows();
            //jl-修改
            if (selectedRows.size() == 0){
                return;
            }
            Set<Long> ids = selectedRows.stream().map(selectedRow -> (Long) selectedRow.getPrimaryKeyValue()).collect(Collectors.toSet());
            String billFormId = ((ListView) this.getView()).getBillFormId();//单据标识
            DynamicObject[] contractObjs = BusinessDataServiceHelper.load(billFormId, "${ISV_FLAG}_fddsignstatuss"
                    , new QFilter[]{new QFilter("id", QCP.in, ids)});
            if (contractObjs.length == 0){
                return;
            }
            Map<Long, DynamicObject> contractObjMap = Arrays.stream(contractObjs).collect(Collectors.toMap(a -> a.getLong("id"), a -> a));
            for (ListSelectedRow selectedRow : selectedRows) {
                Long id = (Long) selectedRow.getPrimaryKeyValue();
                //jl-修改
//                DynamicObject contractObj = BusinessDataServiceHelper.loadSingle(id, ((ListView) this.getView()).getBillFormId());
                DynamicObject contractObj = contractObjMap.get(id);
                if (contractObj ==null){
                    continue;
                }
                String ${ISV_FLAG}_fddsignstatuss = contractObj.getString("${ISV_FLAG}_fddsignstatuss");
                if (("已完成".equals(${ISV_FLAG}_fddsignstatuss) || "F".equals(${ISV_FLAG}_fddsignstatuss) || "待相对方签署".equals(${ISV_FLAG}_fddsignstatuss) || "E".equals(${ISV_FLAG}_fddsignstatuss))) {
                    this.getView().showErrorNotification("选中单据中存在电子签：待相对方签署/已完成、无法删除");
                    args.setCancel(true);
                }
            }
        }
        super.beforeDoOperation(args);
    }

