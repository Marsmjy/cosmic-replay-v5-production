//        });
        //jl-修改  todo 不确定dynamicObjects数组中itemIds字段的是否存在交集
        // 收集所有需要的数据
        List<Long> allPkIds = new ArrayList<>();//所有主单
        Set<Long> allItemIds = new HashSet<>();//所有子单据id
        Map<Long, List<Long>> pkIdToItemIdsMap = new HashMap<>();//key：主id value：子id集合

        // 第一步：收集所有需要的数据
        Arrays.stream(dynamicObjects).forEach(n -> {
            long pkId = n.getLong("id");
            allPkIds.add(pkId);

            String itemIds = n.getString("${ISV_FLAG}_itemids_tag");
            List<Long> currentItemIds = new ArrayList<>();

            if (StringUtils.isNotEmpty(itemIds)) {
                currentItemIds = Arrays.stream(itemIds.split(","))
                        .map(Long::valueOf)
                        .collect(Collectors.toList());
                allItemIds.addAll(currentItemIds);
            }

            pkIdToItemIdsMap.put(pkId, currentItemIds);
        });

      // 批量查询需要绑定的子单
        DynamicObject[] bindItems = new DynamicObject[0];
        if (!allItemIds.isEmpty()) {
            bindItems = BusinessDataServiceHelper.load("hlcm_contractapplyrenew",
                    "id,billstatus,handlestatus,auditstatus,${ISV_FLAG}_renewbatch",
                    new QFilter("id", QCP.in, allItemIds.toArray()).toArray());
        }

        // 批量查询需要解绑的子单
        DynamicObject[] unbindItems = BusinessDataServiceHelper.load("hlcm_contractapplyrenew",
                "id,billstatus,handlestatus,auditstatus,${ISV_FLAG}_renewbatch",
                new QFilter("${ISV_FLAG}_renewbatch.id", QCP.in, allPkIds.toArray()).toArray());

         // 创建更新列表
        List<DynamicObject> updateList = new ArrayList<>();

        // 处理绑定逻辑
        Map<Long, DynamicObject> bindItemsMap = Arrays.stream(bindItems)
                .collect(Collectors.toMap(item -> item.getLong("id"), item -> item));
        // 处理解绑逻辑
        Map<Long, DynamicObject> unbindItemsMap = Arrays.stream(unbindItems)
                .collect(Collectors.toMap(item -> item.getLong("id"), item -> item));

        // 根据业务规则更新记录
        for (Map.Entry<Long, List<Long>> entry : pkIdToItemIdsMap.entrySet()) {
            Long pkId = entry.getKey();//主id
            List<Long> itemIds = entry.getValue();//子id

            // 绑定新增的子单
            for (Long itemId : itemIds) {
                DynamicObject item = bindItemsMap.get(itemId);
                if (item != null) {
                    item.set("billstatus", "B");
                    item.set("handlestatus", "2");
                    item.set("auditstatus", "B");
                    item.set("${ISV_FLAG}_renewbatch", pkId);
                    updateList.add(item);
                }
            }

            // 解绑删除的子单
            for (DynamicObject item : unbindItems) {
                if (pkId.equals(item.getLong("${ISV_FLAG}_renewbatch.id")) &&
                        !itemIds.contains(item.getLong("id"))) {
                    item.set("billstatus", "A");
                    item.set("handlestatus", "1");
                    item.set("auditstatus", "A");
                    item.set("${ISV_FLAG}_renewbatch", null);
                    updateList.add(item);
                }
            }
        }

        // 最后-批量保存所有更新
        if (!updateList.isEmpty()) {
            // 去重，避免同一记录被多次更新
            Map<Long, DynamicObject> distinctUpdateMap = updateList.stream()
                    .collect(Collectors.toMap(
                            item -> item.getLong("id"),
                            item -> item,
                            (existing, replacement) -> existing // 如果有重复，保留已存在的
                    ));
            SaveServiceHelper.update(distinctUpdateMap.values().toArray(new DynamicObject[0]));
        }
    }

