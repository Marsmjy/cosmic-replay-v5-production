    @Override
    public Map<String, Object> assembleWordFile(Map<String, Object> allDataMap, String fileName, String templateEncoding, List<String> configNameList) {
        Map<String, Object> resultMap = new HashMap<>(8);
        //查询模板
        DynamicObject perProWordTempDy = queryPerProWord("number", templateEncoding, "${ISV_FLAG}_hspm_wordconversion", "id");
        if (!ObjectUtils.isEmpty(perProWordTempDy)) {
            //获取附件信息
            DynamicObject attachmentDy = queryPerProWord("finterid", perProWordTempDy.getString("id"), "bos_attachment", "ffileid");
            if (!ObjectUtils.isEmpty(attachmentDy)) {
                String url = attachmentDy.getString("ffileid");
                FileService attachmentFileService = FileServiceFactory.getAttachmentFileService();
                InputStream inputStream = attachmentFileService.getInputStream(url);
                // 行循环实例
                LoopRowTableRenderPolicy policy = new LoopRowTableRenderPolicy();
                //这里可以指定一个config类，用来指定一些规则，也可以改变模板中{{}}的这种格式
                ConfigureBuilder builder = Configure.builder();
                for (String configName : configNameList) {
                    builder.bind(configName, policy);
                }
                XWPFTemplate compile = XWPFTemplate.compile(inputStream, builder.build());
                return buildResultMap(allDataMap, fileName, resultMap, compile);
            }
        }
        return resultMap;
    }

    /**
     * @param allDataMap 全部数据
     * @param fileName   文件名称
     * @param resultMap  返回Map
     * @param compile    XWPFTemplate
     * @return java.util.Map<java.lang.String, java.lang.Object>
     * @description 构架返回Map
     * @author ZhouPingHai
     * @lastModifiedBy: （填入修改人）
     * @lastModifyTime: （修改时间）
     * @Date 2023/7/17 16:45
     */
    private Map<String, Object> buildResultMap(Map<String, Object> allDataMap, String fileName, Map<String, Object> resultMap, XWPFTemplate compile) {
        compile.render(allDataMap);
        try {
            ByteArrayOutputStream outStream = new ByteArrayOutputStream();
            compile.writeAndClose(outStream);
            byte[] bytes = outStream.toByteArray();
            InputStream inputStream = new ByteArrayInputStream(bytes);
            TempFileCache cache = CacheFactory.getCommonCacheFactory().getTempFileCache();
            String fullUrl = cache.saveAsFullUrl(fileName, new BufferedInputStream(inputStream), 30 * 3);
            fullUrl = FileServiceExtFactory.getAttachFileServiceExt().getRealPath(URLDecoder.decode(fullUrl, "UTF-8"));
            //先上传到苍穹的缓存中
            resultMap.put("url", fullUrl);
            resultMap.put("size", bytes.length);
            resultMap.put("name", fileName);
            resultMap.put("outStream",outStream);
            return resultMap;
        } catch (IOException e) {
            LOGGER.error("文件构建出错原因" + e.getMessage());
            LOGGER.error("文件构建出错详细信息" + Arrays.toString(e.getStackTrace()));
            throw new RuntimeException(e);
        }
    }

