    /**
     * @param query
     * @return java.util.List<kd.bos.dataentity.entity.DynamicObject>
     * @description 家庭成员信息排序
     * @author ZhouPingHai
     * @lastModifiedBy: （填入修改人）
     * @lastModifyTime: （修改时间）
     * @Date 2023/9/2 15:02
     */
    private static List<DynamicObject> sortFamilyMemberDy(DynamicObject[] query) {
        //主要家庭成员及社会关系排序List集合
        List<String> familymembSortList = familymembSort();
        List<DynamicObject> allSortFamilyMemberList = new ArrayList<>();
        //存在在集合中的数据
        Map<String, List<DynamicObject>> inFamilyMemberMap = Arrays.stream(query).filter(dy -> !ObjectUtils.isEmpty(dy.getDynamicObject("familymembship")) && familymembSortList.contains(dy.getString("familymembship.number"))).collect(Collectors.groupingBy(dy -> dy.getString("familymembship.number")));
        for (String familyMemberSort : familymembSortList) {
            List<DynamicObject> familyMemberList = inFamilyMemberMap.get(familyMemberSort);
            if (!ObjectUtils.isEmpty(familyMemberList)) {
                allSortFamilyMemberList.addAll(familyMemberList);
            }
        }
        //不存在familymembSortList集合中的数据
        List<DynamicObject> notInFamilyMemberList = Arrays.stream(query).filter(dy -> !ObjectUtils.isEmpty(dy.getDynamicObject("familymembship")) && !familymembSortList.contains(dy.getString("familymembship.number"))).collect(Collectors.toList());

        //不在familymembSortList集合中的数据排在后面
        if (!ObjectUtils.isEmpty(notInFamilyMemberList)) {
            allSortFamilyMemberList.addAll(notInFamilyMemberList);
        }
        //家庭成员关系为空的排最后 避免报错
        List<DynamicObject> familyMemberShipList = Arrays.stream(query).filter(dy -> ObjectUtils.isEmpty(dy.getDynamicObject("familymembship"))).collect(Collectors.toList());
        if (!ObjectUtils.isEmpty(familyMemberShipList)) {
            allSortFamilyMemberList.addAll(familyMemberShipList);
        }

        return allSortFamilyMemberList;
    }

