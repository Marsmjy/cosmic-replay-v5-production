    /**
     * 处理任职总经历
     *
     * @param empOrgRelAllColl 任职经历记录
     * @return 处理后任职经历
     */
    private List<DynamicObject> empOrgRelAllHandle(DynamicObject[] empOrgRelAllColl) {
        // 过滤掉开始或结束时间为空、虚拟兼职数据
        List<DynamicObject> empOrgRelList = Arrays.stream(empOrgRelAllColl).filter(f -> {
            if (StringUtils.isNotBlank(f.getString("startdate")) && StringUtils.isNotBlank(f.getString("enddate"))) {
                return true;
            }
            return false;
        }).collect(Collectors.toList());

        // 根据公司、部门、岗位进行分组 company、adminorg、position
        Map<String, List<DynamicObject>> disEmpOrgRelMap = new HashMap<>(empOrgRelList.size());
        for (DynamicObject dynamicObject : empOrgRelList) {
            String company = dynamicObject.getString("company");
            String adminOrg = dynamicObject.getString("adminorg");
            String position = dynamicObject.getString("position");
            String key = company + "-" + adminOrg + "-" + position;
            if (disEmpOrgRelMap.containsKey(key)) {
                List<DynamicObject> dynamicObjects = disEmpOrgRelMap.get(key);
                dynamicObjects.add(dynamicObject);
            } else {
                List<DynamicObject> dynamicObjects = new ArrayList<>(1);
                dynamicObjects.add(dynamicObject);
                disEmpOrgRelMap.put(key, dynamicObjects);
            }
        }
        List<DynamicObject> newEmpOrgRelList = new ArrayList<>(disEmpOrgRelMap.size());
        for (String key : disEmpOrgRelMap.keySet()) {
            List<DynamicObject> dynamicObjects = disEmpOrgRelMap.get(key);
            if (dynamicObjects.size() < 2) {
                newEmpOrgRelList.addAll(dynamicObjects);
                continue;
            }
            // 根据结束时间降序、异动类型（将主职排前面）进行排序
            List<DynamicObject> endDateSortList = dynamicObjects.stream().sorted((t1, t2) -> {
                String endDate1 = t1.getString("enddate");
                String endDate2 = t2.getString("enddate");
                if (endDate1.compareTo(endDate2) == 0) {
                    String startDate1 = t1.getString("startdate");
                    String startDate2 = t2.getString("startdate");

                    return startDate1.compareTo(startDate2);
                } else {
                    return endDate2.compareTo(endDate1);
                }
            }).collect(Collectors.toList());

            DynamicObject tempDy = new DynamicObject();
            Date minStartDate = null;
            for (int i = 0; i < endDateSortList.size(); i++) {
                DynamicObject dynamicObject = endDateSortList.get(i);
                // 第一条数据进行赋值
                if (i == 0) {
                    tempDy = dynamicObject;
                    minStartDate = tempDy.getDate("startdate");
                    continue;
                }
                // 判断是否断档，上一条开始日期晚于当前的结束日期+1小于为断档
                Date endDate = DateUtils.addDays(dynamicObject.getDate("enddate"), 1);
                if (minStartDate.after(endDate)) {
                    newEmpOrgRelList.add(tempDy);
                    tempDy = dynamicObject;
                    minStartDate = tempDy.getDate("startdate");
                } else {
                    // 未断档，判断上一条开始日期晚于当前开始日期，如果是就重新赋值
                    Date currentStartDate = dynamicObject.getDate("startdate");
                    if (minStartDate.after(currentStartDate)) {
                        minStartDate = currentStartDate;
                        tempDy.set("startdate", currentStartDate);
                    }
                }
                // 判断是否最后一条，如果最后一条将数据添加
                if (i == endDateSortList.size() - 1) {
                    newEmpOrgRelList.add(tempDy);
                }
            }
        }
        return newEmpOrgRelList;
    }

