                    //部门
                    preWorkExpMap.put("adminorg", new TextRenderData(COLOR, department));
                    //岗位
                    preWorkExpMap.put("positionname", new TextRenderData(COLOR, position));
                    filedStr.append(startDate + " - " + endDate);
                    filedStr.append("  ");
                    filedStr.append(companyAndPosition);
