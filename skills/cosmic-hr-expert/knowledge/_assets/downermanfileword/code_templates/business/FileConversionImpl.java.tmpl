            filedStr = new StringBuilder(filedStr.toString().replace("null", ""));
            allMap.put("perempemprgprework", new TextRenderData(COLOR, filedStr.toString().replace("null", "")));
        }
        allMap.put("emprgprework", perEduList);
    }

    private static boolean equals(String startDate, String endData) {
        String[] start = startDate.split("\\.");
        String[] end = endData.split("\\.");
        if (start[0].equals(end[0]) && (Long.parseLong(start[1]) - 1) == Long.parseLong(end[1])) {
            return true;
        } else
            return (Long.parseLong(start[0]) - 1) == Long.parseLong(end[0]) && end[1].equals("12") && start[1].equals("01");
    }

