    private static void universalConversion(Map<String, Object> allMap, DynamicObject[] perRegionColl, String entityName, String templateNumber) {
        if (!ObjectUtils.isEmpty(perRegionColl)) {
            List<Object> perEduList = new ArrayList<>();
            List<Object> punishmentList = new ArrayList<>();
            List<Object> rewardList = new ArrayList<>();
            for (DynamicObject perRegionDy : perRegionColl) {
                DataEntityPropertyCollection perRegionFiledList = perRegionDy.getDataEntityType().getProperties();
                Map<String, Object> perEduExpMap = new HashMap<>(8);
                for (IDataEntityProperty iDataEntityProperty : perRegionFiledList) {
                    String propertyName = iDataEntityProperty.getName();
                    if (StringUtils.equals("headsculpture", propertyName)) {
                        continue;
                    }

                    //特殊处理字段  服务年限
                    if (StringUtils.equals("hrpi_perserlen", entityName)) {
                        if (StringUtils.equals("employee", propertyName)) {
                            allMap.put(propertyName, new TextRenderData(COLOR, perRegionDy.getString(propertyName + ".empnumber")));
                            perEduExpMap.put(propertyName, new TextRenderData(COLOR, perRegionDy.getString(propertyName + ".empnumber")));
                            continue;
                        }
                        // 本次加入集团日期
                        if (StringUtils.equals("joincomdate", propertyName)) {
                            String format = HRDateTimeUtils.format(perRegionDy.getDate(propertyName), "yyyy-MM-dd");
                            // 加入公司日期
                            allMap.put("${ISV_FLAG}_joindate", new TextRenderData(COLOR, format));
                            perEduExpMap.put("${ISV_FLAG}_joindate", new TextRenderData(COLOR, format));
                            // 本次加入集团日期
                            allMap.put(propertyName, new TextRenderData(COLOR, format));
                            perEduExpMap.put(propertyName, new TextRenderData(COLOR, format));
                            continue;
                        }
                        // 参加工作日期
                        if (StringUtils.equals("joinworktime", propertyName)) {
                            String format = HRDateTimeUtils.format(perRegionDy.getDate(propertyName), "yyyy-MM-dd");
                            allMap.put("beginservicedate", new TextRenderData(COLOR, format));
                            perEduExpMap.put("beginservicedate", new TextRenderData(COLOR, format));
                            continue;
                        }


                    }
                    //任职经历
                    if (StringUtils.equals("hrpi_empposorgrel", entityName)) {
                        if (StringUtils.equals("employee", propertyName)) {
                            allMap.put(propertyName, new TextRenderData(COLOR, perRegionDy.getString(propertyName + ".empnumber")));
                            perEduExpMap.put(propertyName, new TextRenderData(COLOR, perRegionDy.getString(propertyName + ".empnumber")));
                            continue;
                        }
                        if (StringUtils.equals("adminorg", propertyName) || StringUtils.equals("adminorg", propertyName)) {
                            String isPrimary = perRegionDy.getString("isprimary");
                            if (!StringUtils.equals("1", isPrimary)) {
                                continue;
                            }
                        }

                    }
                    if (StringUtils.equals("hrpi_perregion", entityName)) {
                        // 籍贯
                        if (StringUtils.equals("nativeplace", propertyName)) {
                            allMap.put("${ISV_FLAG}_origin", new TextRenderData(COLOR, perRegionDy.getString("nativeplace")));
                            perEduExpMap.put("${ISV_FLAG}_origin", new TextRenderData(COLOR, perRegionDy.getString("nativeplace")));
                            continue;
                        }
                        // 出生地
                        if ("birthplace".equals(propertyName)) {
                            //出生地
                            allMap.put("${ISV_FLAG}_administrative", new TextRenderData(COLOR, perRegionDy.getString("birthplace")));
                            perEduExpMap.put("${ISV_FLAG}_administrative", new TextRenderData(COLOR, perRegionDy.getString("birthplace")));
                            continue;
                        }
                    }
                    //人员
                    if (StringUtils.equals("hrpi_employee", entityName)) {
                        if (StringUtils.equals("birthday", propertyName)) {
                            Date date = perRegionDy.getDate(propertyName);
                            allMap.put(propertyName, new TextRenderData(COLOR, getDateString(date)));
                            perEduExpMap.put(propertyName, new TextRenderData(COLOR, getDateString(date)));
                            if (!ObjectUtils.isEmpty(date)) {
                                Calendar cal = Calendar.getInstance();
                                cal.setTime(date);
                                int year = cal.get(Calendar.YEAR);
                                int month = cal.get(Calendar.MONTH) + 1;
                                String birthday;
                                if (month < 10) {
                                    birthday = year + ".0" + month;
                                } else {
                                    birthday = year + "." + month;
                                }
                                allMap.put("specialbirthday", new TextRenderData(COLOR, birthday));
                                perEduExpMap.put("specialbirthday", new TextRenderData(COLOR, birthday));
                            }
                            continue;
                        }
                    }
                    //培训经历
                    if (pereduExpSpecialtreatment("hrpi_emptrainfile", entityName, "startdate", propertyName, perRegionDy, "enddate", perEduExpMap)) {
                        continue;
                    }
                    //前工作经历
                    if (pereduExpSpecialtreatment("hrpi_preworkexp", entityName, "startdate", propertyName, perRegionDy, "enddate", perEduExpMap)) {
                        continue;
                    }
                    //教育经历
                    if (pereduExpSpecialtreatment("hrpi_pereduexp", entityName, "admissiondate", propertyName, perRegionDy, "gradutiondate", perEduExpMap)) {
                        continue;
                    }

                    Class<?> propertyType = iDataEntityProperty.getPropertyType();
                    if (ObjectUtils.isEmpty(propertyType)) {
                        continue;
                    }
                    String className = propertyType.getName();
                    if (otherFieldProcessing(allMap, perRegionDy, propertyName, className, perEduExpMap)) {
                        continue;
                    }
                    allMap.put(propertyName, new TextRenderData(COLOR, perRegionDy.getString(propertyName)));
                    perEduExpMap.put(propertyName, new TextRenderData(COLOR, perRegionDy.getString(propertyName)));
                }
                perEduList.add(perEduExpMap);
                //奖惩信息
                if (StringUtils.equals("hrpi_perrprecord", entityName)) {
                    String flag = perRegionDy.getString("flag");
                    if (StringUtils.equals("0", flag)) {
                        punishmentList.add(perEduExpMap);
                    } else {
                        rewardList.add(perEduExpMap);
                    }
                }
            }
            if (StringUtils.equals("hlcm_empprotocol", entityName) || StringUtils.equals("hlcm_contract", entityName)) {
                allMap.put("contractinformation", perEduList);
            }
            if (StringUtils.equals("hrpi_perrprecord", entityName)) {
                allMap.put("punishment", punishmentList);
                allMap.put("reward", rewardList);
            }
            allMap.put(entityName, perEduList);

        }
    }

