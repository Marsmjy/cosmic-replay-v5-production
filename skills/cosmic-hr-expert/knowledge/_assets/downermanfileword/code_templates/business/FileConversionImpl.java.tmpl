        }
        strAdmin = parent.getString("name") + strAdmin;
        return retAdmin(parent, strAdmin);
    }

    /**
     * @Description 递归拼接出生地
     * @author LuZhiBin
     * @date 2023/10/25 16:51
     */
    public static String retAdminGM(DynamicObject admindivision, String strAdmin) {
        strAdmin = strAdmin.replace("省", "").replace("市", "");
        if (strAdmin.contains("北京") || strAdmin.contains("上海") || strAdmin.contains("天津") || strAdmin.contains("重庆")) {
            return strAdmin;
        }
        admindivision = BusinessDataServiceHelper.loadSingle(admindivision.getPkValue(), "bd_admindivision");
        DynamicObject basedatafield = admindivision.getDynamicObject("basedatafield");
        //上级行政区划
        DynamicObject parent = admindivision.getDynamicObject("parent");
        if (ObjectUtils.isEmpty(parent) || admindivision.equals(parent)) {
            return strAdmin;
        }
        if (basedatafield.getString("number").equals("003")) {
            strAdmin = parent.getString("name");
            return retAdminGM(parent, strAdmin);
        }
        strAdmin = parent.getString("name") + strAdmin;
        return retAdminGM(parent, strAdmin);
    }


    /**
     * @Description 将yyyy-mm-dd转换成yyyy.mm
     * @author LuZhiBin
     * @date 2023/9/18 10:10
     */
    public static String getDateString(Date date) {
        if (!ObjectUtils.isEmpty(date)) {
            Calendar cal = Calendar.getInstance();
            cal.setTime(date);
            int year = cal.get(Calendar.YEAR);
            int month = cal.get(Calendar.MONTH) + 1;
            String strDate;
            if (month < 10) {
                strDate = year + ".0" + month;
            } else {
                strDate = year + "." + month;
            }
            return strDate;
        }
        return "";
    }

    /**
     * 根据出生年月日计算年龄
     *
     * @param birthday
     * @module
     * @author SJT
     * @date 2022/8/31
     * @return: int
     */
    public static int getAgeByBirth(Date birthday) {
        if (ObjectUtils.isEmpty(birthday)) {
            return 0;
        }

        //获取当前时间${ISV_FLAG}.hr.hspm.formplugin.PersonBaseInfoAssignMentPlugin
        Calendar cal = Calendar.getInstance();

        //获取出生日期的Calendar对象
        Calendar bir = Calendar.getInstance();
        bir.setTime(birthday);
        //如果出生日期大于当前日期，则返回0
        if (cal.before(birthday)) {
            return 0;
        }
        //取出当前年月日
        int nowYear = cal.get(Calendar.YEAR);
        int nowMonth = cal.get(Calendar.MONTH);
        int nowDay = cal.get(Calendar.DAY_OF_MONTH);

        //取出出生日期的年月日
        int birthYear = bir.get(Calendar.YEAR);
        int birthMonth = bir.get(Calendar.MONTH);
        int birthDay = bir.get(Calendar.DAY_OF_MONTH);

        //计算年份
        int age = nowYear - birthYear;

        //计算月份和日，看看是否大于当前月日，如果小于则减去一岁
        if (nowMonth < birthMonth || (nowMonth == birthMonth && nowDay < birthDay)) {
            age--;
        }
        return age;
    }


    private static boolean pereduExpSpecialtreatment(String hrpi_pereduexp, String entityName, String admissiondate, String propertyName, DynamicObject perRegionDy, String gradutiondate, Map<String, Object> perEduExpMap) {
        if (StringUtils.equals(hrpi_pereduexp, entityName)) {
            if (StringUtils.equals(admissiondate, propertyName)) {
                //开始时间
                Date admissionDate = perRegionDy.getDate(admissiondate);
                //毕业时间
                Date graduationDate = perRegionDy.getDate(gradutiondate);
                String admissionDateStr = getDateString(admissionDate);
                String graduationDateStr = getDateString(graduationDate);
                //起止日期
                perEduExpMap.put("startAndEndDate", new TextRenderData(COLOR, admissionDateStr + " - " + graduationDateStr));
                return true;
            }
            if (StringUtils.equals("graduateschool", propertyName)) {
                String graduateSchoolNumber = perRegionDy.getString("graduateschool.number");
                if (StringUtils.equals(getChgeEventNumber("constant.hrmp.hbss.hbss_college.otherschool", "XY03397"), graduateSchoolNumber)) {
                    //其他院校 特殊处理
                    perEduExpMap.put("graduateschool", new TextRenderData(COLOR, perRegionDy.getString("schoolrecord")));
                    return true;
                }
            }
            if (StringUtils.equals("name", propertyName) && StringUtils.equals("hrpi_emptrainfile", entityName)) {
                String name = perRegionDy.getString("name");
                perEduExpMap.put("name", new TextRenderData(COLOR, name));
                //开始时间
                Date admissionDate = perRegionDy.getDate(admissiondate);
                //毕业时间
                Date graduationDate = perRegionDy.getDate(gradutiondate);
                String admissionDateStr = getDateString(admissionDate);
                String graduationDateStr = getDateString(graduationDate);
                //起止日期
                perEduExpMap.put("startAndEndDate", new TextRenderData(COLOR, admissionDateStr + " - " + graduationDateStr));
            }
        }
        return false;
    }

    private static boolean otherFieldProcessing(Map<String, Object> allMap, DynamicObject perRegionDy, String propertyName, String className, Map<String, Object> perEduExpMap) {
        Object propertyDy = perRegionDy.get(propertyName);
        if (StringUtils.equals("kd.bos.dataentity.entity.DynamicObject", className)) {
            if (propertyDy instanceof DynamicObject) {
                if (perRegionDy.getDynamicObjectType().getProperties().containsKey(propertyName)
                        && perRegionDy.getDynamicObject(propertyName).getDynamicObjectType().getProperties().containsKey("name")) {
                    allMap.put(propertyName, new TextRenderData(COLOR, perRegionDy.getString(propertyName + ".name")));
                    perEduExpMap.put(propertyName, new TextRenderData(COLOR, perRegionDy.getString(propertyName + ".name")));
                    return true;
                }
            } else if (propertyDy instanceof DynamicObjectCollection) {
                StringBuilder hobbyTypeBuild = new StringBuilder();
                DynamicObjectCollection mainHobbyTypeColl = perRegionDy.getDynamicObjectCollection(propertyName);
                if (!ObjectUtils.isEmpty(mainHobbyTypeColl)) {
                    for (DynamicObject mainHobbyDy : mainHobbyTypeColl) {
                        DynamicObject fBaseDataDy = mainHobbyDy.getDynamicObject("fbasedataid");
                        if (!ObjectUtils.isEmpty(fBaseDataDy)) {
                            String name = fBaseDataDy.getString("name");
                            hobbyTypeBuild.append(name);
                            hobbyTypeBuild.append(",");
                        }
                    }
                    if (!StringUtils.isEmpty(hobbyTypeBuild)) {
                        allMap.put(propertyName, new TextRenderData(COLOR, hobbyTypeBuild.substring(0, hobbyTypeBuild.lastIndexOf(","))));
                        perEduExpMap.put(propertyName, new TextRenderData(COLOR, hobbyTypeBuild.substring(0, hobbyTypeBuild.lastIndexOf(","))));
                    } else {
                        allMap.put(propertyName, new TextRenderData(COLOR, ""));
                        perEduExpMap.put(propertyName, new TextRenderData(COLOR, ""));
                    }
                }
                return true;
            }
            return true;
        } else if (StringUtils.equals("java.util.Date", className)) {
            //将时间转换成yyyy.mm
            String strDate = getDateString(perRegionDy.getDate(propertyName));

            allMap.put(propertyName, new TextRenderData(COLOR, strDate));
            perEduExpMap.put(propertyName, new TextRenderData(COLOR, strDate));
            return true;
        } else if (StringUtils.equals("boolean", className)) {
            boolean string = perRegionDy.getBoolean(propertyName);
            String booleanStr = "否";
            if (string) {
                booleanStr = "是";
            }
            allMap.put(propertyName, new TextRenderData(COLOR, booleanStr));
            perEduExpMap.put(propertyName, new TextRenderData(COLOR, booleanStr));
            return true;
        } else if (StringUtils.equals("java.lang.String", className)) {
            Object iDataEntityProperty = perRegionDy.getDataEntityType().getProperties().get(propertyName);
            //下拉列表特殊处理
            if (iDataEntityProperty instanceof ComboProp) {
                ComboProp ComboPropProperty = (ComboProp) perRegionDy.getDataEntityType().getProperties().get(propertyName);
                for (ValueMapItem comboItem : ComboPropProperty.getComboItems()) {
                    LocaleString name = comboItem.getName();
                    if (!ObjectUtils.isEmpty(name)) {
                        String comboName = perRegionDy.getString(propertyName);
                        if (!StringUtils.isEmpty(comboName)) {
                            allMap.put(propertyName, new TextRenderData(COLOR, name.getLocaleValue_zh_CN()));
                            perEduExpMap.put(propertyName, new TextRenderData(COLOR, name.getLocaleValue_zh_CN()));
                            return true;
                        }
                    }
                }
            }
        }
        return false;
    }

