    /**
     * @description 图片url转byte[]数组
     * @date 2023/6/30
     */
    static byte[] urlToByte(String path) {
        try {
            path = URLDecoder.decode(path, StandardCharsets.UTF_8.name());
            // 使用更高效的方式处理多个连续斜杠
            path = path.replaceAll("/+", "/");
            // 安全检查：防止路径遍历攻击
            if (path.contains("../") || path.contains("..\\") || path.startsWith("~/")) {
                throw new SecurityException("Invalid path containing traversal sequences: " + path);
            }
        } catch (UnsupportedEncodingException e) {
//            LOGGER.error("图片url解码出错: {}", e.getMessage());
//            LOGGER.error("图片url解码出错，path: {}", path);
        } catch (SecurityException e) {
//            LOGGER.error("图片url安全检查失败: {}", e.getMessage());
        }

        FileService attachmentFileService = FileServiceFactory.getImageFileService();
//        LOGGER.info("文件地址：{}  ", path);

        ByteArrayOutputStream outStream = new ByteArrayOutputStream();
        attachmentFileService.download(path, outStream, null);
        return outStream.toByteArray();

    }

