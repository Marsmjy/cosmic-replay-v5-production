                    String unitName = empOrgRelAllDy.getString("unitname");
                    //任职岗位
                    String position = empOrgRelAllDy.getString("position");
                    //任职部门
                    String department = empOrgRelAllDy.getString("department");
//                    LOGGER.error("zyx_department" + department);
                    String companyAndPosition = unitName + "  " + department + "  " + position;
                    if (StringUtils.equals(unitName, "待业") || StringUtils.equals(position, "待业") || StringUtils.equals("待业", department)) {
                        companyAndPosition = "待业";
                    }
                    //开始时间
                    String startDate = getDateString(empOrgRelAllDy.getDate("startdate"));
                    //结束时间
                    String endDate = getDateString(empOrgRelAllDy.getDate("enddate"));
                    if (endDate.contains("2999")) {
                        endDate = "至今";
                    }
                    preWorkExpMap.put("companyandposition", new TextRenderData(COLOR, companyAndPosition));
                    preWorkExpMap.put("startAndEndDate", new TextRenderData(COLOR, startDate + " - " + endDate));
                    //工作单位名称
