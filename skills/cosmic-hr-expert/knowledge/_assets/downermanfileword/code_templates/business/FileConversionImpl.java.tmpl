     * @return void
     * @description 构建返回文件
     * @author ZhouPingHai
     * @lastModifiedBy: （填入修改人）
     * @lastModifyTime: （修改时间）
     * @Date 2023/6/30 19:17
     */
    private Map<String, Object> buildWordFile(Map<String, Object> allMap, String personName, String templateNumber) {
        DynamicObject perProWordTempDy;
        //传入的模板编码为空的话 就是默认编码 用于其他单据进行生成附件
        //不为空的话 则查询指定模板  用于人员档案选择模板下载
        if (StringUtils.isEmpty(templateNumber)) {
            //查询模板
            perProWordTempDy = queryPerProWord("number", getChgeEventNumber(WORDCONVERSIONMCNUM, "XY0001"), "${ISV_FLAG}_hspm_wordconversion", "id,name");
            personName = personName + "人员履历.docx";
        } else {
            perProWordTempDy = queryPerProWord("number", templateNumber, "${ISV_FLAG}_hspm_wordconversion", "id,name");
            personName = personName + perProWordTempDy.getString("name") + ".docx";
        }
        Map<String, Object> resultMap = new HashMap<>();

        if (!ObjectUtils.isEmpty(perProWordTempDy)) {
            //获取附件信息
            DynamicObject attachmentDy = queryPerProWord("finterid", perProWordTempDy.getString("id"), "bos_attachment", "ffileid");
            if (!ObjectUtils.isEmpty(attachmentDy)) {
                String url = attachmentDy.getString("ffileid");
                FileService attachmentFileService = FileServiceFactory.getAttachmentFileService();
                InputStream inputStream = attachmentFileService.getInputStream(url);
                // 行循环实例
                LoopRowTableRenderPolicy policy = new LoopRowTableRenderPolicy();
                //这里可以指定一个config类，用来指定一些规则，也可以改变模板中{{}}的这种格式
                Configure config = Configure.builder().bind("hrpi_pereduexp", policy).bind("hrpi_preworkexp", policy)
                         .bind("hrpi_familymemb", policy).bind("hrpi_languageskills", policy)
                        .bind("hrpi_perprotitle", policy).bind("hrpi_perocpqual", policy)
                        .bind("punishment", policy).bind("reward", policy)
                        /*.bind("${ISV_FLAG}_hrpi_skillidentify", policy).bind("${ISV_FLAG}_hrpi_attendrecords", policy)*/
                        /*.bind("${ISV_FLAG}_hrpi_otheremployinf", policy).bind("${ISV_FLAG}_hrpi_casualtyinfor", policy)*/
                        .bind("hrpi_empposorgrel", policy).bind("hrpi_emrgcontact", policy)
                        .bind("hrpi_emptrainfile", policy).bind("contractinformation", policy)
                        .bind("emprgprework", policy).bind("hrpi_perrprecord", policy).build();
                XWPFTemplate compile = XWPFTemplate.compile(inputStream, config);
                return buildResultMap(allMap, personName, resultMap, compile);
            }
        }
        return resultMap;
    }

