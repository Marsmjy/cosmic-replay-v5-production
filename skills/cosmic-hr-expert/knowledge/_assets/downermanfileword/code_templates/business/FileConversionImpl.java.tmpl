    private static void empPosOrgHandle(DynamicObject[] attendRecordsColl, Map<String, String> empMap, Map<String, Object> allMap, StringBuilder currentPositionCurr) {
        Date startDate = null;
        Date endDate = null;
        for (DynamicObject isPrimaryDy : attendRecordsColl) {
            String isPrimary = isPrimaryDy.getString("isprimary");
            String companySimpleName = isPrimaryDy.getString("company.name");
            String adminOrgName = isPrimaryDy.getString("adminorg.name");
            String positionName = isPrimaryDy.getString("position.name");
            if (StringUtils.equals("1", isPrimary)) {
                //业务状态 = 生效中
                if (StringUtils.equals("1", isPrimaryDy.getString("businessstatus"))) {
                    setCurrentPosition(allMap, companySimpleName, adminOrgName, positionName, currentPositionCurr);
                }

                if (startDate == null) {
                    startDate = isPrimaryDy.getDate("startdate");
                    endDate = isPrimaryDy.getDate("enddate");
                    empMap.put("company", companySimpleName);
                    empMap.put("position", positionName);
                    empMap.put("adminorg", adminOrgName);
                    continue;
                }
                // 如果开始时间相等，比较结束时间，取结束时间晚的任职记录信息
                if (startDate.equals(isPrimaryDy.getDate("startdate")) && endDate.before(isPrimaryDy.getDate("enddate"))) {
                    startDate = isPrimaryDy.getDate("startdate");
                    empMap.put("company", companySimpleName);
                    empMap.put("position", positionName);
                    empMap.put("adminorg", adminOrgName);
                    continue;
                }
                if (startDate.before(isPrimaryDy.getDate("startdate"))) {
                    startDate = isPrimaryDy.getDate("startdate");
                    empMap.put("company", companySimpleName);
                    empMap.put("position", positionName);
                    empMap.put("adminorg", adminOrgName);
                }
            }
        }
    }

