package ${ISV_FLAG}.hspm;


import kd.bos.dataentity.entity.DynamicObject;
import kd.bos.dataentity.entity.DynamicObjectCollection;
import kd.bos.dataentity.utils.ObjectUtils;
import kd.bos.dataentity.utils.StringUtils;
import kd.bos.entity.datamodel.ListSelectedRow;
import kd.bos.entity.datamodel.ListSelectedRowCollection;
import kd.bos.entity.property.PKFieldProp;
import kd.bos.form.*;
import kd.bos.form.events.AfterDoOperationEventArgs;
import kd.bos.form.events.BeforeDoOperationEventArgs;
import kd.bos.form.events.ClosedCallBackEvent;
import kd.bos.form.operate.FormOperate;
import kd.bos.list.IListView;
import kd.bos.list.IMobileListView;
import kd.bos.list.plugin.AbstractListPlugin;
import kd.bos.orm.query.QCP;
import kd.bos.orm.query.QFilter;
import kd.bos.report.IReportView;
import kd.bos.servicehelper.QueryServiceHelper;

import java.util.ArrayList;
import java.util.List;
import java.util.Map;

/**
 * 人事档案复用插件
 */
public class ErmanFileReusePlugin extends AbstractListPlugin {


    private static final String WORDCONVERSION = "wordconversion";

    @Override
    public void afterDoOperation(AfterDoOperationEventArgs e) {
        super.afterDoOperation(e);
        String operateKey = e.getOperateKey();
        if (StringUtils.equals(operateKey, WORDCONVERSION)) {
            //查询全部模板
            DynamicObjectCollection perProWordTempDy = queryPerProWord();
            //获取列表选择id
            List<Object> pkIds = this.getPKIds();
            //查询组织分配 人员employid  分配id
            QFilter qFilter = new QFilter("id", QCP.in, pkIds);
            DynamicObjectCollection employeeColl = QueryServiceHelper.query("hrpi_assignment", "id,employee.id,employee.name", qFilter.toArray());
            FormShowParameter showParameter = new FormShowParameter();
            OpenStyle openStyle = showParameter.getOpenStyle();
            openStyle.setShowType(ShowType.Modal);
            showParameter.setFormId("${ISV_FLAG}_hspm_wordtempprin");
            showParameter.setCloseCallBack(new CloseCallBack(this, "wordconversion"));
            //传参给子页面
            showParameter.setCustomParam("wordTemplate", perProWordTempDy);
            showParameter.setCustomParam("ermanFile", employeeColl);
            this.getView().showForm(showParameter);
        }
    }

    @Override
    public void beforeDoOperation(BeforeDoOperationEventArgs args) {
        super.beforeDoOperation(args);
        FormOperate source = (FormOperate) args.getSource();
        String operateKey = source.getOperateKey();
        if (StringUtils.equals(WORDCONVERSION, operateKey)) {
            DynamicObjectCollection perProWordTempDy = queryPerProWord();
            if (ObjectUtils.isEmpty(perProWordTempDy)) {
                this.getView().showErrorNotification("未找到对应模板！！！");
                args.setCancel(true);
            }

        }
    }

    @Override
    public void closedCallBack(ClosedCallBackEvent close) {
        super.closedCallBack(close);
        String actionId = close.getActionId();
        if (StringUtils.equals("wordconversion", actionId)) {
            Map<String, Object> returnData = (Map<String, Object>) close.getReturnData();
            if (!ObjectUtils.isEmpty(returnData)) {
                //下载附件
                this.getView().download((String) returnData.get("url"));
            }
        }

    }

    /**
     * @return kd.bos.dataentity.entity.DynamicObject
     * @description 查询对应信息公用类
     * @author ZhouPingHai
     * @lastModifiedBy: （填入修改人）
     * @lastModifyTime: （修改时间）
     * @Date 2023/7/3 17:54
     */
    private static DynamicObjectCollection queryPerProWord() {
        QFilter qFilter = new QFilter("status", QCP.equals, "C");
        qFilter.and("enable", QCP.equals, "1");
        return QueryServiceHelper.query("${ISV_FLAG}_hspm_wordconversion", "id,name,number", qFilter.toArray());
    }

    /**
     * @param
     * @return java.util.List<java.lang.Object>
     * @description 获取人员档案列表id
     * @author ZhouPingHai
     * @lastModifiedBy: （填入修改人）
     * @lastModifyTime: （修改时间）
     * @Date 2023/7/3 17:56
     */
    private List<Object> getPKIds() {
        List<Object> pkIds = new ArrayList<>();
        if (this.getView() instanceof IMobileView) {
            if (!(this.getView() instanceof IMobileListView)) {
                DynamicObject obj = this.getView().getModel().getDataEntity();
                Object pkValue = this.getView().getModel().getDataEntityType().getPrimaryKey().getValue((Object) obj);
                String defaultPk = "0";
                if (pkValue != null && !defaultPk.equals(pkValue)) {
                    pkIds.add(pkValue);
                }
            }
        } else if (this.getView() instanceof IListView) {
            ListSelectedRowCollection listSelectedRowCollection = ((IListView) this.getView()).getSelectedRows();
            if (!listSelectedRowCollection.isEmpty()) {
                for (ListSelectedRow listSelectedRowValue : listSelectedRowCollection) {
                    Object pkv = listSelectedRowValue.getPrimaryKeyValue();
                    if (!pkIds.contains(pkv)) {
                        pkIds.add(pkv);
                    }
                }
            }
        } else if (!(this.getView() instanceof IReportView)) {
            Object pkValue2 = this.getView().getModel().getDataEntity().getPkValue();
            PKFieldProp pkProp = (PKFieldProp) this.getView().getModel().getDataEntityType().getPrimaryKey();
            if (!pkProp.getValueComparator().compareValue(pkValue2)) {
                pkIds.add(pkValue2);
            }
        }
        return pkIds;
    }
}
