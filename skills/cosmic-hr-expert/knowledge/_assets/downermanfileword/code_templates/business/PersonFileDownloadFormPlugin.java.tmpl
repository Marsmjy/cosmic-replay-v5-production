public class PersonFileDownloadFormPlugin extends AbstractFormPlugin {
    private static final Log Logger = LogFactory.getLog(PersonFileDownloadFormPlugin.class);
    private static final Map<String, String> VECTORAP_FIELD;
    private static final List<String> MAIN_ERFILE_LIST;

    static {
        Map<String, String> tempMap = new HashMap<>();
        tempMap.put("gender", "kdfont kdfont-kehu4");
        tempMap.put("company", "kdfont kdfont-gongsi");
        tempMap.put("adminorg", "kdfont kdfont-bumen2");
        tempMap.put("position", "kdfont kdfont-gongwenbao");
        tempMap.put("stdposition", "kdfont kdfont-gongwenbao");
        tempMap.put("job", "kdfont kdfont-gongwenbao");
        tempMap.put("location", "kdfont kdfont-gongzuodi3");
        tempMap.put("phone", "kdfont kdfont-dianhua2");
        tempMap.put("peremail", "kdfont kdfont-youjian");
        VECTORAP_FIELD = Collections.unmodifiableMap(tempMap);

        List<String> tempList = new ArrayList<>();
        tempList.add("1110_S");
        tempList.add("1010_S");
        tempList.add("1150_S");
        tempList.add("1190_S");
        tempList.add("1070_S");
