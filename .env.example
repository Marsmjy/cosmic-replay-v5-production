# cosmic-replay-v2 环境变量配置示例
# 复制此文件到 .env 并填入真实值

# ============================================================
# 必需配置（登录凭证）
# ============================================================

# 苍穹用户名
COSMIC_USERNAME=your-username

# 苍穹密码（建议加密存储）
COSMIC_PASSWORD=your-password

# ============================================================
# 可选配置
# ============================================================

# Cookie（用于免登录，可选）
# COSMIC_COOKIE=your-cookie-value

# 加密密钥（自动生成，无需手动配置）
# COSMIC_SECRET_KEY=your-secret-key

# API认证密钥（Web UI访问控制，可选）
# COSMIC_API_KEY=your-api-key

# ============================================================
# 数据库配置（可选，默认使用SQLite）
# ============================================================

# DATABASE_URL=sqlite:///cosmic_replay.db
# DATABASE_URL=postgresql://user:pass@localhost:5432/cosmic_replay

# ============================================================
# 日志配置（可选）
# ============================================================

# 日志级别：debug, info, warn, error
LOG_LEVEL=info

# 日志目录
LOG_DIR=./logs

# ============================================================
# Web UI配置（可选）
# ============================================================

# 监听端口
PORT=8768

# 监听地址（0.0.0.0 允许局域网访问）
HOST=127.0.0.1

# 是否自动打开浏览器
OPEN_BROWSER=true
